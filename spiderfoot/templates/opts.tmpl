<!-- ==================== STATUS CARDS ==================== -->
<h5 class="ob-section-title"><i class="glyphicon glyphicon-stats"></i> API KEY STATUS</h5>
<p class="ob-muted">
Modules with <code>api_key</code> fields. Click <code>CONFIGURE</code> to jump to a module's settings.
</p>

<%
    _ob_configured = []
    _ob_missing = []
    for _ob_mod in sorted(opts['__modules__'].keys()):
        _ob_mopts = opts['__modules__'][_ob_mod].get('opts') or {}
        _ob_apikeys = {k: v for k, v in _ob_mopts.items() if 'api_key' in k or k in ('client_id', 'client_secret', 'access_token', 'github_token', 'api_email')}
        if _ob_apikeys:
            _ob_has_value = any(v and str(v).strip() for v in _ob_apikeys.values())
            _ob_name = opts['__modules__'][_ob_mod].get('name', _ob_mod)
            _ob_keys = ', '.join(sorted(_ob_apikeys.keys()))
            if _ob_has_value:
                _ob_configured.append((_ob_mod, _ob_name, _ob_keys))
            else:
                _ob_missing.append((_ob_mod, _ob_name, _ob_keys))
%>

<div class="row ob-stat-row">
