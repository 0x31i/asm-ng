  <i class="glyphicon glyphicon-ok-circle"></i> CONFIGURED MODULES
  <a href="javascript:void(0)" onclick="$('#ob-configured-table').toggle();" class="ob-toggle-link">[SHOW / HIDE]</a>
</h5>
<table class='table table-bordered table-condensed ob-table' id="ob-configured-table" style="display: none;">
<thead><tr><th class="ob-col-module">MODULE</th><th class="ob-col-keys">KEY(S)</th><th class="ob-col-action"></th></tr></thead>
<tbody>
% for (_ob_m, _ob_n, _ob_k) in _ob_configured:
<tr>
  <td><code>${_ob_n}</code></td>
  <td><code>${_ob_k}</code></td>
  <td class="ob-action-cell">
    <a href="javascript:void(0)" onclick="switchTab('${_ob_m}');" class="btn btn-xs ob-btn-view">VIEW</a>
  </td>
</tr>
% endfor
</tbody>
</table>
% endif

</div>
% endif

% for mod in sorted(opts['__modules__'].keys()):
    <%
        summary = opts['__modules__'][mod].get('descr') or 'No summary available.'
        categories = opts['__modules__'][mod].get('cats') or []
        labels = opts['__modules__'][mod].get('labels') or []
        meta = opts['__modules__'][mod].get('meta') or {}
        modopts = opts['__modules__'][mod].get('opts')
        optdescs = opts['__modules__'][mod].get('optdescs')
        data_source = meta.get('dataSource') or {}
        website = data_source.get('website') or ''
        description = data_source.get('description') or ''
        apiKeyInstructions = data_source.get('apiKeyInstructions') or ''
    %>
    <div id='optsect_${mod}' class="tab-pane" style="display: none">
    <h4>${opts['__modules__'][mod].get('name', mod)} (${mod})</h4>

    <table class='table table-bordered table-striped'>
    <tbody>
    <tr><td>Summary</td><td>${summary}<br/><br/>${description}</td></tr>

    % if categories:
    <tr><td>Categories:</td><td>${', '.join(categories)}</td><tr>
    % endif

    % if labels:
    <tr><td>Tags:</td><td>${', '.join(labels)}</td><tr>
    % endif

    % if website:
    <tr><td>Website:</td><td><a href="${website}" target=_new>${website}</a></td></tr>
    % endif

    </tbody>
    </table>

    <h4>Settings</h4>
    <table class='table table-bordered table-striped'>
    <thead><tr><th>Option</th> <th>Value</th></tr></thead>
    <tbody>

    % for opt in sorted(modopts.keys()):
        % if not opt.startswith("_"):
            <tr>
              <td>${optdescs.get(opt) or "No description available."}
                % if "api_key" in opt:
                    % if apiKeyInstructions:
                        <%
                            import re
                            instructions = ""
                            for step in apiKeyInstructions:
                                if "https://" in step or "http://" in step:
                                    step = re.sub(r'(https?://.[^ ]+)', '<a target=_new href=\'\\1\'>\\1</a>', step)
                                instructions += f"<li>{step}</li>"
                        %>
                        &nbsp;&nbsp;<a href='javascript:void(0)' data-html="true" data-toggle="popover" data-trigger="focus" title="Instructions" data-content="<ol>${instructions}</ol>"><i class="glyphicon glyphicon-question-sign"></i></a>
                    % endif
                % endif
              </td>
              <td style='vertical-align: middle'>
            % if type(modopts[opt]) is int:
                <div class='form-group'>
                    <input id='${mod}:${opt}' class='form-control' type=text value="${modopts[opt]}">
                </div>
            % endif
            % if type(modopts[opt]) is str:
                <div class='form-group'>
                    <input id='${mod}:${opt}' style='width: 500px' class='form-control' type=text value="${modopts[opt]}">
                </div>
            % endif
            % if type(modopts[opt]) is bool:
            <%
                if modopts[opt] == True:
                    seltrue = "selected"
                    selfalse = ""
                else:
                    selfalse = "selected"
                    seltrue = ""
            %>
                <select id='${mod}:${opt}' class='form-control'>
                    <option value=1 ${seltrue}>True</option>
                    <option value=0 ${selfalse}>False</option>                </select>
            % endif
            % if type(modopts[opt]) is list and len(modopts[opt]) > 0 and type(modopts[opt][0]) is str:
                <% expandedopt = ','.join(modopts[opt]) %>
                <div class='form-group'>
                    <input id='${mod}:${opt}' style='width: 500px' class='form-control' type=text value="${expandedopt}">
                </div>
            % endif
            % if type(modopts[opt]) is list and len(modopts[opt]) > 0 and type(modopts[opt][0]) is int:
                <% expandedopt = ','.join(str(x) for x in modopts[opt]) %>
                <div class='form-group'>
                    <input id='${mod}:${opt}' class='form-control' type=text value="${expandedopt}">
                </div>
            % endif
            % if type(modopts[opt]) is list and len(modopts[opt]) == 0:
                <div class='form-group'>
                    <input id='${mod}:${opt}' style='width: 500px' class='form-control' type=text value="" placeholder="Enter comma-separated values">
                </div>
            % endif

            </td></tr>
        % endif
    % endfor
    </tbody>
    </table>
    </div>
% endfor
<div id='optsect_logs' class="tab-pane" style="display: none">
<script>document.write('<script type="text/javascript" src="${docroot}/static/js/spiderfoot.logs.js?v=' + Date.now() + '"><\/script>');</script>

<style>
/* Log Management — scoped styles */
#optsect_logs { width: 100%; max-width: 100%; padding: 0; }
#optsect_logs .log-header { margin-bottom: 20px; }
#optsect_logs .log-header h4 { margin-bottom: 4px; }
#optsect_logs .log-subtitle { color: var(--text-muted, #6b7280); font-size: 13px; font-family: var(--font-sans, sans-serif); }

/* Sub-tab pills — !important needed to override global a { color: green !important } */
#optsect_logs .log-pills { display: flex; gap: 4px; margin-bottom: 20px; flex-wrap: wrap; }
#optsect_logs .log-pills a,
#optsect_logs .log-pills a:visited {
  display: inline-block;
  padding: 7px 16px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  font-family: var(--font-mono, monospace);
  color: var(--text-secondary, #4b5563) !important;
  background: var(--bg-tertiary, #e9ecef) !important;
  text-decoration: none !important;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all 0.2s ease;
  cursor: pointer;
  border: 1px solid transparent;
}
#optsect_logs .log-pills a:hover,
#optsect_logs .log-pills a:focus {
  background: var(--bg-elevated, #fff) !important;
  color: var(--text-primary, #1f2937) !important;
  border-color: var(--accent-cyan, #0891b2);
}
#optsect_logs .log-pills a.active,
#optsect_logs .log-pills a.active:visited,
#optsect_logs .log-pills a.active:hover,
#optsect_logs .log-pills a.active:focus {
  background: linear-gradient(135deg, var(--accent-cyan, #0891b2) 0%, var(--accent-cyan-light, #06b6d4) 100%) !important;
  color: #ffffff !important;
  box-shadow: 0 2px 8px var(--glow-cyan, rgba(8, 145, 178, 0.25));
  border-color: transparent;
}

/* Filter bar */
#optsect_logs .log-filters {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: 12px;
}
#optsect_logs .log-filters select,
#optsect_logs .log-filters input[type="text"],
#optsect_logs .log-filters input[type="date"],
#optsect_logs .log-filters input[type="number"] {
  height: 32px;
  font-size: 12px;
  font-family: var(--font-mono, monospace);
  border-radius: 4px;
  border: 1px solid var(--bg-tertiary, #d1d5db);
  background: var(--bg-secondary, #f8f9fa);
  color: var(--text-primary, #1f2937);
  padding: 4px 8px;
}
#optsect_logs .log-filters select { min-width: 140px; }
#optsect_logs .log-filters input[type="text"] { min-width: 120px; }
#optsect_logs .log-filters input[type="date"] { min-width: 130px; }
#optsect_logs .log-filters .filter-sep { flex-grow: 1; }

/* Ensure tables fill full width */
#optsect_logs .table { width: 100% !important; table-layout: auto; }

/* Override Bootstrap col-md-9 padding pushing content right */
#optsect_logs .log-filters a,
#optsect_logs .log-meta a,
#optsect_logs .retention-section a {
  color: var(--accent-cyan, #0891b2) !important;
}

/* Log count */
#optsect_logs .log-meta {
  font-size: 11px;
  color: var(--text-muted, #6b7280);
  font-family: var(--font-mono, monospace);
  margin-bottom: 6px;
  letter-spacing: 0.3px;
}

/* System log pre */
#optsect_logs #syslog-content {
  max-height: 500px;
  overflow-y: auto;
  font-size: 12px;
  font-family: var(--font-mono, monospace);
  background: var(--bg-tertiary, #1a1a2e);
  color: var(--text-primary, #e0e0e0);
  padding: 12px;
  border-radius: 6px;
  border: 1px solid var(--bg-elevated, #2a2a2a);
  line-height: 1.5;
}

/* Retention section */
#optsect_logs .retention-section { margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--bg-tertiary, #e9ecef); }
#optsect_logs .retention-row { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 12px; }
#optsect_logs .retention-field label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted, #6b7280);
  margin-bottom: 4px;
  font-family: var(--font-mono, monospace);
}
#optsect_logs .retention-field input {
  width: 120px;
  height: 32px;
  font-size: 12px;
  font-family: var(--font-mono, monospace);
  border-radius: 4px;
  border: 1px solid var(--bg-tertiary, #d1d5db);
  background: var(--bg-secondary, #f8f9fa);
  color: var(--text-primary, #1f2937);
  padding: 4px 8px;
}

/* Checkbox label */
#optsect_logs .check-label {
  font-size: 12px;
  font-weight: normal;
  font-family: var(--font-mono, monospace);
  color: var(--text-secondary, #4b5563);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
}
</style>

<div class="log-header">
  <h4>Log Management</h4>
  <div class="log-subtitle">Centralized view of all system logs. Admin only.</div>
</div>

<!-- Log sub-tabs -->
<div class="log-pills">
  <a id="logtab_activity" class="active" onclick="LogsUI.switchLogTab('activity')">Activity Log</a>
  <a id="logtab_scanlogs" onclick="LogsUI.switchLogTab('scanlogs')">Scan Logs</a>
  <a id="logtab_apiaccess" onclick="LogsUI.switchLogTab('apiaccess')">API Access</a>
  <a id="logtab_requests" onclick="LogsUI.switchLogTab('requests')">HTTP Requests</a>
  <a id="logtab_system" onclick="LogsUI.switchLogTab('system')">System</a>
</div>

<!-- ===== Activity Log ===== -->
<div id="logpane_activity">
  <div class="log-filters">
    <select id="log-filter-action"><option value="">All Actions</option></select>
    <select id="log-filter-user"><option value="">All Users</option></select>
    <input type="text" id="log-filter-search" placeholder="Search details...">
    <input type="date" id="log-filter-datefrom" title="From date">
    <input type="date" id="log-filter-dateto" title="To date">
    <span class="filter-sep"></span>
    <button class="btn btn-primary btn-sm" onclick="LogsUI.loadAuditLog(0)">Filter</button>
    <button class="btn btn-default btn-sm" onclick="LogsUI.exportLogCSV('audit')" title="Export CSV"><i class="glyphicon glyphicon-download-alt"></i> CSV</button>
  </div>
  <div class="log-meta">Total: <strong><span id="audit-log-count">0</span></strong> entries</div>
  <table class="table table-striped table-condensed">
    <thead><tr>
      <th style="width:155px;">Time</th>
      <th style="width:100px;">User</th>
      <th style="width:150px;">Action</th>
      <th>Details</th>
      <th style="width:120px;">IP Address</th>
    </tr></thead>
    <tbody id="audit-log-body"></tbody>
  </table>
  <div id="audit-pagination"></div>
</div>

<!-- ===== Scan Logs ===== -->
<div id="logpane_scanlogs" style="display:none">
  <div class="log-filters">
    <select id="scanlog-filter-scan" style="min-width:220px;"><option value="">All Scans</option></select>
    <select id="scanlog-filter-type">
      <option value="">All Types</option>
      <option value="ERROR">Error</option>
      <option value="WARNING">Warning</option>
      <option value="STATUS">Status</option>
      <option value="PROGRESS">Progress</option>
      <option value="DEBUG">Debug</option>
    </select>
    <input type="text" id="scanlog-filter-component" placeholder="Component...">
    <input type="text" id="scanlog-filter-search" placeholder="Search message...">
    <span class="filter-sep"></span>
    <button class="btn btn-primary btn-sm" onclick="LogsUI.loadScanLogs(0)">Filter</button>
    <button class="btn btn-default btn-sm" onclick="LogsUI.exportLogCSV('scanlogs')" title="Export CSV"><i class="glyphicon glyphicon-download-alt"></i> CSV</button>
  </div>
  <div class="log-meta">Total: <strong><span id="scanlog-count">0</span></strong> entries</div>
  <table class="table table-striped table-condensed">
    <thead><tr>
      <th style="width:155px;">Time</th>
      <th style="width:180px;">Scan</th>
      <th style="width:130px;">Component</th>
      <th style="width:85px;">Type</th>
      <th>Message</th>
    </tr></thead>
    <tbody id="scanlog-body"></tbody>
  </table>
  <div id="scanlog-pagination"></div>
</div>

<!-- ===== API Access ===== -->
<div id="logpane_apiaccess" style="display:none">
  <div class="log-subtitle" style="margin-bottom:12px;">External API activity &mdash; requests, auth failures, rate limits, and key lifecycle events.</div>
  <div class="log-meta">Total: <strong><span id="api-access-count">0</span></strong> entries</div>
  <table class="table table-striped table-condensed">
    <thead><tr>
      <th style="width:155px;">Time</th>
      <th style="width:100px;">User / Key</th>
      <th style="width:150px;">Action</th>
      <th>Details</th>
      <th style="width:120px;">IP Address</th>
    </tr></thead>
    <tbody id="api-access-body"></tbody>
  </table>
  <div id="api-pagination"></div>
</div>

<!-- ===== HTTP Requests ===== -->
<div id="logpane_requests" style="display:none">
  <div class="log-filters">
    <input type="text" id="reqlog-filter-user" placeholder="Username...">
    <input type="text" id="reqlog-filter-path" placeholder="Path filter..." style="min-width:200px;">
    <span class="filter-sep"></span>
    <button class="btn btn-primary btn-sm" onclick="LogsUI.loadRequestLog(0)">Filter</button>
    <button class="btn btn-default btn-sm" onclick="LogsUI.exportLogCSV('requests')" title="Export CSV"><i class="glyphicon glyphicon-download-alt"></i> CSV</button>
  </div>
  <div class="log-meta">Total: <strong><span id="reqlog-count">0</span></strong> entries</div>
  <table class="table table-striped table-condensed">
    <thead><tr>
      <th style="width:155px;">Time</th>
      <th style="width:100px;">User</th>
      <th style="width:65px;">Method</th>
      <th>Path</th>
      <th style="width:60px;">Status</th>
      <th style="width:75px;">Latency</th>
      <th style="width:120px;">IP Address</th>
    </tr></thead>
    <tbody id="reqlog-body"></tbody>
  </table>
  <div id="reqlog-pagination"></div>
</div>

<!-- ===== System Log ===== -->
<div id="logpane_system" style="display:none">
  <div class="log-filters">
    <select id="syslog-select">
      <option value="debug">debug.log</option>
      <option value="error">error.log</option>
    </select>
    <input type="number" id="syslog-lines" value="200" min="50" max="2000" style="width:80px;" title="Lines to show">
    <button class="btn btn-primary btn-sm" onclick="LogsUI.loadSystemLog($('#syslog-select').val())">Load</button>
    <label class="check-label">
      <input type="checkbox" id="syslog-autorefresh" onchange="LogsUI.toggleAutoRefresh(this.checked)"> Auto-refresh (10s)
    </label>
  </div>
  <div class="log-meta">File: <strong><span id="syslog-filename"></span></strong></div>
  <pre id="syslog-content"></pre>
</div>

<!-- ===== Log Retention ===== -->
<div class="retention-section">
  <h5>Log Retention</h5>
  <div class="log-subtitle" style="margin-bottom:12px;">
    Configure how long log entries are retained. Old entries are automatically purged on server startup.
  </div>
  <div class="retention-row">
    <div class="retention-field">
      <label>Audit Log (days)</label>
      <input type="number" id="retention-audit-days" value="365" min="7">
    </div>
    <div class="retention-field">
      <label>Scan Logs (days)</label>
      <input type="number" id="retention-scan-days" value="90" min="7">
    </div>
    <div class="retention-field">
      <label>Request Log (days)</label>
      <input type="number" id="retention-request-days" value="30" min="7">
    </div>
  </div>
  <div style="display: flex; gap: 10px; align-items: center;">
    <button class="btn btn-primary btn-sm" onclick="LogsUI.saveRetentionSettings()">Save Retention Settings</button>
    <button class="btn btn-danger btn-sm" onclick="LogsUI.purgeLogsManual()">Purge Now</button>
  </div>
  <div id="retention-result" style="display:none; margin-top: 8px;"></div>
</div>

<script>
$(document).ready(function() {
    $.getJSON(docroot + '/logsettingsget', function(data) {
        if (data.audit_days) $('#retention-audit-days').val(data.audit_days);
        if (data.scan_days) $('#retention-scan-days').val(data.scan_days);
        if (data.request_days) $('#retention-request-days').val(data.request_days);
    });
});
</script>

</div>
</div> <!-- /tab-content col-md-9 -->
</div> <!-- /tabbable tabs-left -->
</form>

<!-- Unsaved Changes Warning Modal -->
<div id="unsaved-warning-overlay" class="unsaved-warning-overlay" style="display: none;">
  <div class="unsaved-warning-modal">
    <div class="unsaved-warning-icon">&#9888;</div>
    <div class="unsaved-warning-title">UNSAVED CHANGES</div>
    <div class="unsaved-warning-message">You have unsaved settings changes that will be lost if you leave this page.</div>
    <div class="unsaved-warning-actions">
      <button id="unsaved-warning-leave" class="unsaved-warning-btn unsaved-warning-btn-leave" type="button">CANCEL &amp; LEAVE</button>
      <button id="unsaved-warning-continue" class="unsaved-warning-btn unsaved-warning-btn-continue" type="button">CONTINUE EDITING</button>
      <button id="unsaved-warning-save" class="unsaved-warning-btn unsaved-warning-btn-save" type="button">SAVE &amp; LEAVE</button>
    </div>
  </div>
</div>

