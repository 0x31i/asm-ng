        // ===== SNAPSHOT RENDERING FUNCTIONS =====

        // Category color map for trend chart lines
        var snapshotCategoryColors = {
            'Network Security': '#dc2626',
            'Web App Security': '#ea580c',
            'Information Leakage': '#eab308',
            'General Health': '#3b82f6',
            'External Account Exposure': '#06b6d4',
            'DNS Health': '#22c55e',
            'IP Reputation': '#d946ef',
            'AI Security': '#8b5cf6',
            'Information / Reference': '#6b7280'
        };

        // Resolve CSS variable values for use in D3 SVG attributes (CSS vars don't work in SVG fill/stroke)
        function cssVar(name) {
            return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
        }

        function renderSnapshotChart(trendData, instanceId) {
            var container = document.getElementById('snapshot-chart');
            if (!container || !trendData.snapshots || trendData.snapshots.length < 2) return;

            var snaps = trendData.snapshots;
            var margin = {top: 20, right: 28, bottom: 40, left: 45};
            // Filter out excluded snapshots entirely — they don't appear on the chart
            var snaps = trendData.snapshots.filter(function(d) { return !d.excluded; });
            if (snaps.length < 2) return;
            var margin = {top: 20, right: 20, bottom: 40, left: 45};
            var width = container.offsetWidth - margin.left - margin.right;
            var height = 280 - margin.top - margin.bottom;

            // Clear any previous chart + tooltip
            d3.select('#snapshot-chart').selectAll('*').remove();
            d3.select('#snapshot-tooltip').remove();

            var rootSvg = d3.select('#snapshot-chart').append('svg')
                .attr('width', width + margin.left + margin.right)
                .attr('height', height + margin.top + margin.bottom);

            // ── SVG defs: gradient + glow filter ──────────────────────────
            var defs = rootSvg.append('defs');

            var latestActive;
            var activeSnaps = snaps.filter(function(d) { return !d.excluded; });
            latestActive = activeSnaps.length > 0 ? activeSnaps[activeSnaps.length - 1] : snaps[snaps.length - 1];
            var gc = gradeGlowColor(latestActive.overall_grade);

            // Vertical gradient for area fill (line color → transparent)
            var areaGrad = defs.append('linearGradient')
                .attr('id', 'snap-area-grad').attr('x1', '0').attr('y1', '0')
                .attr('x2', '0').attr('y2', '1');
            areaGrad.append('stop').attr('offset', '0%')
                .attr('stop-color', gc.text).attr('stop-opacity', 0.25);
            areaGrad.append('stop').attr('offset', '100%')
                .attr('stop-color', gc.text).attr('stop-opacity', 0.02);

            // Glow filter for the main line
            var glowFilter = defs.append('filter')
                .attr('id', 'snap-line-glow').attr('x', '-20%').attr('y', '-20%')
                .attr('width', '140%').attr('height', '140%');
            glowFilter.append('feGaussianBlur').attr('in', 'SourceGraphic')
                .attr('stdDeviation', '4').attr('result', 'blur');
            glowFilter.append('feComposite').attr('in', 'SourceGraphic')
                .attr('in2', 'blur').attr('operator', 'over');

            // Pulse animation for current-scan dot
            var pulseAnim = defs.append('radialGradient')
                .attr('id', 'snap-pulse-grad');
            pulseAnim.append('stop').attr('offset', '0%')
                .attr('stop-color', gc.text).attr('stop-opacity', 0.6);
            pulseAnim.append('stop').attr('offset', '100%')
                .attr('stop-color', gc.text).attr('stop-opacity', 0);

            var svg = rootSvg.append('g')
                .attr('transform', 'translate(' + margin.left + ',' + margin.top + ')');

            // ── Custom tooltip element ────────────────────────────────────
            var tooltip = d3.select('#snapshot-chart').append('div')
                .attr('id', 'snapshot-tooltip')
                .style('position', 'absolute').style('pointer-events', 'none')
                .style('background', 'var(--bg-elevated, #1f2937)')
                .style('border', '1px solid var(--glass-border, #374151)')
                .style('border-radius', '6px').style('padding', '8px 12px')
                .style('font-family', 'var(--font-mono)').style('font-size', '11px')
                .style('color', 'var(--text-primary, #f9fafb)')
                .style('box-shadow', '0 4px 16px rgba(0,0,0,0.4)')
                .style('opacity', 0).style('z-index', 100)
                .style('white-space', 'nowrap').style('transition', 'opacity 0.15s ease');

            // ── Scales ────────────────────────────────────────────────────
            var parseDate = function(d) { return new Date(d); };
            var xExtent = d3.extent(snaps, function(d) { return parseDate(d.date); });
            var x = d3.time.scale().domain(xExtent).range([0, width]);
            var y = d3.scale.linear().domain([0, 100]).range([height, 0]);

            // ── Grade band backgrounds (subtle fills) ─────────────────────
            var gradeBands = [
                {min: 90, max: 100, color: 'rgba(34, 197, 94, 0.05)', label: 'A', textColor: '#22c55e'},
                {min: 80, max: 90, color: 'rgba(59, 130, 246, 0.05)', label: 'B', textColor: '#3b82f6'},
                {min: 70, max: 80, color: 'rgba(245, 158, 11, 0.05)', label: 'C', textColor: '#f59e0b'},
                {min: 60, max: 70, color: 'rgba(249, 115, 22, 0.05)', label: 'D', textColor: '#f97316'},
                {min: 0, max: 60, color: 'rgba(239, 68, 68, 0.04)', label: 'F', textColor: '#ef4444'}
            ];

            gradeBands.forEach(function(band) {
                svg.append('rect')
                    .attr('x', 0).attr('y', y(band.max))
                    .attr('width', width).attr('height', y(band.min) - y(band.max))
                    .attr('fill', band.color);
                svg.append('text')
                    .attr('x', width + 8).attr('y', y((band.min + band.max) / 2) + 4)
                    .style('font-size', '9px').style('fill', band.textColor)
                    .style('font-family', 'var(--font-mono)')
                    .style('font-weight', '600').style('opacity', 0.5)
                    .text(band.label);
            });

            // ── Horizontal gridlines at grade thresholds ──────────────────
            [90, 80, 70, 60].forEach(function(threshold) {
                svg.append('line')
                    .attr('x1', 0).attr('y1', y(threshold))
                    .attr('x2', width).attr('y2', y(threshold))
                    .attr('stroke', cssVar('--glass-border')).attr('stroke-width', 0.5)
                    .attr('stroke-dasharray', '2,4').attr('opacity', 0.6);
            });
            // Subtle intermediate gridlines (every 20 units)
            [20, 40].forEach(function(val) {
                svg.append('line')
                    .attr('x1', 0).attr('y1', y(val))
                    .attr('x2', width).attr('y2', y(val))
                    .attr('stroke', cssVar('--glass-border')).attr('stroke-width', 0.3)
                    .attr('stroke-dasharray', '1,5').attr('opacity', 0.4);
            });

            // ── Axes (clean, minimal style) ───────────────────────────────
            var xAxis = d3.svg.axis().scale(x).orient('bottom')
                .ticks(Math.min(snaps.length, 8))
                .tickFormat(d3.time.format('%b %d'));
            var xAxisG = svg.append('g')
                .attr('class', 'x-axis')
                .attr('transform', 'translate(0,' + height + ')')
                .call(xAxis);
            xAxisG.selectAll('text')
                .style('font-size', '9px').style('fill', cssVar('--text-secondary'))
                .style('font-family', 'var(--font-mono)');
            xAxisG.selectAll('.domain').attr('stroke', 'none').attr('fill', 'none');
            xAxisG.selectAll('.tick line').attr('stroke', cssVar('--glass-border'))
                .attr('opacity', 0.4);

            var yAxis = d3.svg.axis().scale(y).orient('left').ticks(5)
                .tickSize(-width);  // extend gridlines across chart width
            var yAxisG = svg.append('g')
                .attr('class', 'y-axis')
                .call(yAxis);
            yAxisG.selectAll('text')
                .style('font-size', '9px').style('fill', cssVar('--text-secondary'))
                .style('font-family', 'var(--font-mono)');
            yAxisG.selectAll('.domain').attr('stroke', 'none').attr('fill', 'none');
            yAxisG.selectAll('.tick line').attr('stroke', cssVar('--glass-border'))
                .attr('opacity', 0.15).attr('stroke-dasharray', 'none');

            // ── Line + Area generators ────────────────────────────────────
            // Overall line with area fill
            var overallLine = d3.svg.line()
                .x(function(d) { return x(parseDate(d.date)); })
                .y(function(d) { return y(d.overall_score); })
                .interpolate('monotone');

            var overallArea = d3.svg.area()
                .x(function(d) { return x(parseDate(d.date)); })
                .y0(height)
                .y1(function(d) { return y(d.overall_score); })
                .interpolate('monotone');

            // ── Render overall area + line (active snapshots only) ────────
            if (activeSnaps.length > 0) {
                // Gradient area fill
                svg.append('path')
                    .datum(activeSnaps)
                    .attr('d', overallArea)
                    .attr('fill', 'url(#snap-area-grad)')
                    .attr('class', 'snapshot-line-overall');

                // Glow line (wider, blurred)
                svg.append('path')
                    .datum(activeSnaps)
                    .attr('d', overallLine)
                    .attr('fill', 'none').attr('stroke', gc.text)
                    .attr('stroke-width', 6).attr('opacity', 0.2)
                    .attr('filter', 'url(#snap-line-glow)')
                    .attr('class', 'snapshot-line-overall');

                // Main line
                var mainLine = svg.append('path')
                    .datum(activeSnaps)
                    .attr('d', overallLine)
                    .attr('fill', 'none').attr('stroke', gc.text)
                    .attr('stroke-width', 2.5)
                    .attr('stroke-linecap', 'round')
                    .attr('stroke-linejoin', 'round')
                    .attr('class', 'snapshot-line-overall');

                // Line draw-in animation
                try {
                    var totalLength = mainLine.node().getTotalLength();
                    mainLine
                        .attr('stroke-dasharray', totalLength + ' ' + totalLength)
                        .attr('stroke-dashoffset', totalLength)
                        .transition().duration(1200).ease('cubic-out')
                        .attr('stroke-dashoffset', 0);
                } catch(e) { /* animation non-critical */ }
            }

            // ── Data points ───────────────────────────────────────────────
            // Pulse ring on current scan
            var currentSnap = null;
            snaps.forEach(function(s) { if (s.scan_id === instanceId) currentSnap = s; });
            if (currentSnap && !currentSnap.excluded) {
                svg.append('circle')
                    .attr('class', 'snapshot-dot-overall')
                    .attr('cx', x(parseDate(currentSnap.date)))
                    .attr('cy', y(currentSnap.overall_score))
                    .attr('r', 12).attr('fill', 'url(#snap-pulse-grad)')
                    .style('animation', 'snap-pulse 2s ease-in-out infinite');
            }

            // Outer ring for active dots
            svg.selectAll('.snapshot-ring-overall')
                .data(snaps.filter(function(d) { return !d.excluded; }))
                .enter().append('circle')
                .attr('class', 'snapshot-dot-overall')
                .attr('cx', function(d) { return x(parseDate(d.date)); })
                .attr('cy', function(d) { return y(d.overall_score); })
                .attr('r', 6)
                .attr('fill', 'none')
                .attr('stroke', gc.text).attr('stroke-width', 1)
                .attr('opacity', 0.3);

            // Data points for overall (interactive dots with tooltips)
            svg.selectAll('.snapshot-dot-interactive')
                .data(snaps).enter().append('circle')
                .attr('class', 'snapshot-dot-overall')
                .attr('cx', function(d) { return x(parseDate(d.date)); })
                .attr('cy', function(d) { return y(d.overall_score); })
                .attr('r', 4).attr('fill', gc.text).attr('stroke', '#fff').attr('stroke-width', 1.5)
                .style('cursor', 'pointer')
                .on('mouseover', function(d) {
                    var dt = new Date(d.date);
                    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                    var prefix = d.excluded ? '<span style="color:#ef4444;">EXCLUDED</span> &middot; ' : '';
                    var isCurrent = d.scan_id === instanceId;
                    var gcLocal = gradeGlowColor(d.overall_grade);
                    tooltip.html(
                        prefix +
                        '<span style="color:var(--text-secondary);">' + months[dt.getMonth()] + ' ' + dt.getDate() + ', ' + dt.getFullYear() + '</span>' +
                        '<br><span style="font-size:16px;font-weight:700;color:' + gcLocal.text + ';">' + d.overall_grade + '</span>' +
                        ' <span style="color:var(--text-secondary);">' + d.overall_score.toFixed(1) + '</span>' +
                        (isCurrent ? ' <span style="font-size:8px;background:var(--glass-border);padding:1px 5px;border-radius:3px;color:var(--text-muted);">CURRENT</span>' : '')
                    ).style('opacity', 1);
                    d3.select(this).transition().duration(150).attr('r', d.excluded ? 4 : 6);
                })
                .on('mousemove', function() {
                    var pos = d3.mouse(container);
                    tooltip
                        .style('left', (pos[0] + 16) + 'px')
                        .style('top', (pos[1] - 10) + 'px');
                })
                .on('mouseout', function(d) {
                    tooltip.style('opacity', 0);
                    d3.select(this).transition().duration(150).attr('r', d.excluded ? 3 : 4);
                })
                .on('click', function(d) {
                    window.location.hash = '#id=' + d.scan_id + '&tab=summary';
                    location.reload();
                })
                .append('title').text(function(d) {
                    var dt = new Date(d.date);
                    return dt.toLocaleDateString() + ' - ' + d.overall_grade + ' (' + d.overall_score.toFixed(1) + ')';
                });

            // ── Category lines (dashed, toggleable) ──────────────────────
            var categoryNames = [];
            var allCats = snaps[snaps.length - 1].categories || {};
            for (var catName in allCats) {
                if (allCats[catName].weight > 0) categoryNames.push(catName);
            }

            categoryNames.forEach(function(catName) {
                var catLine = d3.svg.line()
                    .x(function(d) { return x(parseDate(d.date)); })
                    .y(function(d) {
                        var cats = d.categories || {};
                        return y(cats[catName] ? cats[catName].score : 0);
                    })
                    .interpolate('monotone');

                svg.append('path')
                    .datum(snaps)
                    .attr('d', catLine)
                    .attr('fill', 'none')
                    .attr('stroke', snapshotCategoryColors[catName] || '#6b7280')
                    .attr('stroke-width', 1.5)
                    .attr('stroke-dasharray', '5,3')
                    .attr('stroke-linecap', 'round')
                    .attr('class', 'snapshot-cat-line')
                    .attr('data-category', catName)
                    .style('display', 'none');
            });

            // ── Legend (pill-style toggles) ───────────────────────────────
            var legendEl = document.getElementById('snapshot-legend');
            if (!legendEl) return;
            legendEl.innerHTML = '';

            function hexToRgba(hex, alpha) {
                var r = parseInt(hex.slice(1,3), 16), g = parseInt(hex.slice(3,5), 16), b = parseInt(hex.slice(5,7), 16);
                return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
            }

            function makeLegendPill(label, color, isActive, onToggle) {
                var el = document.createElement('span');
                var activeBg = color.charAt(0) === '#' ? hexToRgba(color, 0.15) : color.replace(')', ', 0.15)').replace('rgb', 'rgba');
                function applyStyle(active) {
                    el.style.cssText = 'cursor:pointer;padding:3px 10px;border-radius:12px;font-size:10px;' +
                        'font-family:var(--font-mono);letter-spacing:0.5px;transition:all 0.2s ease;' +
                        'border:1px solid ' + color + ';' +
                        'color:' + (active ? color : 'var(--text-muted)') + ';' +
                        'background:' + (active ? activeBg : 'transparent') + ';' +
                        'opacity:' + (active ? '1' : '0.45') + ';';
                }
                applyStyle(isActive);
                el.innerHTML = '<span style="font-size:7px;vertical-align:1px;">&#9679;</span> ' + label;
                el.setAttribute('data-active', isActive ? 'true' : 'false');
                el.onclick = function() {
                    var active = this.getAttribute('data-active') === 'true';
                    this.setAttribute('data-active', active ? 'false' : 'true');
                    applyStyle(!active);
                    onToggle(!active);
                };
                return el;
            }

            // Overall toggle
            legendEl.appendChild(makeLegendPill('OVERALL', gc.text, true, function(active) {
                d3.selectAll('.snapshot-line-overall, .snapshot-dot-overall').style('display', active ? null : 'none');
            }));

            // Category toggles
            categoryNames.forEach(function(catName) {
                var color = snapshotCategoryColors[catName] || '#6b7280';
                legendEl.appendChild(makeLegendPill(catName, color, false, function(active) {
                    d3.selectAll('.snapshot-cat-line[data-category="' + catName + '"]').style('display', active ? null : 'none');
                }));
            });

            // ── Inject CSS keyframes for pulse animation ──────────────────
            if (!document.getElementById('snap-pulse-style')) {
                var style = document.createElement('style');
                style.id = 'snap-pulse-style';
                style.textContent = '@keyframes snap-pulse { 0%,100% { opacity:0.4; transform-origin:center; } 50% { opacity:0.15; } }';
                document.head.appendChild(style);
            }
        }

        function renderSnapshotMetrics(trendData) {
            var container = document.getElementById('snapshot-metrics');
            if (!container || !trendData.deltas) return;

            var d = trendData.deltas;
            var cards = [];

            // 1. Overall Change
            var oc = d.overall_change || 0;
            var ocColor = oc > 0 ? '#22c55e' : (oc < 0 ? '#ef4444' : '#6b7280');
            var ocArrow = oc > 0 ? '&#x25B2;' : (oc < 0 ? '&#x25BC;' : '&#x25C6;');
            cards.push({label: 'CHANGE', value: (oc > 0 ? '+' : '') + oc.toFixed(1), color: ocColor, icon: ocArrow, sublabel: 'vs first scan'});

            // 2. Trajectory
            var tj = d.trajectory || 'stable';
            var tjColor = tj === 'improving' ? '#22c55e' : (tj === 'degrading' ? '#ef4444' : '#6b7280');
            var tjArrow = tj === 'improving' ? '&#x25B2;' : (tj === 'degrading' ? '&#x25BC;' : '&#x25C6;');
            cards.push({label: 'TREND', value: tj.toUpperCase(), color: tjColor, icon: tjArrow, sublabel: 'overall trajectory'});

            // 3. Worst Category
            var wc = d.worst_category;
            if (wc) {
                var wcGc = gradeGlowColor(wc.grade);
                cards.push({label: 'WORST', value: wc.grade, sublabel: wc.name, color: wcGc.text, icon: ''});
            } else {
                cards.push({label: 'WORST', value: '-', color: '#6b7280', icon: ''});
            }

            // 4. Best Category
            var bc = d.best_category;
            if (bc) {
                var bcGc = gradeGlowColor(bc.grade);
                cards.push({label: 'BEST', value: bc.grade, sublabel: bc.name, color: bcGc.text, icon: ''});
            } else {
                cards.push({label: 'BEST', value: '-', color: '#6b7280', icon: ''});
            }

            // 5. Timeframe
            var snaps = trendData.snapshots || [];
            var tfVal = '-';
            var tfSublabel = '';
            if (snaps.length >= 2) {
                var firstDate = snaps[0].date || 0;
                var lastDate = snaps[snaps.length - 1].date || 0;
                if (firstDate && lastDate) {
                    var days = Math.max(1, Math.round((lastDate - firstDate) / 86400000));
                    tfVal = days + ' days';
                    var d1 = new Date(firstDate);
                    var d2 = new Date(lastDate);
                    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                    tfSublabel = months[d1.getMonth()] + ' ' + d1.getDate() + ' \u2013 ' + months[d2.getMonth()] + ' ' + d2.getDate();
                }
            }
            cards.push({label: 'TIMEFRAME', value: tfVal, color: '#8b5cf6', icon: '', sublabel: tfSublabel || '-'});

            // 6. Scan Count
            cards.push({label: 'SCANS', value: trendData.scan_count || snaps.length, color: '#06b6d4', icon: '', sublabel: 'data points'});

            var html = '';
            cards.forEach(function(card) {
                // Adaptive font size based on value length for visual balance
                var valStr = String(card.value);
                var vLen = valStr.length;
                var fontSize = vLen <= 2 ? '22px' : (vLen <= 4 ? '18px' : (vLen <= 7 ? '15px' : '12px'));
                var iconSize = vLen <= 2 ? '12px' : (vLen <= 4 ? '10px' : '9px');

                html += "<div style='background:var(--bg-tertiary);border:1px solid var(--glass-border);border-left:3px solid " + card.color + ";border-radius:6px;padding:10px 8px;text-align:center;min-width:0;overflow:hidden;display:flex;flex-direction:column;justify-content:center;'>";
                html += "<div style='font-size:" + fontSize + ";font-weight:700;color:" + card.color + ";font-family:var(--font-mono);line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;'>";
                if (card.icon) html += "<span style='font-size:" + iconSize + ";vertical-align:middle;'>" + card.icon + "</span> ";
                html += valStr + "</div>";
                html += "<div style='font-size:9px;color:var(--text-muted);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:1px;margin-top:4px;'>" + card.label + "</div>";
                if (card.sublabel) {
                    html += "<div style='font-size:8px;color:var(--text-secondary);font-family:var(--font-mono);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;'>" + card.sublabel + "</div>";
                }
                html += "</div>";
            });

            container.innerHTML = html;
        }

        function renderSnapshotTable(trendData, instanceId) {
            var container = document.getElementById('snapshot-table-container');
            if (!container || !trendData.snapshots || trendData.snapshots.length < 2) return;

            // Filter out excluded snapshots — they don't appear in the table
            var snaps = trendData.snapshots.filter(function(d) { return !d.excluded; });
            if (snaps.length < 2) {
                container.innerHTML = '';
                return;
            }
            // Show last 8 non-excluded scans max
            var displaySnaps = snaps.slice(-8);

            // Collect all categories with weight > 0
            var categories = [];
            var lastCats = displaySnaps[displaySnaps.length - 1].categories || {};
            for (var catName in lastCats) {
                if (lastCats[catName].weight > 0) categories.push(catName);
            }

            var html = "<table style='width:100%;font-family:var(--font-mono);font-size:11px;border-collapse:collapse;'>";

            // Header row with scan dates
            html += "<thead><tr>";
            html += "<th style='text-align:left;padding:6px 10px;color:var(--text-muted);border-bottom:1px solid var(--glass-border);min-width:140px;'>CATEGORY</th>";
            displaySnaps.forEach(function(s) {
                var dt = new Date(s.date);
                var dateStr = (dt.getMonth() + 1) + '/' + dt.getDate();
                var isCurrent = (s.scan_id === instanceId);
                html += "<th style='text-align:center;padding:6px 8px;color:" + (isCurrent ? 'var(--text-primary)' : 'var(--text-muted)') + ";border-bottom:1px solid var(--glass-border);min-width:50px;font-weight:" + (isCurrent ? '700' : '400') + ";'>" + dateStr + "</th>";
            });
            html += "<th style='text-align:center;padding:6px 8px;color:var(--text-muted);border-bottom:1px solid var(--glass-border);min-width:40px;'>TREND</th>";
            html += "</tr></thead><tbody>";

            // Category rows
            categories.forEach(function(catName) {
                var color = snapshotCategoryColors[catName] || '#6b7280';
                html += "<tr>";
                html += "<td style='padding:5px 10px;border-bottom:1px solid var(--glass-border);'>";
                html += "<span style='display:inline-block;width:3px;height:12px;background:" + color + ";border-radius:1px;margin-right:6px;vertical-align:middle;'></span>";
                html += "<span style='color:var(--text-secondary);'>" + catName + "</span></td>";

                var firstScore = null, latestScore = null;
                displaySnaps.forEach(function(s) {
                    var cats = s.categories || {};
                    var catData = cats[catName];
                    var grade = catData ? catData.grade : '-';
                    var score = catData ? catData.score : 0;
                    if (firstScore === null && catData) firstScore = score;
                    if (catData) latestScore = score;
                    var gc = gradeGlowColor(grade);
                    html += "<td style='text-align:center;padding:5px 8px;border-bottom:1px solid var(--glass-border);'>";
                    html += "<span style='display:inline-block;width:28px;height:22px;line-height:22px;border-radius:3px;font-size:11px;font-weight:600;color:" + gc.text + ";background:var(--bg-tertiary);border:1px solid " + gc.text + ";'>" + grade + "</span>";
                    html += "</td>";
                });

                // Trend indicator
                var change = (firstScore !== null && latestScore !== null) ? latestScore - firstScore : 0;
                var trendSymbol, trendColor;
                if (change >= 10) { trendSymbol = '&#x25B2;&#x25B2;'; trendColor = '#22c55e'; }
                else if (change >= 2) { trendSymbol = '&#x25B2;'; trendColor = '#22c55e'; }
                else if (change <= -10) { trendSymbol = '&#x25BC;&#x25BC;'; trendColor = '#ef4444'; }
                else if (change <= -2) { trendSymbol = '&#x25BC;'; trendColor = '#f59e0b'; }
                else { trendSymbol = '&#x25C6;'; trendColor = '#6b7280'; }

                html += "<td style='text-align:center;padding:5px 8px;border-bottom:1px solid var(--glass-border);color:" + trendColor + ";font-size:10px;'>" + trendSymbol + "</td>";
                html += "</tr>";
            });

            // Overall row (bold separator)
            html += "<tr style='border-top:2px solid var(--glass-border);'>";
            html += "<td style='padding:6px 10px;font-weight:700;color:var(--text-primary);'>Overall</td>";
            var firstOverall = null, latestOverall = null;
            displaySnaps.forEach(function(s) {
                var grade = s.overall_grade || '-';
                var score = s.overall_score || 0;
                if (firstOverall === null) firstOverall = score;
                latestOverall = score;
                var gc = gradeGlowColor(grade);
                var isCurrent = (s.scan_id === instanceId);
                html += "<td style='text-align:center;padding:6px 8px;'>";
                html += "<span style='display:inline-block;width:28px;height:22px;line-height:22px;border-radius:3px;font-size:12px;font-weight:700;color:" + gc.text + ";background:" + (isCurrent ? 'var(--bg-elevated)' : 'var(--bg-tertiary)') + ";border:1px solid " + gc.text + ";box-shadow:" + (isCurrent ? '0 0 8px ' + gc.glow : 'none') + ";'>" + grade + "</span>";
                html += "</td>";
            });

            var overallChange = (latestOverall !== null && firstOverall !== null) ? latestOverall - firstOverall : 0;
            var otSymbol, otColor;
            if (overallChange >= 10) { otSymbol = '&#x25B2;&#x25B2;'; otColor = '#22c55e'; }
            else if (overallChange >= 2) { otSymbol = '&#x25B2;'; otColor = '#22c55e'; }
            else if (overallChange <= -10) { otSymbol = '&#x25BC;&#x25BC;'; otColor = '#ef4444'; }
            else if (overallChange <= -2) { otSymbol = '&#x25BC;'; otColor = '#f59e0b'; }
            else { otSymbol = '&#x25C6;'; otColor = '#6b7280'; }

            html += "<td style='text-align:center;padding:6px 8px;color:" + otColor + ";font-size:12px;font-weight:700;'>" + otSymbol + "</td>";
            html += "</tr></tbody></table>";

            container.innerHTML = html;
        }

        function injectDeltaBadges(trendData) {
            if (!trendData || !trendData.deltas || !trendData.deltas.since_previous) return;

            var sp = trendData.deltas.since_previous;
            var scoreChange = sp.score_change || 0;
            if (scoreChange === 0) return;

            var badgeColor = scoreChange > 0 ? '#22c55e' : '#ef4444';
            var badgeText = (scoreChange > 0 ? '+' : '') + scoreChange.toFixed(1) + ' since last scan';

            // Wait for grade panel to render, then inject badge
            setTimeout(function() {
                var gradeCircle = document.querySelector('#grade-panel-body');
                if (!gradeCircle) return;

                // Find the score display and add delta badge after it
                var scoreEl = gradeCircle.querySelector('[id^="grade-overall-score"]');
                if (!scoreEl) {
                    // Try to find by looking at the overall score text
                    var allSpans = gradeCircle.querySelectorAll('span, div');
                    for (var i = 0; i < allSpans.length; i++) {
                        if (allSpans[i].textContent.match(/OVERALL SECURITY RATING/i)) {
                            scoreEl = allSpans[i];
                            break;
                        }
                    }
                }

                if (scoreEl) {
                    var badge = document.createElement('div');
                    badge.style.cssText = 'text-align:center;margin-top:4px;';
                    badge.innerHTML = "<span style='font-family:var(--font-mono);font-size:10px;color:" + badgeColor + ";background:rgba(0,0,0,0.08);border:1px solid " + badgeColor + "33;padding:2px 8px;border-radius:10px;letter-spacing:0.5px;font-weight:700;'>" + badgeText + "</span>";
                    scoreEl.parentNode.insertBefore(badge, scoreEl.nextSibling);
                }

                // Inject per-category deltas
                var catDeltas = trendData.deltas.category_deltas || {};
                for (var catName in catDeltas) {
                    var cd = catDeltas[catName];
                    if (Math.abs(cd.change) < 1) continue;
                    var cdColor = cd.change > 0 ? '#22c55e' : '#ef4444';
                    var cdText = (cd.change > 0 ? '+' : '') + cd.change.toFixed(0);
                    // Find category cards in the grade panel and inject small delta
                    var catHeaders = gradeCircle.querySelectorAll('[data-category-name]');
                    for (var j = 0; j < catHeaders.length; j++) {
                        if (catHeaders[j].getAttribute('data-category-name') === catName) {
                            var deltaSpan = document.createElement('span');
                            deltaSpan.style.cssText = 'font-size:9px;color:' + cdColor + ';margin-left:6px;font-family:var(--font-mono);';
                            deltaSpan.textContent = '(' + cdText + ')';
                            catHeaders[j].appendChild(deltaSpan);
                            break;
                        }
                    }
                }
            }, 2000); // Wait for grade panel to load
        }

        // Grade color map
        function gradeGlowColor(g) {
            var m = {
                'A': {grad: 'linear-gradient(135deg, #22c55e 0%, #16a34a 100%)', glow: 'rgba(34, 197, 94, 0.6)', text: '#22c55e'},
                'B': {grad: 'linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)', glow: 'rgba(59, 130, 246, 0.6)', text: '#3b82f6'},
                'C': {grad: 'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)', glow: 'rgba(245, 158, 11, 0.6)', text: '#f59e0b'},
                'D': {grad: 'linear-gradient(135deg, #f97316 0%, #ea580c 100%)', glow: 'rgba(249, 115, 22, 0.6)', text: '#f97316'},
                'F': {grad: 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)', glow: 'rgba(239, 68, 68, 0.6)', text: '#ef4444'}
            };
            return m[g] || m['F'];
        }

        // Render the Overall Grade panel
        function renderGradePanel(gradeData, instanceId) {
            var panel = $('#grade-panel-body');

            if (!gradeData || !gradeData.enabled) {
                panel.html("<div style='text-align:center;padding:20px;color:var(--text-muted);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:1px;text-shadow:0 0 8px rgba(255,255,255,0.3);'>GRADE CALCULATION IS DISABLED. ENABLE IT IN SETTINGS.</div>");
                return;
            }
            if (gradeData.error) {
                panel.html("<div style='text-align:center;padding:20px;color:var(--accent-orange);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.5px;'>" + gradeData.error + "</div>");
                return;
            }

            var grade = gradeData.overall_grade || '-';
            var score = gradeData.overall_score || 0;
            var categories = gradeData.categories || {};
            var gc = gradeGlowColor(grade);

            var catOrder = [
                'Network Security', 'Web App Security', 'Information Leakage',
                'General Health', 'External Account Exposure', 'DNS Health',
                'IP Reputation', 'AI Security', 'Information / Reference'
            ];

            var h = '';

            // === TOP: Large glowing grade badge centered ===
            h += "<div style='text-align:center;padding:28px 20px 18px 20px;'>";
            // Big glowing circle
            h += "<div style='display:inline-flex;flex-direction:column;align-items:center;justify-content:center;";
            h += "width:130px;height:130px;border-radius:50%;";
            h += "background:" + gc.grad + ";";
            h += "box-shadow:0 0 30px " + gc.glow + ", 0 0 60px " + gc.glow + ", 0 0 90px " + gc.glow + ";";
            h += "border:3px solid rgba(255,255,255,0.2);'>";
            h += "<span style='font-family:var(--font-mono);font-size:56px;font-weight:900;line-height:1;color:#fff;text-shadow:0 0 20px rgba(255,255,255,0.9),0 0 40px rgba(255,255,255,0.5);'>" + grade + "</span>";
            h += "<span style='font-family:var(--font-mono);font-size:16px;font-weight:600;color:rgba(255,255,255,0.9);text-shadow:0 0 10px rgba(255,255,255,0.7);'>" + score + "</span>";
            h += "</div>";
            // Subtitle
            h += "<div style='margin-top:12px;color:var(--text-secondary);font-size:13px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:1px;text-shadow:0 0 10px rgba(255,255,255,0.4);'>OVERALL SECURITY RATING</div>";
            h += "<div style='color:var(--text-muted);font-size:11px;margin-top:2px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.5px;'>ONLY UNVALIDATED ITEMS COUNT &mdash; VALIDATED &amp; FALSE POSITIVES ARE EXCLUDED</div>";
            h += "<div style='color:var(--accent-blue, #3b82f6);font-size:9px;margin-top:4px;font-family:var(--font-mono);letter-spacing:0.5px;'>GRADE ENGINE v3-2026-02-09</div>";
            if (typeof scanStatus !== 'undefined' && scanStatus && scanStatus != 'FINISHED' && scanStatus != 'ABORTED' && scanStatus.indexOf('FAILED') < 0) {
                h += "<div style='display:inline-block;margin-top:8px;font-size:10px;color:var(--accent-yellow);background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);border-radius:4px;padding:3px 10px;'>";
                h += "<i class='glyphicon glyphicon-exclamation-sign'></i> SCAN IN PROGRESS &mdash; GRADE MAY CHANGE</div>";
            }
            h += "</div>";

            // === CATEGORY CARDS ===
            h += "<div style='padding:0 16px 16px 16px;'>";

            for (var ci = 0; ci < catOrder.length; ci++) {
                var catName = catOrder[ci];
                var cat = categories[catName];
                if (!cat) continue;
                var catId = 'gcat' + ci;
                var cc = gradeGlowColor(cat.grade);
                var hasDetails = cat.details && cat.details.length > 0;

                // Category card
                h += "<div style='background:var(--bg-tertiary);border:1px solid var(--glass-border);border-radius:var(--radius-md);margin-bottom:8px;overflow:hidden;'>";

                // Card header - clickable
                h += "<div onclick='toggleGradeDetail(\"" + catId + "\")' style='display:flex;align-items:center;justify-content:space-between;padding:10px 14px;cursor:pointer;transition:background 0.15s;' onmouseover='this.style.background=\"var(--bg-elevated)\"' onmouseout='this.style.background=\"transparent\"'>";

                // Left: color bar + name + mini badge
                h += "<div style='display:flex;align-items:center;gap:10px;flex:1;'>";
                h += "<div style='width:4px;height:28px;border-radius:2px;background:" + cat.color + ";flex-shrink:0;'></div>";
                h += "<span data-category-name='" + catName + "' style='font-weight:600;font-size:13px;color:var(--text-primary);text-transform:uppercase;font-family:var(--font-mono);letter-spacing:0.5px;'>" + catName + "</span>";
                // Mini grade badge with glow
                h += "<span style='display:inline-block;width:26px;height:22px;line-height:22px;text-align:center;border-radius:4px;font-family:var(--font-mono);font-size:11px;font-weight:700;color:#fff;background:" + cc.grad + ";box-shadow:0 0 8px " + cc.glow + ";text-shadow:0 0 6px rgba(255,255,255,0.7);'>" + cat.grade + "</span>";
                h += "</div>";

                // Right: scores
                h += "<div style='display:flex;align-items:center;gap:16px;font-family:var(--font-mono);font-size:12px;'>";
                h += "<div style='text-align:right;'><div style='color:var(--text-muted);font-size:9px;text-transform:uppercase;letter-spacing:0.5px;'>Raw</div><div style='color:var(--text-secondary);'>" + cat.raw_score + "</div></div>";
                h += "<div style='text-align:right;'><div style='color:var(--text-muted);font-size:9px;text-transform:uppercase;letter-spacing:0.5px;'>Adj</div><div style='color:var(--text-secondary);'>" + cat.adj_score + "</div></div>";
                h += "<div style='text-align:right;min-width:36px;'><div style='color:var(--text-muted);font-size:9px;text-transform:uppercase;letter-spacing:0.5px;'>Score</div><div style='color:" + cc.text + ";font-weight:700;'>" + cat.score + "</div></div>";
                if (hasDetails) {
                    h += "<span class='grade-chevron' id='" + catId + "-icon' style='color:var(--text-muted);font-size:10px;transition:transform 0.2s;'>&#9654;</span>";
                }
                h += "</div>";

                h += "</div>"; // end header

                // Detail panel (hidden by default)
                if (hasDetails) {
                    h += "<div id='" + catId + "-detail' style='display:none;border-top:1px solid var(--glass-border);background:var(--bg-secondary);padding:8px 14px 8px 28px;'>";
                    for (var di = 0; di < cat.details.length; di++) {
                        var d = cat.details[di];
                        var ptColor = d.points < 0 ? 'var(--accent-red)' : 'var(--text-muted)';
                        var ptStr = d.points < 0 ? d.points : '0';
                        // Build clickable link to Data > Type for this event type
                        var typeLink = '';
                        var safeType = d.type.replace(/"/g, '&quot;');
                        if (d.type === 'EXTERNAL_VULNERABILITIES') {
                            typeLink = "<a href='javascript:void(0)' class='finding-type-link' style='cursor:pointer;color:var(--text-secondary);text-decoration:none;border-bottom:1px dotted var(--text-muted);' onclick='event.stopPropagation(); viewVulnerabilities(\"" + instanceId + "\"); window.scrollTo(0,0); return false;' title='View External Vulnerabilities'>" + d.type + "</a>";
                        } else if (d.type === 'WEBAPP_VULNERABILITIES') {
                            typeLink = "<a href='javascript:void(0)' class='finding-type-link' style='cursor:pointer;color:var(--text-secondary);text-decoration:none;border-bottom:1px dotted var(--text-muted);' onclick='event.stopPropagation(); viewVulnerabilities(\"" + instanceId + "\"); switchVulnTab(\"burp\", \"" + instanceId + "\"); window.scrollTo(0,0); return false;' title='View Web App Vulnerabilities'>" + d.type + "</a>";
                        } else {
                            typeLink = "<a href='javascript:void(0)' class='finding-type-link' style='cursor:pointer;color:var(--text-secondary);text-decoration:none;border-bottom:1px dotted var(--text-muted);' onclick='event.stopPropagation(); dataEventData(\"" + instanceId + "\", \"" + safeType + "\", \"" + safeType + "\", \"full\"); window.scrollTo(0,0); return false;' title='View " + safeType + " data'>" + d.type + "</a>";
                        }
                        var foundLabel = d.found ? 'FOUND' : 'NOT FOUND';
                        var foundColor = d.found ? 'var(--text-muted)' : 'var(--accent-orange)';
                        h += "<div style='display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:11px;'>";
                        h += "<span style='font-family:var(--font-mono);'>" + typeLink + " <span style='color:var(--text-muted);'>(" + d.count + " unval)</span> <span style='color:" + foundColor + ";font-size:9px;'>[" + foundLabel + "]</span></span>";
                        h += "<span style='font-family:var(--font-mono);font-weight:600;color:" + ptColor + ";'>" + ptStr + "</span>";
                        h += "</div>";
                    }
                    h += "</div>";
                }

                h += "</div>"; // end card
            }

            // Unmapped types warning
            if (gradeData.unmapped_types && gradeData.unmapped_types.length > 0) {
                h += "<div style='font-size:11px;color:var(--accent-yellow);background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.12);border-radius:var(--radius-sm);padding:6px 12px;margin-top:4px;'>";
                h += "<i class='glyphicon glyphicon-info-sign'></i> ";
                h += gradeData.unmapped_types.length + " EVENT TYPE(S) AUTO-CATEGORIZED. ";
                h += "REVIEW IN <a href='${docroot}/opts' style='color:var(--accent-yellow);text-decoration:underline;font-family:var(--font-mono);'>SETTINGS</a>.";
