        function showCorrelationLoadingUI(panel) {
            panel.html(
                "<div style='text-align: center; padding: 40px 30px;'>" +
                "  <i class='glyphicon glyphicon-refresh spinning' style='font-size: 28px; color: #38bdf8; display: block; margin-bottom: 15px;'></i>" +
                "  <p id='corr-loading-msg' style='font-family: \"JetBrains Mono\", \"Fira Code\", \"SF Mono\", monospace; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; min-height: 20px; margin-bottom: 18px;'>" + corrLoadingMessages[0] + "</p>" +
                "  <div class='progress' style='height: 18px; margin: 0 auto; max-width: 400px; border-radius: 4px;'>" +
                "    <div id='corr-loading-bar' class='progress-bar progress-bar-striped active' role='progressbar' style='width: 5%; min-width: 2em; transition: width 0.8s ease; font-weight: 600; font-size: 11px; line-height: 18px;'>5%</div>" +
                "  </div>" +
