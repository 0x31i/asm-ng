        function knownBulkType(newType) {
            var ids = [];
            $(".asset-cb:checked").each(function() { ids.push($(this).val()); });
            if (ids.length === 0) return;
            knownBulkSpinnerShow("CHANGING TYPE FOR " + ids.length + " ASSETS...");
            sf.fetchData('${docroot}/knownassetbulkupdate', {
                ids: JSON.stringify(ids), asset_type: newType
            }, function(ret) {
                knownBulkSpinnerHide();
                if (ret[0] === "SUCCESS") {
                    alertify.success("TYPE CHANGED (" + ids.length + ")");
                    assetsShowKnown(_instanceId);
                } else {
                    alertify.error("ERROR: " + ret[1]);
                }
            });
            $("#assets-select-all").prop("checked", false);
            $(".asset-cb").prop("checked", false);
            assetsUpdateSelection();
        }

        function knownBulkTagPrompt() {
            var $modal = $("#assets-bulk-tag-modal");
            var $container = $("#bulk-tag-list-container");
            $container.html("<p style='opacity:0.5;font-size:11px;'>LOADING TAGS...</p>");
            $modal.show();

            var populateBulkTags = function(tags) {
                var html = "";
                for (var i = 0; i < tags.length; i++) {
                    var t = tags[i];
                    var safeTag = $('<span>').text(t.tag).html();
                    html += "<div class='assets-bulk-tag-option' onclick='knownBulkTag(\"" + safeTag.replace(/"/g, '&quot;') + "\");assetsCloseModals();'>";
                    html += "<span class='assets-kebab-tag-swatch' style='background:" + t.color + ";'></span>&nbsp;&nbsp;" + safeTag + "</div>";
                }
                html += "<div class='assets-bulk-tag-option assets-kebab-remove-tag' onclick='knownBulkTag(\"\");assetsCloseModals();'>";
                html += "<i class='glyphicon glyphicon-remove'></i>&nbsp;&nbsp;REMOVE TAG</div>";
                if (tags.length === 0) {
                    html = "<p style='opacity:0.5;font-size:11px;'>NO TAGS DEFINED. CREATE TAGS VIA MANAGE TAGS FIRST.</p>" + html;
                }
                $container.html(html);
            };

            if (cachedAssetTags !== null) {
                populateBulkTags(cachedAssetTags);
            } else {
                sf.fetchData('${docroot}/assettaglist', {target: assetsTarget}, function(tags) {
                    cachedAssetTags = tags;
                    populateBulkTags(tags);
                });
            }
        }

        function knownBulkTag(tagValue) {
            var ids = [];
            $(".asset-cb:checked").each(function() { ids.push($(this).val()); });
            if (ids.length === 0) return;
            knownBulkSpinnerShow("TAGGING " + ids.length + " ASSETS...");
            sf.fetchData('${docroot}/knownassetbulkupdate', {
                ids: JSON.stringify(ids), tag: tagValue
            }, function(ret) {
                knownBulkSpinnerHide();
                if (ret[0] === "SUCCESS") {
                    alertify.success("TAG UPDATED (" + ids.length + ")");
                    for (var i = 0; i < ids.length; i++) {
                        knownUpdateRowInPlace(parseInt(ids[i]), 'tag', tagValue);
                    }
                } else {
                    alertify.error("ERROR: " + ret[1]);
                }
            });
            $("#assets-select-all").prop("checked", false);
            $(".asset-cb").prop("checked", false);
            assetsUpdateSelection();
