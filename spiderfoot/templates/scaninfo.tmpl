            var fullVal = a.raw_value || a.asset_value;
            h += "<div class='assets-detail-card assets-detail-card-fullval'><div class='assets-detail-card-label'>FULL VALUE</div><div class='assets-detail-card-value' style='word-break:break-all;'>" + $('<span>').text(fullVal).html() + "</div></div>";
            h += "</div></td></tr>";
            return h;
        }

        // Click-to-expand detail for known asset rows
        function knownToggleDetail(td) {
            var $row = $(td).closest('tr');
            var $detail = $row.next('.assets-known-detail');
            if ($detail.is(':visible')) {
                $detail.hide();
                $row.removeClass('assets-row-expanded');
            } else {
                $detail.show();
                $row.addClass('assets-row-expanded');
            }
        }

        // Click anywhere in checkbox cell to toggle
        function knownToggleCb(td, event) {
            if (event.target.type === 'checkbox') return;
            var cb = $(td).find('input[type=checkbox]');
            cb.prop('checked', !cb.prop('checked'));
            assetsUpdateSelection();
        }

        // Track checkbox changes
        function knownInitSelectionTracking() {
            $(document).off('change.knownassetscb').on('change.knownassetscb', '.asset-cb, #assets-select-all', function() {
                assetsUpdateSelection();
            });
        }

        // Debounced text search for known assets
        var _knownSearchTimer = null;
        function knownInitSearch() {
            $(document).off('input.knownsearch').on('input.knownsearch', '#assets-known-search', function() {
                clearTimeout(_knownSearchTimer);
                _knownSearchTimer = setTimeout(function() { knownApplyFilters(); }, 200);
            });
        }

        // Type filter - independent of source filter
        function knownFilterType(filter, btn) {
            knownActiveFilters.type = filter;
            $(".assets-known-filter-group-type .assets-known-filter-btn").removeClass("assets-known-filter-active assets-known-filter-active-type");
            $(btn).addClass("assets-known-filter-active assets-known-filter-active-type");
            knownApplyFilters();
        }

        // Source filter - independent of type filter
        function knownFilterSource(filter, btn) {
            knownActiveFilters.source = filter;
            $(".assets-known-filter-group-source .assets-known-filter-btn").removeClass("assets-known-filter-active assets-known-filter-active-source");
            $(btn).addClass("assets-known-filter-active assets-known-filter-active-source");
            knownApplyFilters();
        }

        function knownFilterAffinity(filter, btn) {
            knownActiveFilters.affinity = filter;
            $(".assets-known-filter-group-affinity .assets-known-filter-btn").removeClass("assets-known-filter-active assets-known-filter-active-affinity");
            $(btn).addClass("assets-known-filter-active assets-known-filter-active-affinity");
            knownApplyFilters();
        }

        function knownFilterTag(filter, btn) {
            knownActiveFilters.tag = filter;
            $(".assets-known-filter-group-tag .assets-known-filter-btn").removeClass("assets-known-filter-active assets-known-filter-active-tag");
            $(btn).addClass("assets-known-filter-active assets-known-filter-active-tag");
            knownApplyFilters();
        }

        // Apply all filters together (including text search)
        function knownApplyFilters() {
            var searchTerm = ($("#assets-known-search").val() || '').toLowerCase();
            var visibleCount = 0;
            $("#known-assets-table tbody tr.assets-known-row").each(function() {
                var $row = $(this);
                var typeMatch = (knownActiveFilters.type === 'all' || knownActiveFilters.type === $row.data('asset-type'));
                var affinityMatch = (knownActiveFilters.affinity === 'all' || knownActiveFilters.affinity === $row.data('asset-affinity'));
                var sourceMatch = (knownActiveFilters.source === 'all' || knownActiveFilters.source === $row.data('asset-source'));
                var rowTag = $row.data('asset-tag') || '';
                var tagMatch = (knownActiveFilters.tag === 'all' || (knownActiveFilters.tag === '_untagged' && !rowTag) || knownActiveFilters.tag === rowTag);
                var textMatch = !searchTerm || ($row.data('asset-value') || '').toLowerCase().indexOf(searchTerm) !== -1;
                var show = typeMatch && affinityMatch && sourceMatch && tagMatch && textMatch;
                $row.toggle(show);
                if (show) visibleCount++;
                // Also hide detail row if main row is hidden
                $row.next('.assets-known-detail').toggle(show && $row.hasClass('assets-row-expanded'));
            });
            // Update visible count
            $("#assets-visible-count").text(visibleCount);
            // Uncheck select-all when filters change
            $("#assets-select-all").prop("checked", false);
            assetsUpdateSelection();
        }

        // Column sorting for known assets table
        function knownSortBy(col) {
            if (knownSortState.col === col) {
                knownSortState.dir = knownSortState.dir === 'asc' ? 'desc' : 'asc';
            } else {
                knownSortState.col = col;
                knownSortState.dir = 'asc';
            }
            // Update sort icons
            $(".assets-sort-icon").html('');
            $(".assets-sort-icon[data-col='" + col + "']").html(knownSortState.dir === 'asc' ? ' &#9650;' : ' &#9660;');

            var $tbody = $("#known-assets-table tbody");
            var rows = $tbody.find("tr.assets-known-row").get();
            var dir = knownSortState.dir === 'asc' ? 1 : -1;

            rows.sort(function(a, b) {
                var aVal = ($(a).data('asset-' + col) || '').toString().toLowerCase();
                var bVal = ($(b).data('asset-' + col) || '').toString().toLowerCase();
                if (aVal < bVal) return -1 * dir;
                if (aVal > bVal) return 1 * dir;
                return 0;
            });

            // Re-append rows (each main row followed by its detail row)
            for (var i = 0; i < rows.length; i++) {
                var $row = $(rows[i]);
                var $detail = $row.next('.assets-known-detail');
                $tbody.append($row);
                if ($detail.length) $tbody.append($detail);
            }
        }

        function assetsToggleSelectAll() {
            var checked = $("#assets-select-all").is(":checked");
            $(".asset-cb:visible").prop("checked", checked);
            assetsUpdateSelection();
        }

        function assetsUpdateSelection() {
            var count = $(".asset-cb:checked").length;
            if (count > 0) {
                $("#assets-known-bulk-row").show();
                $("#assets-remove-sel-btn").html("<i class='glyphicon glyphicon-trash'></i>&nbsp;&nbsp;REMOVE SELECTED (" + count + ")");
                $("#assets-bulk-fp-btn").html("<i class='glyphicon glyphicon-ban-circle'></i>&nbsp;&nbsp;FALSE POSITIVE (" + count + ")");
                $("#assets-bulk-pending-btn").html("<i class='glyphicon glyphicon-repeat'></i>&nbsp;&nbsp;PENDING (" + count + ")");
                $("#assets-bulk-affinity-btn").html("<i class='glyphicon glyphicon-transfer'></i>&nbsp;&nbsp;CHANGE AFFINITY (" + count + ")");
                $("#assets-bulk-tag-btn").html("<i class='glyphicon glyphicon-tag'></i>&nbsp;&nbsp;ASSIGN TAG (" + count + ")");
            } else {
                $("#assets-known-bulk-row").hide();
            }
        }

        // In-place action for known asset row: mark as FP or reset to pending
        function knownAssetAction(assetId, action) {
            var $row = $("tr.assets-known-row[data-asset-id='" + assetId + "']");
            if (!$row.length) return;
            var $actionCell = $row.find('.assets-known-action-cell');

            if (action === 'fp') {
                // Mark as false positive - remove from known assets
                sf.fetchData('${docroot}/knownassetremove', {id: assetId}, function(ret) {
                    if (ret[0] === "SUCCESS") {
                        $row.addClass('assets-known-row-fp');
                        $actionCell.html(
                            "<div class='assets-kebab-wrapper'><button class='btn btn-xs assets-kebab-btn' onclick='event.stopPropagation();knownAssetAction(" + assetId + ", \"undo_fp\")' title='UNDO - RESTORE ASSET'>" +
                            "<i class='glyphicon glyphicon-repeat'></i></button></div>"
                        );
                        alertify.success("MARKED AS FALSE POSITIVE");
                    } else {
                        alertify.error("ERROR: " + ret[1]);
                    }
                });
            } else if (action === 'undo_fp') {
                // Restore the asset - re-add it
                var assetType = $row.data('asset-type');
                var assetValue = $row.find('.assets-known-value-cell').text();
                var assetSource = $row.data('asset-source');
                sf.fetchData('${docroot}/knownassetadd', {
                    target: assetsTarget,
                    asset_type: assetType,
                    asset_value: assetValue,
                    source: assetSource === 'CLIENT_PROVIDED' ? 'CLIENT_PROVIDED' : 'ANALYST_CONFIRMED'
                }, function(ret) {
                    if (ret[0] === "SUCCESS") {
                        $row.removeClass('assets-known-row-fp');
                        $actionCell.html(
                            "<div class='assets-kebab-wrapper'><button class='btn btn-xs assets-kebab-btn' onclick='event.stopPropagation();knownToggleKebab(this, " + assetId + ")' title='ACTIONS'>" +
                            "<i class='glyphicon glyphicon-option-vertical'></i></button></div>"
                        );
                        alertify.success("ASSET RESTORED");
                    } else {
                        alertify.error("ERROR: " + ret[1]);
                    }
                });
            } else if (action === 'reset') {
                // Reset to pending - real backend call to change status
                sf.fetchData('${docroot}/knownassetsetstatus', {id: assetId, status: 'PENDING'}, function(ret) {
                    if (ret[0] === "SUCCESS") {
                        $row.addClass('assets-known-row-pending');
                        var $detail = $row.next('.assets-known-detail');
                        setTimeout(function() {
                            $row.fadeOut(300, function() { $row.remove(); });
                            $detail.fadeOut(300, function() { $detail.remove(); });
                        }, 400);
                        alertify.success("MOVED TO PENDING — VISIBLE IN POTENTIAL MATCHES");
                    } else {
                        alertify.error("ERROR: " + ret[1]);
                    }
                });
            }
        }

        // Bulk action for known assets: mark selected as FP or reset
        function knownBulkAction(instanceId, action) {
            var ids = [];
            $(".asset-cb:checked").each(function() { ids.push($(this).val()); });
            if (ids.length === 0) return;
            knownBulkSpinnerShow("PROCESSING " + ids.length + " ASSETS...");
            if (action === 'reset') {
                sf.fetchData('${docroot}/knownassetsetstatus', {ids: JSON.stringify(ids), status: 'PENDING'}, function(ret) {
                    knownBulkSpinnerHide();
                    if (ret[0] === "SUCCESS") {
                        for (var i = 0; i < ids.length; i++) {
                            var $row = $("tr.assets-known-row[data-asset-id='" + ids[i] + "']");
                            var $detail = $row.next('.assets-known-detail');
                            $row.addClass('assets-known-row-pending');
                            (function($r, $d) {
                                setTimeout(function() {
                                    $r.fadeOut(300, function() { $r.remove(); });
                                    $d.fadeOut(300, function() { $d.remove(); });
                                }, 400);
                            })($row, $detail);
                        }
                        alertify.success("MOVED " + ids.length + " ASSETS TO PENDING");
                    } else {
                        alertify.error("ERROR: " + ret[1]);
                    }
                });
            } else {
                knownBulkSpinnerHide();
                for (var i = 0; i < ids.length; i++) {
                    knownAssetAction(parseInt(ids[i]), action);
                }
            }
            $("#assets-select-all").prop("checked", false);
            $(".asset-cb").prop("checked", false);
            assetsUpdateSelection();
        }

        function assetsRemoveSelected(instanceId) {
            var ids = [];
            $(".asset-cb:checked").each(function() { ids.push($(this).val()); });
            if (ids.length === 0) return;
            if (!confirm("Remove " + ids.length + " selected assets?")) return;
            knownBulkSpinnerShow("REMOVING " + ids.length + " ASSETS...");
            sf.fetchData('${docroot}/knownassetremove', {ids: JSON.stringify(ids)}, function(ret) {
                knownBulkSpinnerHide();
                if (ret[0] === "SUCCESS") {
                    alertify.success(ret[1]);
                    for (var i = 0; i < ids.length; i++) {
                        var $row = $("tr.assets-known-row[data-asset-id='" + ids[i] + "']");
                        $row.next('.assets-known-detail').remove();
                        $row.remove();
                    }
                    $("#assets-select-all").prop("checked", false);
                    assetsUpdateSelection();
                } else {
                    alertify.error("ERROR: " + ret[1]);
                }
            });
        }

        // ---- KEBAB MENU & IN-PLACE UPDATE FUNCTIONS ----

        function knownCloseKebab() {
            $("#assets-kebab-dropdown").hide();
            knownKebabActiveId = null;
        }

        function knownToggleKebab(btn, assetId) {
            var $dd = $("#assets-kebab-dropdown");
            // If already open for this asset, close it
            if ($dd.is(":visible") && knownKebabActiveId === assetId) {
                knownCloseKebab();
                return;
            }
            knownKebabActiveId = assetId;

            // Position dropdown relative to the button (use getBoundingClientRect
            // since the dropdown is position:fixed and needs viewport coordinates)
            var $btn = $(btn);
            var rect = btn.getBoundingClientRect();

            // Populate affinity toggle label based on current row data
            var $row = $("tr.assets-known-row[data-asset-id='" + assetId + "']");
            var currentAffinity = $row.data('asset-affinity') || 'DIRECT';
            var newAffinity = (currentAffinity === 'DIRECT') ? 'ASSOCIATED' : 'DIRECT';
            $("#kebab-affinity-label").text("SET " + newAffinity);

            // Populate tag list (cached)
            var currentTag = $row.data('asset-tag') || '';
            knownPopulateKebabTags(currentTag);

            // Position: show the dropdown, measure, then adjust
            $dd.css({ top: -9999, left: -9999, display: 'block' });
            var ddWidth = $dd.outerWidth();
            var ddHeight = $dd.outerHeight();
            var winW = $(window).width();
            var winH = $(window).height();

            // Default: below button, right-aligned to button
            var top = rect.bottom + 4;
            var left = rect.right - ddWidth;

            // Clamp left edge to viewport
            if (left < 4) left = 4;
            // Clamp right edge to viewport
            if (left + ddWidth > winW - 4) left = winW - ddWidth - 4;
            // If dropdown overflows bottom, show above button
            if (top + ddHeight > winH - 4) top = rect.top - ddHeight - 4;
            // If still overflows top, clamp to top
            if (top < 4) top = 4;

            $dd.css({ top: top, left: left });
        }

        function knownPopulateKebabTags(currentTag) {
            if (cachedAssetTags !== null) {
                renderKebabTags(cachedAssetTags, currentTag);
                return;
            }
            $("#kebab-tag-list").html("<div class='assets-kebab-menu-item' style='opacity:0.5;'>LOADING...</div>");
            sf.fetchData('${docroot}/assettaglist', {target: assetsTarget}, function(tags) {
                cachedAssetTags = tags;
                renderKebabTags(tags, currentTag);
            });
        }

        function renderKebabTags(tags, currentTag) {
            var html = "";
            for (var i = 0; i < tags.length; i++) {
                var t = tags[i];
                var safeTag = $('<span>').text(t.tag).html();
                var isActive = (currentTag === t.tag);
                html += "<div class='assets-kebab-menu-item assets-kebab-tag-item" + (isActive ? " assets-kebab-tag-active" : "") + "' onclick='knownKebabSetTag(\"" + safeTag.replace(/"/g, '&quot;') + "\")'>";
                html += "<span class='assets-kebab-tag-swatch' style='background:" + t.color + ";'></span>&nbsp;&nbsp;" + safeTag;
                if (isActive) html += " &nbsp;<i class='glyphicon glyphicon-ok' style='font-size:10px;'></i>";
                html += "</div>";
            }
            html += "<div class='assets-kebab-menu-item assets-kebab-remove-tag' onclick='knownKebabSetTag(\"\")'>";
            html += "<i class='glyphicon glyphicon-remove'></i>&nbsp;&nbsp;REMOVE TAG</div>";
            $("#kebab-tag-list").html(html);
        }

        function knownKebabAffinity() {
            if (!knownKebabActiveId) return;
            var $row = $("tr.assets-known-row[data-asset-id='" + knownKebabActiveId + "']");
            var currentAffinity = $row.data('asset-affinity') || 'DIRECT';
            var newAffinity = (currentAffinity === 'DIRECT') ? 'ASSOCIATED' : 'DIRECT';
            knownCloseKebab();
            knownUpdateAssetProperty(knownKebabActiveId, 'affinity', newAffinity);
        }

        function knownKebabSetTag(tagValue) {
            if (!knownKebabActiveId) return;
            knownCloseKebab();
            knownUpdateAssetProperty(knownKebabActiveId, 'tag', tagValue);
        }

        function knownKebabFp() {
            if (!knownKebabActiveId) return;
            var id = knownKebabActiveId;
            knownCloseKebab();
            knownAssetAction(id, 'fp');
        }

        function knownKebabReset() {
            if (!knownKebabActiveId) return;
            var id = knownKebabActiveId;
            knownCloseKebab();
            knownAssetAction(id, 'reset');
        }

        // ---- ASSET TYPE → SF DATA TYPE MAPPING ----
        function knownAssetTypeToSfTypes(assetType) {
            var map = {
                'ip': [['IP_ADDRESS', 'IP Address'], ['IPV6_ADDRESS', 'IPv6 Address']],
                'domain': [['DOMAIN_NAME', 'Domain Name'], ['INTERNET_NAME', 'Internet Name']],
                'email': [['EMAILADDR', 'Email Address']],
                'human_name': [['HUMAN_NAME', 'Human Name']],
                'username': [['USERNAME', 'Username'], ['SOCIAL_MEDIA', 'Social Media']]
            };
            return map[assetType] || [];
        }

        // ---- TYPE REASSIGNMENT ----
        function knownChangeType(assetId, newType) {
            sf.fetchData('${docroot}/knownassetupdate', {
                id: assetId, asset_type: newType
            }, function(ret) {
                if (ret[0] === "SUCCESS") {
                    alertify.success("TYPE CHANGED TO " + newType.toUpperCase());
                    // Update the badge in the main row
                    var $row = $("tr.assets-known-row[data-asset-id='" + assetId + "']");
                    if ($row.length) {
                        $row.attr('data-asset-type', newType);
                        $row.find('.assets-type-badge').attr('class', 'assets-type-badge assets-type-' + newType).text(newType.toUpperCase());
                    }
                } else if (ret[0] === "CONFLICT") {
                    var conflictId = ret[2];
                    alertify.confirm(ret[1] + "<br/><small>Merge this entry into the existing one?</small>",
                        function() {
                            // MERGE: source=assetId (being changed), target=conflictId (existing)
                            sf.fetchData('${docroot}/knownassetmerge', {
                                source_id: assetId, target_id: conflictId
                            }, function(mergeRet) {
                                if (mergeRet[0] === "SUCCESS") {
                                    alertify.success("ASSETS MERGED");
                                    assetsShowKnown(_instanceId);
                                } else {
                                    alertify.error("MERGE FAILED: " + mergeRet[1]);
                                }
                            });
                        },
                        function() {
                            alertify.warning("TYPE CHANGE CANCELLED");
                            // Revert the select
                            var $row = $("tr.assets-known-row[data-asset-id='" + assetId + "']");
                            var origType = $row.attr('data-asset-type');
                            var $detail = $row.next('.assets-known-detail');
                            $detail.find('.assets-type-select').val(origType);
                        }
                    ).setHeader("MERGE ASSETS");
                } else {
                    alertify.error("ERROR: " + ret[1]);
                    // Revert the select to the original value
                    var $row = $("tr.assets-known-row[data-asset-id='" + assetId + "']");
                    var origType = $row.attr('data-asset-type');
                    var $detail = $row.next('.assets-known-detail');
                    $detail.find('.assets-type-select').val(origType);
                }
            });
        }

        // ---- INLINE NOTES EDITING ----
        function knownEditNotes(card, assetId) {
            // Prevent row toggle
            event.stopPropagation();

            var $card = $(card);
            // Don't re-enter edit mode if already editing
            if ($card.find('.assets-notes-textarea').length) return;

            var $val = $card.find('.assets-notes-value');
            var currentText = $val.find('.assets-notes-placeholder').length ? '' : $val.text().trim();

            var editHtml = "<textarea class='assets-notes-textarea' rows='3' placeholder='Add notes...'>" + $('<span>').text(currentText).html() + "</textarea>";
            editHtml += "<div class='assets-notes-actions'>";
            editHtml += "<button class='assets-notes-save-btn' onclick='knownSaveNotes(event, this, " + assetId + ")'>SAVE</button>";
            editHtml += "<button class='assets-notes-cancel-btn' onclick='knownCancelNotes(event, this)'>CANCEL</button>";
            editHtml += "</div>";

            // Store original content for cancel
            $card.data('original-html', $val.html());
            $val.html(editHtml);
            $val.find('.assets-notes-textarea').focus();
        }

        function knownSaveNotes(e, btn, assetId) {
            e.stopPropagation();
            var $card = $(btn).closest('.assets-notes-card');
            var newVal = $card.find('.assets-notes-textarea').val().trim();
            knownUpdateAssetProperty(assetId, 'notes', newVal);
        }

        function knownCancelNotes(e, btn) {
            e.stopPropagation();
            var $card = $(btn).closest('.assets-notes-card');
            var $val = $card.find('.assets-notes-value');
            $val.html($card.data('original-html'));
        }

        function knownUpdateAssetProperty(id, prop, val) {
            var params = {id: id};
            params[prop] = val;
            sf.fetchData('${docroot}/knownassetupdate', params, function(ret) {
                if (ret[0] === "SUCCESS") {
                    knownUpdateRowInPlace(id, prop, val);
                    alertify.success(prop.toUpperCase() + " UPDATED");
                } else {
                    alertify.error("ERROR: " + ret[1]);
                }
            });
        }

        function knownUpdateRowInPlace(id, prop, val) {
            var $row = $("tr.assets-known-row[data-asset-id='" + id + "']");
            if (!$row.length) return;
            var $detailRow = $row.next('.assets-known-detail');

            if (prop === 'affinity') {
                $row.data('asset-affinity', val).attr('data-asset-affinity', val);
                var affinityClass = (val === 'ASSOCIATED') ? 'assets-affinity-associated' : 'assets-affinity-direct';
                var affinityLabel = (val === 'ASSOCIATED') ? 'ASSOCIATED' : 'DIRECT';
                // Update main row badge
                $row.find('.assets-affinity-badge').attr('class', 'assets-affinity-badge ' + affinityClass).text(affinityLabel);
                // Update detail row badge
                if ($detailRow.length) {
                    $detailRow.find('.assets-detail-card').each(function() {
                        if ($(this).find('.assets-detail-card-label').text() === 'AFFINITY') {
                            $(this).find('.assets-detail-card-value').html("<span class='assets-affinity-badge " + affinityClass + "'>" + affinityLabel + "</span>");
                        }
                    });
                }
            } else if (prop === 'notes') {
                // Update notes card in detail row
                if ($detailRow.length) {
                    var $notesCard = $detailRow.find('.assets-notes-card');
                    if ($notesCard.length) {
                        var $notesVal = $notesCard.find('.assets-notes-value');
                        if (val) {
                            $notesVal.html($('<span>').text(val).html());
                        } else {
                            $notesVal.html("<span class='assets-notes-placeholder'>CLICK TO ADD NOTES</span>");
                        }
                    }
                }
            } else if (prop === 'tag') {
                $row.data('asset-tag', val).attr('data-asset-tag', val);
                var tagColor = '#64748b';
                // Try to find color from cached tags
                if (cachedAssetTags) {
                    for (var i = 0; i < cachedAssetTags.length; i++) {
                        if (cachedAssetTags[i].tag === val) {
                            tagColor = cachedAssetTags[i].color;
                            break;
                        }
                    }
                }
                var tagHtml;
                if (val) {
                    var safeTag = $('<span>').text(val).html();
                    tagHtml = "<span class='assets-tag-badge' style='background:" + tagColor + "20;color:" + tagColor + ";border:1px solid " + tagColor + "33;'>" + safeTag + "</span>";
                } else {
                    tagHtml = "<span style='color:rgba(255,255,255,0.2);font-size:10px;'>-</span>";
                }
                // Update main row tag cell (the one with the tag badge)
                $row.find('.assets-tag-badge, .assets-known-source-cell:last span').parent().filter('.assets-known-source-cell:last').html(tagHtml);
                // More reliable: find the 6th td (TAG column)
                $row.find('td').eq(5).html(tagHtml);
                // Update detail row
                if ($detailRow.length) {
                    $detailRow.find('.assets-detail-card').each(function() {
                        if ($(this).find('.assets-detail-card-label').text() === 'TAG') {
                            $(this).find('.assets-detail-card-value').html(val ? tagHtml : '-');
                        }
                    });
                }
            }

            // Flash animation
            $row.addClass('assets-known-row-updated');
            setTimeout(function() { $row.removeClass('assets-known-row-updated'); }, 800);

            // Re-apply filters so row hides if it no longer matches active filter
            knownApplyFilters();
        }

        // ---- BULK AFFINITY / TAG ACTIONS ----

        function knownBulkAffinityPrompt() {
            alertify.confirm(
                "<div style='text-align:center;font-family:monospace;'>" +
                "<p style='margin-bottom:12px;font-weight:700;'>CHANGE AFFINITY FOR SELECTED ASSETS</p>" +
                "<button class='btn assets-known-bulk-affinity-btn' style='display:inline-block;margin:4px;' onclick='knownBulkAffinity(\"DIRECT\");alertify.closeAll();'>DIRECT</button>" +
                "<button class='btn assets-known-bulk-affinity-btn' style='display:inline-block;margin:4px;' onclick='knownBulkAffinity(\"ASSOCIATED\");alertify.closeAll();'>ASSOCIATED</button>" +
                "</div>",
                function() {} // OK callback (unused, buttons handle it)
            ).setting({
                'labels': {ok: 'CANCEL', cancel: ''},
                'closable': true
            });
            // Hide the default cancel button
            setTimeout(function() {
                $(".alertify .ajs-footer .ajs-cancel").hide();
            }, 50);
        }

        function knownBulkAffinity(newAffinity) {
            var ids = [];
            $(".asset-cb:checked").each(function() { ids.push($(this).val()); });
            if (ids.length === 0) return;
            knownBulkSpinnerShow("UPDATING " + ids.length + " ASSETS...");
            sf.fetchData('${docroot}/knownassetbulkupdate', {
                ids: JSON.stringify(ids), affinity: newAffinity
            }, function(ret) {
                knownBulkSpinnerHide();
                if (ret[0] === "SUCCESS") {
                    alertify.success("AFFINITY UPDATED (" + ids.length + ")");
                    for (var i = 0; i < ids.length; i++) {
                        knownUpdateRowInPlace(parseInt(ids[i]), 'affinity', newAffinity);
                    }
                } else {
                    alertify.error("ERROR: " + ret[1]);
                }
            });
            $("#assets-select-all").prop("checked", false);
            $(".asset-cb").prop("checked", false);
            assetsUpdateSelection();
        }

        function knownBulkTypePrompt() {
            alertify.confirm(
                "<div style='text-align:center;font-family:monospace;'>" +
                "<p style='margin-bottom:12px;font-weight:700;'>CHANGE TYPE FOR SELECTED ASSETS</p>" +
                "<button class='btn assets-known-bulk-affinity-btn' style='display:inline-block;margin:4px;' onclick='knownBulkType(\"ip\");alertify.closeAll();'>IP</button>" +
                "<button class='btn assets-known-bulk-affinity-btn' style='display:inline-block;margin:4px;' onclick='knownBulkType(\"domain\");alertify.closeAll();'>DOMAIN</button>" +
                "<button class='btn assets-known-bulk-affinity-btn' style='display:inline-block;margin:4px;' onclick='knownBulkType(\"email\");alertify.closeAll();'>EMAIL</button>" +
                "<button class='btn assets-known-bulk-affinity-btn' style='display:inline-block;margin:4px;' onclick='knownBulkType(\"human_name\");alertify.closeAll();'>HUMAN NAME</button>" +
                "<button class='btn assets-known-bulk-affinity-btn' style='display:inline-block;margin:4px;' onclick='knownBulkType(\"username\");alertify.closeAll();'>USERNAME</button>" +
                "</div>",
                function() {}
            ).setting({'labels': {ok: 'CANCEL', cancel: ''}, 'closable': true});
            setTimeout(function() { $(".alertify .ajs-footer .ajs-cancel").hide(); }, 50);
