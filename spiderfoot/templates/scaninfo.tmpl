        // Load correlations data using async polling (prevents browser "page unresponsive")
        function loadCorrelationsIntoPanel(instanceId) {
            var panel = $('#findings-correlations-content');
            showCorrelationLoadingUI(panel);

            // Go straight to async load — skip the scanstatus pre-check
            // because scanstatus queries the DB and can hold the CherryPy
            // session lock while waiting on SQLite, blocking all subsequent polls.
            startAsyncCorrelationLoad(instanceId, null);
        }

        function startAsyncCorrelationLoad(instanceId, counts) {
            // Fire the async load request (returns immediately with a job_id)
            $.ajax({
                type: "POST",
                url: '${docroot}/scancorrelationsAsync',
                data: {'id': instanceId},
                dataType: "json",
                timeout: 10000,
                success: function(resp) {
                    if (resp.success && resp.job_id) {
                        pollCorrelationLoad(resp.job_id, instanceId, counts, 0);
                    } else {
                        renderCorrelationsPanelEmpty(instanceId);
                    }
                },
                error: function() {
                    renderCorrelationsPanelEmpty(instanceId);
                }
            });
        }

        function pollCorrelationLoad(jobId, instanceId, counts, msgIndex) {
            // Each poll is a short request (~50ms) that keeps the browser alive
            $.ajax({
                type: "GET",
                url: '${docroot}/correlationLoadStatus',
                data: {'job_id': jobId},
                dataType: "json",
                timeout: 10000,
                success: function(resp) {
                    if (!resp.success) {
                        renderCorrelationsPanelEmpty(instanceId);
                        return;
                    }

                    // Update progress bar and fun message from server progress
                    var pct = Math.min(95, resp.progress || 0);
                    msgIndex = (msgIndex + 1) % corrLoadingMessages.length;
                    var msg = resp.step || corrLoadingMessages[msgIndex];
                    // Use fun messages for the "querying" phase (the long part)
                    if (resp.progress <= 60) {
                        msg = corrLoadingMessages[msgIndex];
                    }
                    $('#corr-loading-msg').text(msg);
                    $('#corr-loading-bar').css('width', pct + '%').text(pct + '%');

                    if (resp.status === 'complete') {
                        // Animate progress bar to 100% before rendering results
                        $('#corr-loading-msg').text('Complete!');
                        $('#corr-loading-bar').css('width', '100%').text('100%');
                        var data = resp.data || [];
                        setTimeout(function() {
                            if (data.length > 0) {
                                renderCorrelationsPanel(instanceId, data, counts);
                            } else {
                                renderCorrelationsPanelEmpty(instanceId);
                            }
                        }, 800);
                    } else if (resp.status === 'error') {
                        renderCorrelationsPanelEmpty(instanceId);
                    } else {
                        // Still running — poll again in 2 seconds
                        setTimeout(function() {
                            pollCorrelationLoad(jobId, instanceId, counts, msgIndex);
                        }, 2000);
                    }
                },
                error: function() {
                    // Network blip — retry once more after a delay
                    setTimeout(function() {
                        pollCorrelationLoad(jobId, instanceId, counts, msgIndex);
                    }, 3000);
                }
            });
        }

        function buildAiCorrelationBar(instanceId) {
            // No longer rendered as a separate bar - AI rescan is now in the toolbar
            return "";
        }

        function initAiCorrelationButtons(instanceId) {
            sf.fetchData('${docroot}/checkAiCorrelationModes', {'id': instanceId},
                function(data) {
                    if (data.success) {
                        if (!data.single_scan_available) {
                            $("#btn-panel-rescan").prop('disabled', true).addClass('disabled')
                                .attr('title', 'No scan data available for analysis.');
                        }
                    }
                },
                function() { }
            );
        }

        function renderCorrelationsPanel(instanceId, data, counts) {
            var panel = $('#findings-correlations-content');

            if (!data || data.length == 0) {
                renderCorrelationsPanelEmpty(instanceId);
                return;
            }

            // Store raw data for filtering
            window.correlationsRawData = data;

            // Group correlations by rule_id (index [4] in API response)
            // AI correlations share a single rule_id, so group them by title prefix pattern instead.
            // AI headlines follow: "{type_label} {verb phrase}: {ioc_data}"
            // e.g. "Affiliate - IP Address corroborated by 2 modules: 23.210.216.135"
            // Group key = prefix before the IOC data = "Affiliate - IP Address corroborated by 2 modules"
            var aiTitlePrefixRe = /^(.+?(?:modules|event types|times|historical scan\(s\))): /;
            var groups = {};
            var groupOrder = [];
            for (var i = 0; i < data.length; i++) {
                var ruleId = data[i][4] || 'unknown';
                var isAiCorrelation = (ruleId === 'ai_single_scan_correlation' || ruleId === 'ai_cross_scan_correlation');
                var groupKey, groupName;

                if (isAiCorrelation) {
                    var title = data[i][1] || '';
                    var prefixMatch = title.match(aiTitlePrefixRe);
                    if (prefixMatch) {
                        var prefix = prefixMatch[1];
                        // Normalize the count number so "detected 3 times" and "detected 4 times" merge
                        var normalized = prefix.replace(/\b\d+\b(?= (?:modules|event types|times|historical scan))/, 'N');
                        groupKey = 'ai_' + normalized;
                        groupName = normalized;
                    } else {
                        // Fallback: each unmatched AI correlation is its own row
                        groupKey = 'ai_' + data[i][0];
                        groupName = title;
                    }
                } else {
                    groupKey = ruleId;
                    groupName = data[i][2] || ruleId;
                }

                if (!groups[groupKey]) {
                    groups[groupKey] = {
                        ruleId: ruleId,
                        ruleName: groupName,
                        risk: data[i][3] || 'INFO',
                        description: data[i][5] || '',
                        items: []
                    };
                    groupOrder.push(groupKey);
                } else if (isAiCorrelation) {
                    // AI groups may mix risk levels; promote to highest severity
                    var riskRank = { 'CRITICAL': 0, 'HIGH': 1, 'MEDIUM': 2, 'LOW': 3, 'INFO': 4 };
                    var curRisk = data[i][3] || 'INFO';
                    if ((riskRank[curRisk] || 4) < (riskRank[groups[groupKey].risk] || 4)) {
                        groups[groupKey].risk = curRisk;
                    }
                }
                groups[groupKey].items.push(data[i]);
            }

            // Sort groups by risk priority then by rule name
            var riskPriority = { 'CRITICAL': 0, 'HIGH': 1, 'MEDIUM': 2, 'LOW': 3, 'INFO': 4 };
            groupOrder.sort(function(a, b) {
                var riskA = riskPriority[groups[a].risk.toUpperCase()] !== undefined ? riskPriority[groups[a].risk.toUpperCase()] : 5;
                var riskB = riskPriority[groups[b].risk.toUpperCase()] !== undefined ? riskPriority[groups[b].risk.toUpperCase()] : 5;
                if (riskA !== riskB) return riskA - riskB;
                return (groups[a].ruleName || '').localeCompare(groups[b].ruleName || '');
            });

            // For AI groups with normalized "N", resolve to actual count or range
            var countBeforeSuffixRe = /\bN\b(?= (?:modules|event types|times|historical scan))/;
            for (var g = 0; g < groupOrder.length; g++) {
                var grp = groups[groupOrder[g]];
                if (grp.ruleName && grp.ruleName.match(countBeforeSuffixRe) && grp.items.length > 0) {
                    var counts = {};
                    for (var j = 0; j < grp.items.length; j++) {
                        var m = grp.items[j][1].match(aiTitlePrefixRe);
                        if (m) {
                            var numMatch = m[1].match(/\b(\d+)\b(?= (?:modules|event types|times|historical scan))/);
                            if (numMatch) counts[numMatch[1]] = true;
                        }
                    }
                    var unique = Object.keys(counts).sort(function(a, b) { return a - b; });
                    if (unique.length === 1) {
                        grp.ruleName = grp.ruleName.replace(countBeforeSuffixRe, unique[0]);
                    } else if (unique.length > 1) {
                        grp.ruleName = grp.ruleName.replace(countBeforeSuffixRe, unique[0] + '-' + unique[unique.length - 1]);
                    }
                }
            }

            // Store group data for filter/count functions
            window.correlationsGroupData = { groups: groups, groupOrder: groupOrder };

            // Count risk levels at group level (for filter buttons)
            var groupSevCounts = { critical: 0, high: 0, medium: 0, low: 0, info: 0 };
            for (var g = 0; g < groupOrder.length; g++) {
                var r = groups[groupOrder[g]].risk.toUpperCase();
                if (r === 'CRITICAL') groupSevCounts.critical++;
                else if (r === 'HIGH') groupSevCounts.high++;
                else if (r === 'MEDIUM') groupSevCounts.medium++;
                else if (r === 'LOW') groupSevCounts.low++;
                else if (r === 'INFO') groupSevCounts.info++;
            }

            var totalGroups = groupOrder.length;

            // Helper: badge class from risk level
            function corrBadgeClass(risk) {
                if (risk === 'CRITICAL') return 'alert-critical';
                if (risk === 'HIGH') return 'alert-danger';
                if (risk === 'MEDIUM') return 'alert-warning';
                if (risk === 'LOW') return 'alert-info';
                if (risk === 'INFO') return 'alert-success';
                return '';
            }

            // Helper: render type links
            function corrTypeLinks(eventTypes, instId) {
                if (!eventTypes) return '';
                var types = eventTypes.split(',');
                var links = [];
                for (var t = 0; t < types.length; t++) {
                    var typ = types[t].trim();
                    if (typ) {
                        links.push("<a class='finding-type-link' onclick='event.stopPropagation(); dataEventData(\"" + instId + "\", \"" + typ.replace(/"/g, '&quot;') + "\", \"" + typ.replace(/"/g, '&quot;') + "\", \"full\");' title='View " + typ + " data'>" + typ + "</a>");
                    }
                }
                return links.join(", ");
            }

            // Helper: render individual correlation detail row HTML
            function corrDetailHtml(item, riskLower, extraClasses, extraAttrs, hiddenStyle) {
                var corrId = item[0];
                var desc = item[5] || '';
                var h = "<tr class='finding-detail-row finding-" + riskLower + " corr-detail-row " + extraClasses + "' id='corrwell_tr_" + corrId + "'" + extraAttrs + (hiddenStyle ? " style='display:none'" : "") + ">";
                h += "<td colspan='4'><div class='finding-detail' id='corr-detail-content-" + corrId + "'>";
                if (desc) {
                    h += "<div class='corr-description-wrapper'>";
                    h += "<div class='finding-detail-section detail-description corr-description-wide'>";
                    h += "<div class='finding-detail-label'>Description</div>";
                    h += "<div class='finding-detail-text'>" + desc + "</div>";
                    h += "</div>";
                    h += "</div>";
                }
                h += "<div id='corrwell_td_" + corrId + "' class='corr-events-container'></div>";
                h += "</div></td></tr>";
                return h;
            }

            // Toolbar
            var html = "<div class='findings-toolbar'>";
            html += "<div class='findings-toolbar-left'>";
            html += "<button id='btn-panel-rescan' class='btn btn-sm btn-cyan' onclick='runAiCorrelation(\"" + instanceId + "\", \"single\")'>";
            html += "<i class='glyphicon glyphicon-flash'></i>&nbsp;COMPILE</button>&nbsp;";
            html += "<span class='findings-count' id='correlations-count'>" + totalGroups + " CORRELATIONS</span>";
            html += "&nbsp;<span class='findings-count-detail' id='correlations-total-count'>(" + data.length + " total findings)</span>";
            html += "</div>";
            html += "<div class='findings-toolbar-right'>";
            html += "<span class='ai-correlation-compact-results' id='ai-correlation-results'></span>";
            if (groupSevCounts.critical > 0) html += "<button class='filter-btn" + (correlationsFilterState.critical ? " filter-btn-active" : "") + "' id='corr-hide-critical' onclick='toggleCorrelationsFilter(\"critical\")'>" + (correlationsFilterState.critical ? "HIDING " : "HIDE ") + groupSevCounts.critical + " CRITICALS</button>&nbsp;";
            if (groupSevCounts.high > 0) html += "<button class='filter-btn" + (correlationsFilterState.high ? " filter-btn-active" : "") + "' id='corr-hide-high' onclick='toggleCorrelationsFilter(\"high\")'>" + (correlationsFilterState.high ? "HIDING " : "HIDE ") + groupSevCounts.high + " HIGHS</button>&nbsp;";
            if (groupSevCounts.medium > 0) html += "<button class='filter-btn" + (correlationsFilterState.medium ? " filter-btn-active" : "") + "' id='corr-hide-medium' onclick='toggleCorrelationsFilter(\"medium\")'>" + (correlationsFilterState.medium ? "HIDING " : "HIDE ") + groupSevCounts.medium + " MEDIUMS</button>&nbsp;";
            if (groupSevCounts.low > 0) html += "<button class='filter-btn" + (correlationsFilterState.low ? " filter-btn-active" : "") + "' id='corr-hide-low' onclick='toggleCorrelationsFilter(\"low\")'>" + (correlationsFilterState.low ? "HIDING " : "HIDE ") + groupSevCounts.low + " LOWS</button>&nbsp;";
            if (groupSevCounts.info > 0) html += "<button class='filter-btn" + (correlationsFilterState.info ? " filter-btn-active" : "") + "' id='corr-hide-info' onclick='toggleCorrelationsFilter(\"info\")'>" + (correlationsFilterState.info ? "HIDING " : "HIDE ") + groupSevCounts.info + " INFOS</button>";
            html += "</div></div>";

            // Table
            html += "<div class='findings-table-wrapper'>";
            html += "<table id='correlations-panel-table' class='table findings-table small'>";
            html += "<colgroup>";
            html += "<col class='col-priority'>";
            html += "<col class='col-corr-name'>";
            html += "<col class='col-corr-type'>";
            html += "<col class='col-corr-elements'>";
            html += "</colgroup>";
            html += "<thead><tr>";
            html += "<th>Risk</th>";
            html += "<th>Correlation</th>";
            html += "<th>Type</th>";
            html += "<th>Data Elements</th>";
            html += "</tr></thead><tbody id='corr-panel-tbody'></tbody></table></div>";

            // Insert toolbar + empty table immediately (fast, small DOM)
            panel.html(html);
            initAiCorrelationButtons(instanceId);

            // Render table rows progressively in chunks to keep browser responsive.
            // Each chunk appends a batch of groups to the tbody, then yields to the
            // browser via setTimeout so Chrome never considers the page unresponsive.
            var CHUNK_SIZE = 5;
            var chunkStart = 0;

            function renderNextChunk() {
                var end = Math.min(chunkStart + CHUNK_SIZE, groupOrder.length);
                var chunkHtml = '';

                for (var g = chunkStart; g < end; g++) {
                    var ruleId = groupOrder[g];
                    var group = groups[ruleId];
                    var items = group.items;
                    var risk = group.risk;
                    var riskLower = risk.toLowerCase();
                    var badgeClass = corrBadgeClass(risk);
                    var groupId = ruleId.replace(/[^a-zA-Z0-9_-]/g, '_');

                    if (items.length === 1) {
                        // Single-item group: render as individual row
                        var item = items[0];
                        var corrId = item[0];
                        var eventTypes = item[8] || '';

                        chunkHtml += "<tr class='finding-row finding-" + riskLower + " corr-row' data-corr-id='" + corrId + "' data-group-id='" + groupId + "' onclick='toggleCorrelation(\"" + instanceId + "\",\"" + corrId + "\")'>";
                        chunkHtml += "<td><span class='badge " + badgeClass + "'>" + risk + "</span>";
                        chunkHtml += " <i class='glyphicon glyphicon-chevron-right finding-expand-icon' id='corr-icon-" + corrId + "'></i>";
                        chunkHtml += "</td>";
                        chunkHtml += "<td><div class='cell-clamp'>" + item[1] + "</div></td>";
                        chunkHtml += "<td><div class='cell-clamp'>" + corrTypeLinks(eventTypes, instanceId) + "</div></td>";
                        chunkHtml += "<td><div class='cell-clamp'>" + item[7] + "</div></td>";
                        chunkHtml += "</tr>";

                        chunkHtml += corrDetailHtml(item, riskLower, 'corr-group-member', " data-group-id='" + groupId + "'", false);

                    } else {
                        // Multi-item group: render group header + hidden children
                        var totalElements = 0;
                        var allTypes = {};
                        for (var j = 0; j < items.length; j++) {
                            totalElements += parseInt(items[j][7]) || 0;
                            var types = (items[j][8] || '').split(',');
                            for (var t = 0; t < types.length; t++) {
                                var typ = types[t].trim();
                                if (typ) allTypes[typ] = true;
                            }
                        }
                        var aggregatedTypes = Object.keys(allTypes).join(',');

                        // Group header row
                        chunkHtml += "<tr class='finding-row finding-" + riskLower + " corr-group-row' data-group-id='" + groupId + "' onclick='toggleCorrelationGroup(\"" + instanceId + "\",\"" + groupId + "\")'>";
                        chunkHtml += "<td><span class='badge " + badgeClass + "'>" + risk + "</span>";
                        chunkHtml += " <i class='glyphicon glyphicon-chevron-right finding-expand-icon' id='corrgroup-icon-" + groupId + "'></i>";
                        chunkHtml += "</td>";
                        chunkHtml += "<td><div class='cell-clamp'>" + group.ruleName + " <span class='corr-group-count'>" + items.length + " findings</span></div></td>";
                        chunkHtml += "<td><div class='cell-clamp'>" + corrTypeLinks(aggregatedTypes, instanceId) + "</div></td>";
                        chunkHtml += "<td><div class='cell-clamp'>" + totalElements + "</div></td>";
                        chunkHtml += "</tr>";

                        // Child rows (hidden by default)
                        for (var j = 0; j < items.length; j++) {
                            var item = items[j];
                            var corrId = item[0];
                            var eventTypes = item[8] || '';

                            chunkHtml += "<tr class='finding-row finding-" + riskLower + " corr-row corr-group-child corr-group-member' data-group-id='" + groupId + "' data-corr-id='" + corrId + "' onclick='event.stopPropagation(); toggleCorrelation(\"" + instanceId + "\",\"" + corrId + "\")' style='display:none'>";
                            chunkHtml += "<td>";
                            chunkHtml += " <i class='glyphicon glyphicon-chevron-right finding-expand-icon' id='corr-icon-" + corrId + "'></i>";
                            chunkHtml += "</td>";
                            chunkHtml += "<td><div class='cell-clamp'>" + item[1] + "</div></td>";
                            chunkHtml += "<td><div class='cell-clamp'>" + corrTypeLinks(eventTypes, instanceId) + "</div></td>";
                            chunkHtml += "<td><div class='cell-clamp'>" + item[7] + "</div></td>";
                            chunkHtml += "</tr>";

                            chunkHtml += corrDetailHtml(item, riskLower, 'corr-group-child-detail corr-group-member', " data-group-id='" + groupId + "'", true);
                        }
                    }
                }

                // Append this chunk's rows to the tbody (fast incremental insert)
                document.getElementById('corr-panel-tbody').insertAdjacentHTML('beforeend', chunkHtml);
                chunkStart = end;

                if (chunkStart < groupOrder.length) {
                    // More chunks to render — yield to browser then continue
                    setTimeout(renderNextChunk, 0);
                } else {
                    // All rows rendered — update tooltips on next tick
                    // Note: tablesorter is intentionally skipped here because:
                    // 1. Rows are already sorted by risk priority (groupOrder.sort)
                    // 2. Tablesorter on ~2000 rows with cssChildRow blocks for seconds
                    // 3. Re-sorting a grouped table breaks parent-child row associations
                    setTimeout(function() {
                        sf.updateTooltips();
                    }, 0);
                }
            }

            // Start chunked rendering on next frame
            setTimeout(renderNextChunk, 0);
        }

