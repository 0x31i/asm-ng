        function saveTypeComment() {
            var ta = document.getElementById('analyst-type-comment');
            var status = document.getElementById('comment-save-status');
            if (!ta) return;
            var comment = ta.value;
            sf.fetchData('${docroot}/typecommentsave', {id: '${id}', eventType: currentType, comment: comment}, function(data) {
                if (status) {
                    if (data && data.success) {
                        status.textContent = 'Saved';
                        status.className = 'comment-save-status saved';
                    } else {
                        status.textContent = 'Error';
                        status.className = 'comment-save-status error';
                    }
                    setTimeout(function() { status.textContent = ''; status.className = 'comment-save-status'; }, 2000);
                }
            });
        }

        function saveRowNote(eventHash, idx) {
            var ta = document.getElementById('analyst-row-note-' + eventHash);
            var status = document.getElementById('note-save-status-' + eventHash);
            if (!ta) return;
            var note = ta.value;
            sf.fetchData('${docroot}/rownotesave', {id: '${id}', resultHash: eventHash, note: note}, function(data) {
                if (status) {
                    if (data && data.success) {
                        status.textContent = 'Saved';
                        status.className = 'note-save-status saved';
                        // Update in-memory data so re-renders preserve the note
                        if (typeof idx !== 'undefined' && currentViewData && currentViewData[idx]) {
                            currentViewData[idx][16] = note || null;
                        }
                    } else {
                        status.textContent = 'Error';
                        status.className = 'note-save-status error';
                    }
                    setTimeout(function() { status.textContent = ''; status.className = 'note-save-status'; }, 2000);
                }
            });
        }

        // Update button disabled states based on current type
        function updateInfoButtonStates() {
            // Close panel when switching types
            if (_infoPanelOpen) {
                closeInfoPanel();
            }
            var btnMod = document.getElementById("btn-module-info");
            var btnInst = document.getElementById("btn-instructions");
            var btnComm = document.getElementById("btn-comments");
            if (!currentType || currentType === "ALL") {
                if (btnMod) { btnMod.disabled = true; btnMod.classList.add('disabled'); }
                if (btnInst) { btnInst.disabled = true; btnInst.classList.add('disabled'); }
                if (btnComm) { btnComm.disabled = true; btnComm.classList.add('disabled'); }
                return;
            }
            // Module info is always available (every type has producing modules)
            if (btnMod) { btnMod.disabled = false; btnMod.classList.remove('disabled'); }

            // Instructions: only enable if mapping exists
            if (_instructionsMap[currentType]) {
                if (btnInst) { btnInst.disabled = false; btnInst.classList.remove('disabled'); }
            } else {
                if (btnInst) { btnInst.disabled = true; btnInst.classList.add('disabled'); }
            }

            // Comments: always available when a specific type is selected
            if (btnComm) { btnComm.disabled = false; btnComm.classList.remove('disabled'); }
        }

