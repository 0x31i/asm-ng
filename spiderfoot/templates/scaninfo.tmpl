        function assetsSetActiveBtn(viewName) {
            $(".assets-view-btn").removeClass("assets-view-btn-active");
            $("#assets-btn-" + viewName).addClass("assets-view-btn-active");
            currentAssetsView = viewName;
        }

        function assetsShowImportModal() {
            assetsPopulateTagDropdowns();
            $("#assets-import-modal").show();
        }
        function assetsShowAddModal() {
            assetsPopulateTagDropdowns();
            $("#assets-add-modal").show();
        }
        function assetsShowTagModal() {
            assetsLoadTagList();
            $("#assets-tag-modal").show();
        }
        function assetsCloseModals() { $(".assets-modal-overlay").hide(); }

        // Populate tag dropdowns in import/add modals
        function assetsPopulateTagDropdowns() {
            sf.fetchData('${docroot}/assettaglist', {target: assetsTarget}, function(tags) {
                var opts = "<option value=''>NONE</option>";
                for (var i = 0; i < tags.length; i++) {
                    opts += "<option value='" + $('<span>').text(tags[i].tag).html() + "'>" + $('<span>').text(tags[i].tag).html() + "</option>";
                }
                $("#import-asset-tag").html(opts);
                $("#add-asset-tag").html(opts);
            });
        }

        // Load tag list for management modal
        function assetsLoadTagList() {
            sf.fetchData('${docroot}/assettaglist', {target: assetsTarget}, function(tags) {
                if (tags.length === 0) {
                    $("#tag-list-container").html("<p class='assets-empty-text'>NO TAGS DEFINED YET.</p>");
                    return;
                }
                var html = "<table class='table table-bordered assets-table' style='margin-bottom:0;'>";
                html += "<thead><tr><th>TAG</th><th>COLOR</th><th style='width:80px;'>ACTIONS</th></tr></thead><tbody>";
                for (var i = 0; i < tags.length; i++) {
                    var t = tags[i];
                    var safeTag = $('<span>').text(t.tag).html();
                    html += "<tr data-tag-id='" + t.id + "'>";
                    html += "<td><span class='assets-tag-badge' style='background:" + t.color + "20;color:" + t.color + ";border:1px solid " + t.color + "33;'>" + safeTag + "</span></td>";
                    html += "<td><input type='color' value='" + t.color + "' onchange='assetsUpdateTagColor(" + t.id + ", this.value)' style='width:32px;height:24px;border:none;background:none;cursor:pointer;'></td>";
                    html += "<td><button class='btn btn-xs assets-icon-btn' onclick='assetsRemoveTag(" + t.id + ")' title='DELETE'>";
                    html += "<i class='glyphicon glyphicon-trash'></i></button></td>";
                    html += "</tr>";
                }
                html += "</tbody></table>";
                $("#tag-list-container").html(html);
            });
        }

        function assetsDoAddTag() {
            cachedAssetTags = null;
            var name = document.getElementById('new-tag-name').value.trim();
            var color = document.getElementById('new-tag-color').value;
            if (!name) { alertify.error("ENTER A TAG NAME."); return; }
            sf.fetchData('${docroot}/assettagadd', {target: assetsTarget, tag: name, color: color}, function(ret) {
                if (ret[0] === "SUCCESS") {
                    alertify.success("TAG ADDED");
                    document.getElementById('new-tag-name').value = '';
                    assetsLoadTagList();
                } else {
                    alertify.error("ERROR: " + ret[1]);
                }
            });
        }

        function assetsRemoveTag(tagId) {
            cachedAssetTags = null;
            sf.fetchData('${docroot}/assettagremove', {id: tagId}, function(ret) {
                if (ret[0] === "SUCCESS") {
                    alertify.success("TAG REMOVED");
                    assetsLoadTagList();
                } else {
                    alertify.error("ERROR: " + ret[1]);
                }
            });
        }

        function assetsUpdateTagColor(tagId, color) {
            cachedAssetTags = null;
            sf.fetchData('${docroot}/assettagupdate', {id: tagId, color: color}, function(ret) {
                if (ret[0] === "SUCCESS") {
                    assetsLoadTagList();
                }
            });
        }

        // ---- SYNC VERIFIED → KNOWN ASSETS ----
        function assetsSyncVerified(instanceId) {
            alertify.success("SYNCING VERIFIED ENTRIES...");
            sf.fetchData('${docroot}/knownassetsyncverified', {id: instanceId}, function(ret) {
                if (ret[0] === "SUCCESS") {
                    alertify.success(ret[1]);
                    if (currentAssetsView === 'overview') assetsShowOverview(instanceId);
                    else if (currentAssetsView === 'known') assetsShowKnown(instanceId);
                    else if (currentAssetsView === 'potential') assetsShowPotential(instanceId);
                } else {
                    alertify.error("SYNC FAILED: " + ret[1]);
                }
            });
        }

        // ---- OVERVIEW VIEW ----
        function assetsShowOverview(instanceId) {
            assetsSetActiveBtn('overview');
            pushViewState('btn-assets', {assetsView: 'overview'});
            $("#assets-content").html("<div class='assets-loader'><img src='${docroot}/static/img/loader.gif'></div>");

            // Fetch counts and matches in parallel
            var countsLoaded = false, matchesLoaded = false;
            var counts = {total:0, client_provided:0, analyst_confirmed:0, direct:0, associated:0, by_type:{ip:0, domain:0, email:0, human_name:0}};
            var matchData = [];

            sf.fetchData('${docroot}/knownassetcount', {target: assetsTarget}, function(data) {
                counts = data;
                countsLoaded = true;
                if (matchesLoaded) renderOverview(instanceId, counts, matchData);
            });

            sf.fetchData('${docroot}/knownassetmatches', {id: instanceId}, function(data) {
                matchData = data;
                matchesLoaded = true;
                if (countsLoaded) renderOverview(instanceId, counts, matchData);
            });
        }

        function renderOverview(instanceId, counts, matches) {
            var pendingMatches = 0;
            for (var i = 0; i < matches.length; i++) {
                if (matches[i].false_positive == 0 && !matches[i].isTargetFp && !matches[i].isTargetValidated) {
                    pendingMatches++;
                }
            }

            var html = "<div class='assets-overview-grid'>";

            // Summary Cards Row
            html += "<div class='assets-cards-row'>";
            html += "<div class='assets-card assets-card-total'>";
            html += "<div class='assets-card-icon'><i class='glyphicon glyphicon-hdd'></i></div>";
            html += "<div class='assets-card-info'><span class='assets-card-number'>" + (counts.confirmed || 0) + "</span>";
            html += "<span class='assets-card-label'>CONFIRMED ASSETS</span></div></div>";

            html += "<div class='assets-card assets-card-pending-review'>";
            html += "<div class='assets-card-icon'><i class='glyphicon glyphicon-time'></i></div>";
            html += "<div class='assets-card-info'><span class='assets-card-number'>" + (counts.pending || 0) + "</span>";
            html += "<span class='assets-card-label'>PENDING REVIEW</span></div></div>";

            html += "<div class='assets-card assets-card-client'>";
            html += "<div class='assets-card-icon'><i class='glyphicon glyphicon-briefcase'></i></div>";
            html += "<div class='assets-card-info'><span class='assets-card-number'>" + counts.client_provided + "</span>";
            html += "<span class='assets-card-label'>CLIENT PROVIDED</span></div></div>";

            html += "<div class='assets-card assets-card-analyst'>";
            html += "<div class='assets-card-icon'><i class='glyphicon glyphicon-ok-sign'></i></div>";
            html += "<div class='assets-card-info'><span class='assets-card-number'>" + counts.analyst_confirmed + "</span>";
            html += "<span class='assets-card-label'>ANALYST CONFIRMED</span></div></div>";

            html += "<div class='assets-card assets-card-pending'>";
            html += "<div class='assets-card-icon'><i class='glyphicon glyphicon-search'></i></div>";
            html += "<div class='assets-card-info'><span class='assets-card-number'>" + pendingMatches + "</span>";
            html += "<span class='assets-card-label'>PENDING MATCHES</span></div></div>";
            html += "</div>";

            // Type Breakdown Row (5 columns)
            html += "<div class='assets-breakdown-row assets-breakdown-row-5'>";
            html += "<div class='assets-breakdown-card assets-breakdown-card-ip'>";
            html += "<i class='glyphicon glyphicon-map-marker'></i>";
            html += "<span class='assets-breakdown-count'>" + (counts.by_type.ip || 0) + "</span>";
            html += "<span class='assets-breakdown-label'>IP ADDRESSES</span></div>";

            html += "<div class='assets-breakdown-card assets-breakdown-card-domain'>";
            html += "<i class='glyphicon glyphicon-globe'></i>";
            html += "<span class='assets-breakdown-count'>" + (counts.by_type.domain || 0) + "</span>";
            html += "<span class='assets-breakdown-label'>DOMAINS</span></div>";

            html += "<div class='assets-breakdown-card assets-breakdown-card-email'>";
            html += "<i class='glyphicon glyphicon-envelope'></i>";
            html += "<span class='assets-breakdown-count'>" + (counts.by_type.email || 0) + "</span>";
            html += "<span class='assets-breakdown-label'>EMAILS</span></div>";

            html += "<div class='assets-breakdown-card assets-breakdown-card-human'>";
            html += "<i class='glyphicon glyphicon-user'></i>";
            html += "<span class='assets-breakdown-count'>" + (counts.by_type.human_name || 0) + "</span>";
            html += "<span class='assets-breakdown-label'>HUMAN NAMES</span></div>";

            html += "<div class='assets-breakdown-card assets-breakdown-card-username'>";
            html += "<i class='glyphicon glyphicon-comment'></i>";
            html += "<span class='assets-breakdown-count'>" + (counts.by_type.username || 0) + "</span>";
            html += "<span class='assets-breakdown-label'>USERNAMES</span></div>";

            // Mixed Breakdown Row (3 columns)
            html += "<div class='assets-breakdown-row assets-breakdown-row-3' style='margin-top:0;'>";
            html += "<div class='assets-breakdown-card assets-breakdown-card-matches'>";
            html += "<i class='glyphicon glyphicon-warning-sign'></i>";
            html += "<span class='assets-breakdown-count'>" + matches.length + "</span>";
            html += "<span class='assets-breakdown-label'>SCAN MATCHES</span></div>";

            html += "<div class='assets-breakdown-card assets-breakdown-card-direct'>";
            html += "<i class='glyphicon glyphicon-record'></i>";
            html += "<span class='assets-breakdown-count'>" + (counts.direct || 0) + "</span>";
            html += "<span class='assets-breakdown-label'>DIRECT</span></div>";

            html += "<div class='assets-breakdown-card assets-breakdown-card-associated'>";
            html += "<i class='glyphicon glyphicon-transfer'></i>";
            html += "<span class='assets-breakdown-count'>" + (counts.associated || 0) + "</span>";
            html += "<span class='assets-breakdown-label'>ASSOCIATED</span></div>";
            html += "</div>";

            // Quick action callout
            if (pendingMatches > 0) {
                html += "<div class='assets-callout'>";
                html += "<i class='glyphicon glyphicon-bell'></i>&nbsp;&nbsp;";
                html += "<strong>" + pendingMatches + " POTENTIAL MATCHES</strong> NEED REVIEW.&nbsp;&nbsp;";
                html += "<a class='link assets-callout-link' onclick='assetsShowPotential(\"" + instanceId + "\")'>REVIEW NOW</a>";
                html += "</div>";
            } else if (counts.total === 0) {
                html += "<div class='assets-callout assets-callout-info'>";
                html += "<i class='glyphicon glyphicon-info-sign'></i>&nbsp;&nbsp;";
                html += "NO KNOWN ASSETS YET. USE <strong>IMPORT LIST</strong> TO UPLOAD CLIENT ASSETS, ";
                html += "OR <strong>SYNC VERIFIED</strong> TO PULL IN EXISTING VALIDATED ENTRIES.";
                html += "</div>";
            }

            // Import History
            html += "<div class='assets-section-header'><i class='glyphicon glyphicon-time'></i>&nbsp;&nbsp;IMPORT HISTORY</div>";
            html += "<div id='assets-import-history'><span class='assets-loader-text'>LOADING...</span></div>";

            html += "</div>";
            $("#assets-content").html(html);
            $("#loader").hide();

            // Load import history
            sf.fetchData('${docroot}/knownassetimporthistory', {target: assetsTarget}, function(history) {
                if (history.length === 0) {
                    $("#assets-import-history").html("<p class='assets-empty-text'>NO IMPORTS YET. USE THE IMPORT LIST BUTTON TO GET STARTED.</p>");
                    return;
                }
                var tbl = "<table class='table table-bordered table-striped assets-table'>";
                tbl += "<thead><tr><th>DATE</th><th>TYPE</th><th>FILE</th><th>ITEMS</th><th>BY</th></tr></thead><tbody>";
                for (var i = 0; i < history.length; i++) {
                    var h = history[i];
                    var d = new Date(h.date_imported * 1000);
                    tbl += "<tr><td>" + d.toLocaleString() + "</td>";
                    tbl += "<td><span class='assets-type-badge assets-type-" + h.asset_type + "'>" + h.asset_type.toUpperCase() + "</span></td>";
                    tbl += "<td>" + (h.file_name || '-') + "</td>";
                    tbl += "<td>" + h.item_count + "</td>";
                    tbl += "<td>" + (h.imported_by || '-') + "</td></tr>";
                }
                tbl += "</tbody></table>";
                $("#assets-import-history").html(tbl);
            });
        }

        // ---- KNOWN ASSETS VIEW ----
        // Known assets active filters (multi-select)
        var knownActiveFilters = { type: 'all', affinity: 'all', source: 'all', tag: 'all' };
        var knownSortState = { col: null, dir: 'asc' };
        var _knownAllData = [];    // Full dataset for progressive rendering
        var _knownRenderedCount = 0; // How many rows have been rendered so far
        var cachedAssetTags = null;
        var knownKebabActiveId = null;

        function assetsShowKnown(instanceId, onComplete) {
            assetsSetActiveBtn('known');
            pushViewState('btn-assets', {assetsView: 'known'});
            $("#assets-content").html("<div class='assets-loader'><img src='${docroot}/static/img/loader.gif'></div>");

            sf.fetchData('${docroot}/knownassetlist', {target: assetsTarget, status: 'CONFIRMED'}, function(response) {
                // Handle both old array format and new {items, total} format
                var data = Array.isArray(response) ? response : (response.items || []);
                var KNOWN_PAGE_SIZE = 200;
                _knownAllData = data; // Store for progressive rendering
                _knownRenderedCount = 0;

                var html = "";

                // Count by type and source
                var ipCount = 0, domainCount = 0, emailCount = 0, humanNameCount = 0, usernameCount = 0;
                var clientCount = 0, analystCount = 0, directCount = 0, associatedCount = 0;
                var tagCounts = {}, untaggedCount = 0;
                for (var i = 0; i < data.length; i++) {
                    if (data[i].asset_type === 'ip') ipCount++;
                    if (data[i].asset_type === 'domain') domainCount++;
                    if (data[i].asset_type === 'email') emailCount++;
                    if (data[i].asset_type === 'human_name') humanNameCount++;
                    if (data[i].asset_type === 'username') usernameCount++;
                    if (data[i].source === 'CLIENT_PROVIDED') clientCount++;
                    if (data[i].source === 'ANALYST_CONFIRMED') analystCount++;
                    if (data[i].affinity === 'ASSOCIATED') associatedCount++;
                    else directCount++;
                    if (data[i].tag) {
                        tagCounts[data[i].tag] = (tagCounts[data[i].tag] || 0) + 1;
                    } else {
                        untaggedCount++;
                    }
                }

                // Filter bar - compact pills, color-coded groups, two-row layout
                html += "<div class='assets-known-filter-bar assets-known-sticky-bar' id='assets-known-sticky-bar'>";

                // Search box
                html += "<div class='assets-known-filter-row' style='margin-bottom:4px;'>";
                html += "<div class='assets-known-filter-group' style='flex:1;'>";
                html += "<span class='assets-known-filter-label' style='margin-right:6px;'>SEARCH</span>";
                html += "<input type='text' id='assets-known-search' class='assets-known-search-input' placeholder='Filter by value...' autocomplete='off' style='flex:1;max-width:320px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:4px;padding:5px 10px;font-family:monospace;font-size:11px;color:inherit;outline:none;'>";
                html += "</div></div>";

                // Row 1: TYPE + AFFINITY + bulk action buttons
                html += "<div class='assets-known-filter-row'>";
                html += "<div class='assets-known-filter-group assets-known-filter-group-type'>";
                html += "<span class='assets-known-filter-label assets-known-filter-label-type'>TYPE</span>";
                html += "<button class='assets-known-filter-btn assets-known-filter-type" + (knownActiveFilters.type === 'all' ? " assets-known-filter-active assets-known-filter-active-type" : "") + "' onclick='knownFilterType(\"all\", this)'>";
                html += "<i class='glyphicon glyphicon-th-list'></i>&nbsp;&nbsp;ALL (" + data.length + ")</button>";
                html += "<button class='assets-known-filter-btn assets-known-filter-type" + (knownActiveFilters.type === 'ip' ? " assets-known-filter-active assets-known-filter-active-type" : "") + "' onclick='knownFilterType(\"ip\", this)'>";
                html += "<i class='glyphicon glyphicon-globe'></i>&nbsp;&nbsp;IPS (" + ipCount + ")</button>";
                html += "<button class='assets-known-filter-btn assets-known-filter-type" + (knownActiveFilters.type === 'domain' ? " assets-known-filter-active assets-known-filter-active-type" : "") + "' onclick='knownFilterType(\"domain\", this)'>";
                html += "<i class='glyphicon glyphicon-link'></i>&nbsp;&nbsp;DOMAINS (" + domainCount + ")</button>";
                html += "<button class='assets-known-filter-btn assets-known-filter-type" + (knownActiveFilters.type === 'email' ? " assets-known-filter-active assets-known-filter-active-type" : "") + "' onclick='knownFilterType(\"email\", this)'>";
                html += "<i class='glyphicon glyphicon-envelope'></i>&nbsp;&nbsp;EMAILS (" + emailCount + ")</button>";
                html += "<button class='assets-known-filter-btn assets-known-filter-type" + (knownActiveFilters.type === 'human_name' ? " assets-known-filter-active assets-known-filter-active-type" : "") + "' onclick='knownFilterType(\"human_name\", this)'>";
                html += "<i class='glyphicon glyphicon-user'></i>&nbsp;&nbsp;HUMAN NAMES (" + humanNameCount + ")</button>";
                html += "<button class='assets-known-filter-btn assets-known-filter-type" + (knownActiveFilters.type === 'username' ? " assets-known-filter-active assets-known-filter-active-type" : "") + "' onclick='knownFilterType(\"username\", this)'>";
                html += "<i class='glyphicon glyphicon-comment'></i>&nbsp;&nbsp;USERNAMES (" + usernameCount + ")</button>";
                html += "</div>";
                html += "<div class='assets-known-filter-group assets-known-filter-group-affinity'>";
                html += "<span class='assets-known-filter-label assets-known-filter-label-affinity'>AFFINITY</span>";
                html += "<button class='assets-known-filter-btn assets-known-filter-affinity" + (knownActiveFilters.affinity === 'all' ? " assets-known-filter-active assets-known-filter-active-affinity" : "") + "' onclick='knownFilterAffinity(\"all\", this)'>";
                html += "<i class='glyphicon glyphicon-th-list'></i>&nbsp;&nbsp;ALL</button>";
                html += "<button class='assets-known-filter-btn assets-known-filter-affinity" + (knownActiveFilters.affinity === 'DIRECT' ? " assets-known-filter-active assets-known-filter-active-affinity" : "") + "' onclick='knownFilterAffinity(\"DIRECT\", this)'>";
                html += "<i class='glyphicon glyphicon-record'></i>&nbsp;&nbsp;DIRECT (" + directCount + ")</button>";
                html += "<button class='assets-known-filter-btn assets-known-filter-affinity" + (knownActiveFilters.affinity === 'ASSOCIATED' ? " assets-known-filter-active assets-known-filter-active-affinity" : "") + "' onclick='knownFilterAffinity(\"ASSOCIATED\", this)'>";
                html += "<i class='glyphicon glyphicon-transfer'></i>&nbsp;&nbsp;ASSOCIATED (" + associatedCount + ")</button>";
                html += "</div>";
                html += "</div>";

                // Row 2: SOURCE + TAG
                html += "<div class='assets-known-filter-row'>";
                html += "<div class='assets-known-filter-group assets-known-filter-group-source'>";
                html += "<span class='assets-known-filter-label assets-known-filter-label-source'>SOURCE</span>";
                html += "<button class='assets-known-filter-btn assets-known-filter-src assets-known-filter-source" + (knownActiveFilters.source === 'all' ? " assets-known-filter-active assets-known-filter-active-source" : "") + "' onclick='knownFilterSource(\"all\", this)'>";
                html += "<i class='glyphicon glyphicon-th-list'></i>&nbsp;&nbsp;ALL</button>";
