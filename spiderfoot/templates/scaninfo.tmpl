        // Store data for bulk FP operations
        var currentViewData = [];

        // Pagination state for "Load All" button
        var paginatedInstanceId = null;
        var paginatedEventType = null;
        var PAGE_SIZE = 500;
        var _pendingScrollToHash = null;

        // Client-side filter state - persists while on the page
        var clientFilterState = {
            fp: false,
            validated: false,
            imported: false
        };

        // Data type tracking filter state
        var dataTrackingFilterState = {
            closed: false,
            ticketed: false
        };

        // Get tracking badge HTML for data type events
        function getDataTrackingBadge(tracking, eventHash) {
            var labels = {0: 'OPEN', 1: 'CLOSED', 2: 'TICKETED'};
            var classes = {0: 'tracking-open', 1: 'tracking-closed', 2: 'tracking-ticketed'};
            var val = parseInt(tracking) || 0;
            return "<span class='tracking-badge " + classes[val] + "' data-event-hash='" + eventHash + "' data-tracking='" + val + "' onclick='cycleDataTracking(event, \"" + eventHash + "\", " + val + ")'>" + labels[val] + "</span>";
        }

        // Cycle data tracking: OPEN(0) -> TICKETED(2) -> CLOSED(1) -> OPEN(0)
        function cycleDataTracking(evt, eventHash, currentVal) {
            evt.stopPropagation();
            var next = currentVal === 0 ? 2 : (currentVal === 2 ? 1 : 0);
            var scanId = '${id}';

            sf.fetchData('${docroot}/scaneventsettracking', {'id': scanId, 'resultHash': eventHash, 'tracking': next},
                function(data) {
                    if (data.success) {
                        // Update badge in place
                        var labels = {0: 'OPEN', 1: 'CLOSED', 2: 'TICKETED'};
                        var classes = {0: 'tracking-open', 1: 'tracking-closed', 2: 'tracking-ticketed'};
                        var badge = $(evt.target);
                        badge.removeClass('tracking-open tracking-closed tracking-ticketed');
                        badge.addClass(classes[next]);
                        badge.text(labels[next]);
                        badge.attr('data-tracking', next);
                        badge.attr('onclick', "cycleDataTracking(event, '" + eventHash + "', " + next + ")");
                        // Update stored data
                        for (var i = 0; i < currentViewData.length; i++) {
                            if (currentViewData[i][7] === eventHash) {
                                currentViewData[i][15] = next;
                            }
                        }
                        updateDataTrackingFilterCounts();
                    }
                }
            );
        }

        // Toggle data tracking filter
        function toggleDataTrackingFilter(type) {
            dataTrackingFilterState[type] = !dataTrackingFilterState[type];
            applyDataTrackingFilters();
            // Update button states
            var btn = $('.filter-btn-data-' + type);
            if (dataTrackingFilterState[type]) {
                btn.addClass('filter-btn-active');
                btn.text(btn.attr('data-hiding-text'));
            } else {
                btn.removeClass('filter-btn-active');
                btn.text(btn.attr('data-show-text'));
            }
        }

        // Apply data tracking filters
        function applyDataTrackingFilters() {
            var visibleCount = 0;
            var hiddenCount = 0;

            $("#scansummary-content tbody tr").each(function() {
                var row = $(this);
                // Skip detail rows
                if (row.hasClass('data-detail-row')) return;

                var shouldHide = false;
                var badge = row.find('.tracking-badge');

                // Check existing client-side filters first
                var statusSpan = row.find(".validation-status span");
                var isImported = row.hasClass("imported-row");

                if (clientFilterState.fp && statusSpan.hasClass('status-fp')) {
                    shouldHide = true;
                }
                if (clientFilterState.validated && statusSpan.hasClass('status-validated')) {
                    shouldHide = true;
                }
                if (clientFilterState.imported && isImported) {
                    shouldHide = true;
                }

                // Check tracking filters
                if (badge.length > 0) {
                    var trackingVal = parseInt(badge.attr('data-tracking')) || 0;
                    if (dataTrackingFilterState.closed && trackingVal === 1) {
                        shouldHide = true;
                    }
                    if (dataTrackingFilterState.ticketed && trackingVal === 2) {
                        shouldHide = true;
                    }
                }

                if (shouldHide) {
                    row.hide();
                    row.next('.data-detail-row').hide();
                    hiddenCount++;
                } else {
                    row.show();
                    visibleCount++;
                }
            });

            $(".stats-bar-left .stats-item:first-child .stats-value").text(visibleCount);
            return visibleCount;
        }

        // Update data tracking filter counts
        function updateDataTrackingFilterCounts() {
            var closedCount = 0;
            var ticketedCount = 0;

            $("#scansummary-content tbody tr").each(function() {
                var row = $(this);
                if (row.hasClass('data-detail-row')) return;
                var badge = row.find('.tracking-badge');
                if (badge.length > 0) {
                    var val = parseInt(badge.attr('data-tracking')) || 0;
                    if (val === 1) closedCount++;
                    if (val === 2) ticketedCount++;
                }
            });

            // Show/hide filter buttons
            var closedBtn = $('.filter-btn-data-closed');
            var ticketedBtn = $('.filter-btn-data-ticketed');

            if (closedCount > 0) {
                closedBtn.show();
                closedBtn.attr('data-show-text', 'HIDE ' + closedCount + ' CLOSED');
                closedBtn.attr('data-hiding-text', 'HIDING ' + closedCount + ' CLOSED');
                closedBtn.text(dataTrackingFilterState.closed ? 'HIDING ' + closedCount + ' CLOSED' : 'HIDE ' + closedCount + ' CLOSED');
            } else {
                closedBtn.hide();
            }

            if (ticketedCount > 0) {
                ticketedBtn.show();
                ticketedBtn.attr('data-show-text', 'HIDE ' + ticketedCount + ' TICKETED');
                ticketedBtn.attr('data-hiding-text', 'HIDING ' + ticketedCount + ' TICKETED');
                ticketedBtn.text(dataTrackingFilterState.ticketed ? 'HIDING ' + ticketedCount + ' TICKETED' : 'HIDE ' + ticketedCount + ' TICKETED');
            } else {
                ticketedBtn.hide();
            }
        }

        // Discovery path cache (hash -> pathData array)
        var dpPathCache = {};

        // Build data detail HTML for expanded row
        function buildDataDetailHtml(d) {
            var noteVal = (d[16] != null && d[16] !== undefined) ? d[16] : '';
            var eventHash = d[7] || '';
            var rowIdx = d._idx !== undefined ? d._idx : '';
            // Discovery Path section (lazy-loaded on expand)
            var html = "<div class='detail-discovery-path' id='dp-container-" + sf.escapeHtml(eventHash) + "'>";
            html += "<div class='finding-detail-label dp-label'>Discovery Path</div>";
            html += "<div class='dp-path-content' id='dp-content-" + sf.escapeHtml(eventHash) + "'></div>";
            html += "</div>";
            // Analyst Note section
            html += "<div class='detail-analyst-note'>";
            html += "<div class='finding-detail-label'>Analyst Note</div>";
            html += "<div class='analyst-note-container'>";
            html += "<textarea id='analyst-row-note-" + sf.escapeHtml(eventHash) + "' class='analyst-note-textarea' placeholder='Add a note for this result...' rows='2' onclick='event.stopPropagation()'>" + sf.escapeHtml(noteVal) + "</textarea>";
            html += "<button class='btn-save-note' onclick='event.stopPropagation(); saveRowNote(\"" + sf.escapeHtml(eventHash) + "\", " + rowIdx + ")'>SAVE</button>";
            html += "<span id='note-save-status-" + sf.escapeHtml(eventHash) + "' class='note-save-status'></span>";
            html += "</div></div>";
            return html;
        }

        // Toggle data detail row expansion
        function toggleDataDetail(idx) {
            var row = $('tr[data-event-idx="' + idx + '"]');
            var detail = row.next('.data-detail-row');
            if (row.hasClass('finding-expanded')) {
                row.removeClass('finding-expanded');
                detail.find('.finding-detail').slideUp(150, function() {
                    detail.hide();
                });
            } else {
                row.addClass('finding-expanded');
                detail.show();
                detail.find('.finding-detail').slideDown(150);
                // Lazy-load discovery path on first expand
                var d = currentViewData ? currentViewData[idx] : null;
                if (d && d[7] && !dpPathCache[d[7]]) {
                    loadDiscoveryPath(d[7]);
                }
            }
        }

        // Load discovery path for a given element hash
        function loadDiscoveryPath(eventHash) {
            if (dpPathCache[eventHash]) return;
            dpPathCache[eventHash] = 'loading';
            var container = document.getElementById('dp-content-' + eventHash);
            if (container) container.innerHTML = "<span class='dp-loading'>Loading...</span>";

            sf.fetchData('${docroot}/scanelementpath', {id: '${id}', resultHash: eventHash}, function(pathData) {
                dpPathCache[eventHash] = pathData;
                renderDiscoveryPath(eventHash, pathData);
            });
        }

        // Render discovery path as inline badge trail
        function renderDiscoveryPath(eventHash, pathData) {
            var container = document.getElementById('dp-content-' + eventHash);
            if (!container) return;
            if (!pathData || !pathData.length) {
                container.innerHTML = "<span class='dp-no-path'>No discovery path available</span>";
                return;
            }
            var html = "<div class='dp-inline-trail'>";
            for (var i = 0; i < pathData.length; i++) {
                var node = pathData[i];
                var isLast = (i === pathData.length - 1);
                var nodeClass = 'dp-inline-node';
                if (isLast) nodeClass += ' dp-inline-current';
                if (node.isRoot) nodeClass += ' dp-inline-root';

                html += "<div class='" + nodeClass + "'>";
                html += "<span class='dp-inline-type'>" + sf.escapeHtml(node.typeDescr || node.type) + "</span>";
                var fullData = node.data || '';
                var isTruncated = fullData.length > 80;
                var displayData = isTruncated ? fullData.substring(0, 77) + '...' : fullData;
                if (isTruncated) {
                    html += "<span class='dp-inline-data dp-truncated' onclick='event.stopPropagation(); toggleDpData(this)' data-full='" + sf.escapeHtml(fullData).replace(/'/g, '&#39;') + "' data-short='" + sf.escapeHtml(displayData).replace(/'/g, '&#39;') + "'>" + sf.escapeHtml(displayData) + "</span>";
                } else {
                    html += "<span class='dp-inline-data'>" + sf.escapeHtml(displayData) + "</span>";
                }
                if (node.module && !node.isRoot) {
                    html += "<span class='dp-inline-module'>" + sf.escapeHtml(node.module) + "</span>";
                }
                html += "</div>";
                if (!isLast) html += "<span class='dp-inline-arrow'>\u2192</span>";
            }
            html += "</div>";
            container.innerHTML = html;
        }

        // Toggle discovery path data between truncated and full
        function toggleDpData(el) {
            var node = el.closest('.dp-inline-node');
            if (el.classList.contains('dp-expanded')) {
                el.textContent = el.getAttribute('data-short');
                el.classList.remove('dp-expanded');
                if (node) node.classList.remove('dp-node-expanded');
            } else {
                el.textContent = el.getAttribute('data-full');
                el.classList.add('dp-expanded');
                if (node) node.classList.add('dp-node-expanded');
            }
        }

        // Load all results (removes pagination limit)
        function loadAllResults() {
            var btn = document.getElementById('btn-load-all');
            var spinner = document.getElementById('load-all-spinner');
            if (btn) btn.disabled = true;
            if (spinner) spinner.style.display = 'inline';

            sf.fetchData('${docroot}/scaneventresults', {
                'id': paginatedInstanceId,
                'eventType': paginatedEventType
            }, function(allData) {
                // Re-trigger the full view with all data by calling the refresh function
                // which re-renders everything without pagination
                var loadAllBar = document.getElementById('load-all-bar');
                if (loadAllBar) loadAllBar.remove();

                // Build new tbody rows for the additional data (beyond first page)
                var tbody = $('#scansummary-content tbody');
                var existingCount = currentViewData ? currentViewData.length : 0;

                // Replace currentViewData with full dataset
                currentViewData = allData;

                // Clear and rebuild entire tbody with full data
                tbody.empty();
                for (var i = 0; i < allData.length; i++) {
                    var isImported = allData[i][13] != null;
                    var isKnownAsset = allData[i][14] && allData[i][14] > 0;
                    var rowClasses = ['data-event-row'];
                    if (isImported) rowClasses.push("imported-row");
                    if (isKnownAsset) rowClasses.push("known-asset-row");

                    var row = "<tr class='" + rowClasses.join(" ") + "' data-event-idx='" + i + "' data-event-hash='" + allData[i][7] + "' onclick='toggleDataDetail(" + i + ")'>";
                    row += "<td class='text-center' onclick='event.stopPropagation()'><input type='checkbox' id='cb_" + allData[i][7] + "'></td>";
                    row += "<td class='text-center validation-status'>";
                    var importedClass = isImported ? " status-imported-glow" : "";
                    if (allData[i][8] == "1" || allData[i][11] == 1) {
                        row += "<span class='status-fp" + importedClass + "'>FALSE POSITIVE</span>";
                    } else if (allData[i][8] == "2" || allData[i][12] == 1) {
                        row += "<span class='status-validated" + importedClass + "'>VALIDATED</span>";
                    } else {
                        row += "<span class='status-unvalidated" + importedClass + "'>UNVALIDATED</span>";
                    }
                    if (isKnownAsset) {
                        row += "<br><span class='status-known-asset'>KNOWN ASSET</span>";
                    }
                    row += "</td>";
                    row += "<td class='pre-expandable pre-collapsed'><pre class='table-border-bg-inherit'>" + sf.replace_sfurltag(allData[i][1]) + "</pre><div class='pre-expand-hint'></div></td>";
                    row += "<td class='pre-expandable pre-collapsed'><pre class='table-border-bg-inherit'>" + sf.replace_sfurltag(allData[i][2]) + "</pre><div class='pre-expand-hint'></div></td>";
                    row += "<td><pre class='table-border-bg-inherit'>" + allData[i][3] + "</pre></td>";
                    row += "<td class='text-center'>" + getDataTrackingBadge(allData[i][15], allData[i][7]) + "</td>";
                    row += "</tr>";
                    allData[i]._idx = i;
                    row += "<tr class='data-detail-row' style='display:none'><td colspan='6'><div class='finding-detail' style='display:none'>" + buildDataDetailHtml(allData[i]) + "</div></td></tr>";
                    tbody.append(row);
                }

                // Re-initialize tablesorter with new data
                $("#scansummary-content").trigger("update");
                initExpandableCells();
                updateDataTrackingFilterCounts();
                updateStatsBarCounts();

                // Re-apply any active filters
                if (clientFilterState.fp || clientFilterState.validated || clientFilterState.imported || dataTrackingFilterState.closed || dataTrackingFilterState.ticketed) {
                    applyClientSideFilters();
                }

                // Re-bind shift-click
                lastChecked = null;
                var chkboxes = $('input[id*=cb_]');
                chkboxes.click(function(e) {
                    if (!lastChecked) { lastChecked = this; return; }
                    if (e.shiftKey) {
                        var start = chkboxes.index(this);
                        var end = chkboxes.index(lastChecked);
                        chkboxes.slice(Math.min(start, end), Math.max(start, end) + 1).prop('checked', lastChecked.checked);
                    }
                    lastChecked = this;
                });

                // Check for pending scroll-to-hash after load-all
                if (_pendingScrollToHash) {
                    var targetRow = $('tr[data-event-hash="' + _pendingScrollToHash + '"]');
                    if (targetRow.length) {
                        setTimeout(function() { scrollAndHighlight(targetRow); }, 200);
                    }
                    _pendingScrollToHash = null;
                }
            });
        }

        // Toggle client-side filter
        function toggleClientFilter(type) {
            clientFilterState[type] = !clientFilterState[type];
            applyClientSideFilters();
            updateFilterButtonStates();
        }

        // Initialize expandable pre cells — mark overflowing cells and bind click
        function initExpandableCells() {
            $("#scansummary-content td.pre-expandable.pre-collapsed").each(function() {
                var pre = this.querySelector('pre');
                if (pre && pre.scrollHeight > 96) {
                    this.classList.add('pre-has-overflow');
                } else {
                    this.classList.remove('pre-collapsed');
                }
            });
            $("#scansummary-content").on('click', 'td.pre-expandable.pre-has-overflow', function(e) {
                if ($(e.target).is('a') || $(e.target).closest('a').length) return;
                e.stopPropagation();
                if (this.classList.contains('pre-collapsed')) {
                    this.classList.remove('pre-collapsed');
                    this.classList.add('pre-expanded');
                } else {
                    this.classList.remove('pre-expanded');
                    this.classList.add('pre-collapsed');
                }
            });
        }

        // Apply client-side filters by showing/hiding rows
        function applyClientSideFilters() {
            var visibleCount = 0;
            var hiddenCount = 0;

            $("#scansummary-content tbody tr").each(function() {
                var row = $(this);
                // Skip detail rows - they follow their parent row visibility
                if (row.hasClass('data-detail-row')) return;

                var statusSpan = row.find(".validation-status span");
                var isImported = row.hasClass("imported-row");

                var shouldHide = false;

                // Check FP filter
                if (clientFilterState.fp && statusSpan.hasClass('status-fp')) {
                    shouldHide = true;
                }

                // Check Validated filter
                if (clientFilterState.validated && statusSpan.hasClass('status-validated')) {
                    shouldHide = true;
                }

                // Check Imported filter
                if (clientFilterState.imported && isImported) {
                    shouldHide = true;
                }

                // Check data tracking filters
                var badge = row.find('.tracking-badge');
                if (badge.length > 0) {
                    var trackingVal = parseInt(badge.attr('data-tracking')) || 0;
                    if (dataTrackingFilterState.closed && trackingVal === 1) {
                        shouldHide = true;
                    }
                    if (dataTrackingFilterState.ticketed && trackingVal === 2) {
                        shouldHide = true;
                    }
                }

                if (shouldHide) {
                    row.hide();
                    row.next('.data-detail-row').hide();
                    hiddenCount++;
                } else {
                    row.show();
                    visibleCount++;
                }
            });

            // Update visible count in stats
            $(".stats-bar-left .stats-item:first-child .stats-value").text(visibleCount);

            return visibleCount;
        }

