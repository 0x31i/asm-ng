                    row.removeClass('finding-expanded');
                    $('tr.corr-group-child[data-group-id="' + groupId + '"]').removeClass('finding-expanded');
                    $('tr.corr-group-child-detail[data-group-id="' + groupId + '"]').find('.finding-detail').stop(true, true).hide();
                } else {
                    row.show();
                    // Don't auto-show children - they follow the group's expanded state
                }
            });

            // Filter single-item rows (not part of a multi-item group)
            $('#correlations-panel-table tbody tr.corr-row:not(.corr-group-child)').each(function() {
                var row = $(this);
                var badge = row.find('.badge').text().toLowerCase();
                var shouldHide = correlationsFilterState[badge] || false;
