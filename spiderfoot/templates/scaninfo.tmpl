        function searchResults(instanceId, query, typeName) {
            // Remove pre-existing search results and related elements
            $("#scansummary-content").remove();
            $(".search-results-info").remove();
            $("#search-chips-bar").remove();
            $("#search-scope-bar").remove();
            $("#load-all-bar").remove();
            $("#ai-correlation-section").remove();
            $("#ai-correlation-table-single").remove();
            $("#ai-correlation-table-cross").remove();
            $("#scanlogs-content").remove();
            $("#stats-bar").remove();
            $("#dedup-bar").remove();
            navTo("btn-search");
            pushViewState('btn-search', {searchQuery: query, searchType: typeName || 'ALL'});
            $("#modifyactions").hide();
            $("#loader").show();
            $("#btn-export").show();
            updateExportCurrentType('');
            $("#btn-download-logs").hide();
            $("#btn-refresh").show();
            $("#btn-search").show();
            $("#scanreminder").hide();
            refresh = function() { searchResults(instanceId, query, typeName); }
            sf.search(instanceId, query, typeName, function(response) {
                            // Handle both new dict format and legacy array format
                            var data, total, respQuery, operators, respScope, truncated, searchLimit;
                            if (response && response.results) {
                                data = response.results;
                                total = response.total;
                                respQuery = response.query || query;
                                operators = response.operators || {};
                                respScope = response.scope || searchScope;
                                truncated = response.truncated || false;
                                searchLimit = response.limit || 1000;
                            } else {
                                data = response || [];
                                total = data.length;
                                respQuery = query;
                                operators = {};
                                respScope = searchScope;
                                truncated = false;
                                searchLimit = 1000;
                            }

                            lastSearchType = typeName;
                            lastSearchQuery = query;

                            // Build scope toggle + action bar (always shown)
                            var scopeBar = "<div id='search-scope-bar' class='search-scope-bar'>";
                            scopeBar += "<div class='search-scope-toggle'>";
                            scopeBar += "<span class='search-scope-btn" + (searchScope === 'scan' ? ' active' : '') + "' data-scope='scan' onclick='setSearchScope(\"scan\")'>This Scan</span>";
                            scopeBar += "<span class='search-scope-btn" + (searchScope === 'all' ? ' active' : '') + "' data-scope='all' onclick='setSearchScope(\"all\")'>All Scans</span>";
                            scopeBar += "</div>";
                            scopeBar += "<div class='search-scope-actions'>";
                            scopeBar += "<button class='btn btn-default btn-xs search-save-btn' onclick='saveCurrentSearch()' title='Save this search'><i class='glyphicon glyphicon-star'></i> Save</button>";
                            scopeBar += "</div>";
                            scopeBar += "<div id='search-hint-badge' class='search-hint-badge'></div>";
                            scopeBar += "</div>";

                            if (data.length == 0) {
                                var errMsg = response.error ? "<br><br><span style='color:#dc2626;font-family:monospace;font-size:11px;'>&nbsp;&nbsp;Server error: " + $('<span>').text(response.error).html() + "</span>" : "";
                                var table = "<div id='scansummary-content'>&nbsp;&nbsp;No results found. Try broadening your search criteria or use plain text for substring matching." + errMsg + "</div>";
                            } else {
                                // Build operator display string
                                var opStr = '';
                                for (var k in operators) {
                                    if (operators.hasOwnProperty(k)) opStr += ' (' + k + ':' + operators[k] + ')';
                                }
                                var scopeLabel = respScope === 'all' ? 'all scans' : 'current scan';

                                // Search results info bar with export button
                                var infoBar = "<div class='search-results-info'>";
                                var totalLabel = truncated ? searchLimit + "+" : String(total);
                                infoBar += "<span class='search-results-text'>" + totalLabel + " results for &quot;" + sf.escapeHtml(respQuery) + "&quot;" + sf.escapeHtml(opStr) + " in " + scopeLabel;
                                if (truncated) {
                                    infoBar += " <span style='color:#f59e0b;font-size:11px;'>(showing first " + searchLimit + " — refine your search for more specific results)</span>";
                                }
                                infoBar += "</span>";
                                infoBar += "<button class='btn btn-default btn-xs search-export-btn' onclick='exportSearchCSV()' title='Export to CSV'><i class='glyphicon glyphicon-download-alt'></i> Export CSV</button>";
                                infoBar += "</div>";

                                // Build filter chips from result data
                                var typeFreq = {};
                                var riskFreq = {};
                                var riskLabels = {'0': 'INFO', '1': 'LOW', '2': 'MEDIUM', '3': 'HIGH'};
                                for (var ci = 0; ci < data.length; ci++) {
                                    var et = data[ci][8] || data[ci][9] || '';
                                    typeFreq[et] = (typeFreq[et] || 0) + 1;
                                    var rv = String(data[ci][6] || '0');
                                    var rl = riskLabels[rv] || rv;
                                    riskFreq[rl] = (riskFreq[rl] || 0) + 1;
                                }
                                var chipsBar = "<div id='search-chips-bar' class='search-chips-bar'>";
                                for (var etype in typeFreq) {
                                    if (typeFreq.hasOwnProperty(etype)) {
                                        chipsBar += "<span class='search-chip' data-filter-type='type' data-filter-value='" + sf.escapeHtml(etype) + "'>" + sf.escapeHtml(etype) + ": " + typeFreq[etype] + "</span>";
                                    }
                                }
                                for (var rname in riskFreq) {
                                    if (riskFreq.hasOwnProperty(rname)) {
                                        chipsBar += "<span class='search-chip' data-filter-type='risk' data-filter-value='" + rname + "'>risk:" + rname + ": " + riskFreq[rname] + "</span>";
                                    }
                                }
                                chipsBar += "<span class='search-chip search-chip-clear' style='display:none;'>Clear All</span>";
                                chipsBar += "</div>";

                                var table = "<table id='scansummary-content' class='table table-bordered table-striped small tablesorter'><thead><tr>";
                                if (typeName == null) {
                                    table += "<th class='sorter-false'>Data Element Type</th>";
                                }
                                table += "<th>Data Element</th><th>Source Data Element</th><th>Source Module</th><th>Identified</th>";
                                if (respScope !== 'all') {
                                    table += "<th class='sorter-false' style='width:30px;'></th>";
                                }
                                table += "</tr></thead><tbody>";
                                for (var i = 0; i < data.length; i++) {
                                    var rowRisk = String(data[i][6] || '0');
                                    var rowRiskLabel = riskLabels[rowRisk] || rowRisk;
                                    var rowType = data[i][8] || data[i][9] || '';
                                    table += "<tr class='search-result-row' data-row-type='" + sf.escapeHtml(rowType) + "' data-row-risk='" + rowRiskLabel + "' data-row-idx='" + i + "'>";
                                    if (typeName == null) {
                                        table += "<td><pre class='table-border-bg-inherit'>" + sf.escapeHtml(rowType) + "</pre></td>";
                                    }
                                    table += "<td class='pre-expandable pre-collapsed'><pre class='table-border-bg-inherit'>";
                                    table += highlightTerm(sf.replace_sfurltag(data[i][1]), respQuery);
                                    table += "</pre><div class='pre-expand-hint'></div></td>";
                                    table += "<td class='pre-expandable pre-collapsed'><pre class='table-border-bg-inherit'>";
                                    table += highlightTerm(sf.replace_sfurltag(data[i][2]), respQuery);
                                    table += "</pre><div class='pre-expand-hint'></div></td>";
                                    table += "<td><pre class='table-border-bg-inherit'>" + data[i][3];
                                    table += "</pre></td><td><pre class='table-border-bg-inherit'>" + data[i][0];
                                    table += "</pre></td>";
                                    if (respScope !== 'all') {
                                        var navEventType = data[i][10] || data[i][9] || '';
                                        var navEventLabel = data[i][8] || data[i][9] || '';
                                        var navHash = data[i][7] || '';
                                        table += "<td class='search-goto-cell' title='Go to this row in DATA view' onclick='event.stopPropagation(); navigateToDataRow(\"" + _instanceId + "\", \"" + sf.escapeHtml(navEventType) + "\", \"" + sf.escapeHtml(navEventLabel) + "\", \"" + sf.escapeHtml(navHash) + "\")'>";
                                        table += "<i class='glyphicon glyphicon-arrow-right'></i></td>";
                                    }
                                    table += "</tr>";
                                    // Hidden detail row
                                    var conf = data[i][4] || ''; var vis = data[i][5] || ''; var risk = data[i][6] || '';
                                    var hash = data[i][7] || ''; var fp = data[i][11] || 0; var parentFp = data[i][12] || 0;
                                    var mod = data[i][3] || ''; var fullData = data[i][1] || '';
                                    table += "<tr class='search-detail-row' style='display:none;'><td colspan='99'>";
                                    table += "<div class='search-detail-grid'>";
                                    table += "<div><strong>Hash:</strong> <span style='font-size:10px;'>" + sf.escapeHtml(String(hash)) + "</span></div>";
                                    table += "<div><strong>Confidence:</strong> " + conf + "</div>";
                                    table += "<div><strong>Visibility:</strong> " + vis + "</div>";
                                    table += "<div><strong>Risk:</strong> " + risk + "</div>";
                                    table += "<div><strong>False Positive:</strong> " + (fp == 1 ? 'Yes' : (fp == 2 ? 'Verified' : 'No')) + "</div>";
                                    table += "<div><strong>Source Module:</strong> " + sf.escapeHtml(String(mod)) + "</div>";
                                    table += "</div>";
                                    table += "<div style='padding:8px 16px;'><strong>Full Data:</strong><pre style='white-space:pre-wrap;word-break:break-all;max-height:200px;overflow:auto;'>" + sf.escapeHtml(String(fullData)) + "</pre></div>";
                                    table += "</td></tr>";
                                }
                                table += "</tbody></table>"
                                table = infoBar + chipsBar + table;
                            }
                            $("#loader").fadeOut(500);
                            $("#mainbody").append(scopeBar + table);
                            $("#scansummary-content").tablesorter();
                            initExpandableCells();

                            // Filter chip click handlers
                            $(document).off('click.searchChip').on('click.searchChip', '.search-chip', function() {
                                if ($(this).hasClass('search-chip-clear')) {
                                    // Clear all filters
                                    $('.search-chip').removeClass('active');
                                    $('.search-chip-clear').hide();
                                    $('.search-result-row').removeClass('search-row-hidden').show();
                                    $('.search-detail-row').hide();
                                    return;
                                }
                                $(this).toggleClass('active');
                                var activeFilters = [];
                                $('.search-chip.active').each(function() {
                                    activeFilters.push({ type: $(this).data('filter-type'), value: $(this).data('filter-value') });
                                });
                                if (activeFilters.length === 0) {
                                    $('.search-result-row').removeClass('search-row-hidden').show();
                                    $('.search-detail-row').hide();
                                    $('.search-chip-clear').hide();
                                } else {
                                    $('.search-chip-clear').show();
                                    $('.search-result-row').each(function() {
                                        var row = $(this);
                                        var match = false;
                                        for (var f = 0; f < activeFilters.length; f++) {
                                            if (activeFilters[f].type === 'type' && row.data('row-type') === activeFilters[f].value) match = true;
                                            if (activeFilters[f].type === 'risk' && row.data('row-risk') === activeFilters[f].value) match = true;
                                        }
                                        if (match) {
                                            row.removeClass('search-row-hidden').show();
                                        } else {
                                            row.addClass('search-row-hidden').hide();
                                            row.next('.search-detail-row').hide();
                                        }
                                    });
                                }
                            });

                            // Expandable detail row click handler
                            $(document).off('click.searchDetail').on('click.searchDetail', '.search-result-row', function(e) {
                                if ($(e.target).closest('.pre-expandable, a, button, input').length) return;
                                $(this).next('.search-detail-row').toggle();
                            });
            }, searchScope);
        }

