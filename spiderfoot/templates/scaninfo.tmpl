            <ul id="export-dropdown-menu" class="dropdown-menu">
              <li id="export-current-type-section" style="display:none"></li>
              <li class="dropdown-header" style="color: #16a34a; font-weight: bold; font-size: 13px;">
                <i class="glyphicon glyphicon-file" style="margin-right: 4px;"></i> Full Report
              </li>
              <li>
                <a class="link export-fullreport-link" onClick='exportReportData("${id}")'>
