             aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="width: 0%; border-radius: 4px;">
        </div>
      </div>
      <small id="scan-progress-pct" style="white-space: nowrap; font-weight: bold; min-width: 30px; font-family: var(--font-mono, monospace); font-size: 12px;"></small>
