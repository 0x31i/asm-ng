        function loadSnapshotExclusionList(instanceId) {
            var container = document.getElementById('snapshot-exclusion-list');
            if (!container) return;

            sf.fetchData('${docroot}/scantrend', {id: instanceId}, function(trendData) {
                if (!trendData || !trendData.snapshots || trendData.snapshots.length === 0) {
                    container.innerHTML = "<p class='text-muted' style='padding:10px;'>No snapshots available for this target.</p>";
                    return;
                }

                var snaps = trendData.snapshots;
                var html = "<table class='table table-bordered table-striped' style='font-family:var(--font-mono);font-size:12px;margin-bottom:0;'>";
                html += "<thead><tr><th style='width:40px;'>Include</th><th>Scan Name</th><th>Date</th><th>Grade</th><th>Score</th><th style='width:100px;'>Scan Status</th><th style='width:100px;'>Trend</th></tr></thead><tbody>";

                snaps.forEach(function(s) {
                    var isExcluded = s.excluded ? true : false;
                    var isCurrent = (s.scan_id === instanceId);
                    var dt = new Date(s.date);
                    var dateStr = dt.toLocaleDateString() + ' ' + dt.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'});
                    var gc = gradeGlowColor(s.overall_grade);
                    var rowStyle = isExcluded ? 'opacity:0.5;' : '';
                    var currentBadge = isCurrent ? " <span class='label label-info' style='font-size:9px;'>CURRENT</span>" : '';
                    var scanName = s.scan_name || s.scan_id.substring(0, 8);
                    var scanStatus = s.scan_status || '';
                    var statusColor = scanStatus === 'FINISHED' ? '#22c55e' : (scanStatus === 'ABORTED' ? '#f59e0b' : '#ef4444');

                    html += "<tr style='" + rowStyle + "'>";
                    html += "<td style='text-align:center;vertical-align:middle;'>";
                    html += "<input type='checkbox' class='snapshot-exclude-cb' data-scan-id='" + s.scan_id + "' " + (isExcluded ? '' : 'checked') + " style='cursor:pointer;width:16px;height:16px;'>";
                    html += "</td>";
                    html += "<td>" + scanName + currentBadge + "</td>";
                    html += "<td>" + dateStr + "</td>";
                    html += "<td style='text-align:center;'><span style='display:inline-block;width:28px;height:22px;line-height:22px;border-radius:3px;font-size:11px;font-weight:700;color:" + gc.text + ";background:var(--bg-tertiary);border:1px solid " + gc.text + ";'>" + s.overall_grade + "</span></td>";
                    html += "<td style='text-align:center;'>" + s.overall_score.toFixed(1) + "</td>";
                    html += "<td style='text-align:center;'><span style='color:" + statusColor + ";'>" + scanStatus + "</span></td>";
                    html += "<td style='text-align:center;'>" + (isExcluded ? "<span class='text-muted'>Excluded</span>" : "<span style='color:#22c55e;'>Included</span>") + "</td>";
                    html += "</tr>";
                });

                html += "</tbody></table>";
                container.innerHTML = html;

                // Wire up checkbox toggle handlers
                container.querySelectorAll('.snapshot-exclude-cb').forEach(function(cb) {
                    cb.addEventListener('change', function() {
                        var scanId = this.getAttribute('data-scan-id');
                        var newExcluded = this.checked ? 0 : 1;
                        var checkbox = this;
                        var wasChecked = !this.checked;
                        checkbox.disabled = true;
                        $.ajax({
                            type: 'POST',
                            url: '${docroot}/snapshotexclude',
                            data: {id: scanId, excluded: String(newExcluded)},
                            dataType: 'json',
                            timeout: 15000
                        }).done(function(resp) {
                            checkbox.disabled = false;
                            if (resp && resp.success) {
                                loadSnapshotExclusionList(instanceId);
                            } else {
                                checkbox.checked = wasChecked;
                                alertify.error('Failed to update: ' + (resp && resp.message ? resp.message : 'unknown error'));
                            }
                        }).fail(function(xhr, status, err) {
                            checkbox.disabled = false;
                            checkbox.checked = wasChecked;
                            alertify.error('Request failed: ' + (err || status));
                        });
                    });
                });
            }, function() {
                container.innerHTML = "<p class='text-muted' style='padding:10px;'>Failed to load snapshot data.</p>";
            });
        }

        function overrideScanStatus(instanceId) {
            var newStatus = $('#status-override-select').val();
            if (!confirm('Are you sure you want to override the scan status to ' + newStatus + '?')) {
                return;
            }
            $('#status-override-result').html('<img src="${docroot}/static/img/loader.gif"> Updating...');
            sf.fetchData('${docroot}/scanstatusoverride', {'id': instanceId, 'status': newStatus}, function(data) {
                if (data.success) {
                    $('#status-override-result').html(
                        '<div class="alert alert-success">' +
                        '<i class="glyphicon glyphicon-ok"></i> Status changed from <b>' +
                        data.old_status + '</b> to <b>' + data.new_status + '</b></div>'
                    );
                    $('#scanstatusbadge').html(data.new_status);
                    $('#scanstatusbadge').removeClass('alert-info alert-warning alert-danger').addClass(
                        data.new_status === 'FINISHED' ? 'alert-info' :
                        data.new_status === 'ABORTED' ? 'alert-warning' : 'alert-danger'
                    );
                } else {
                    $('#status-override-result').html(
                        '<div class="alert alert-danger">' +
                        '<i class="glyphicon glyphicon-exclamation-sign"></i> ' +
                        (data.error ? data.error.message : 'Unknown error') + '</div>'
                    );
                }
            });
        }

        // Toggle collapsible manage sections
        function toggleManageSection(header) {
            var $header = $(header);
            var $body = $header.next('.manage-section-body');
            var $chevron = $header.find('.section-chevron');

            if ($header.hasClass('collapsed')) {
                $header.removeClass('collapsed');
                $chevron.removeClass('glyphicon-chevron-right').addClass('glyphicon-chevron-down');
                $body.slideDown(200);
            } else {
                $header.addClass('collapsed');
                $chevron.removeClass('glyphicon-chevron-down').addClass('glyphicon-chevron-right');
                $body.slideUp(200);
            }
        }

        // Toggle scan log section - fetches logs on first expand
        var scanLogLoaded = false;
        function toggleScanLog(header, instanceId) {
            var $header = $(header);
            var $body = $('#scan-log-body');
            var $chevron = $header.find('.section-chevron');

            if ($header.hasClass('collapsed')) {
                $header.removeClass('collapsed');
                $chevron.removeClass('glyphicon-chevron-right').addClass('glyphicon-chevron-down');
                $body.slideDown(200);

                // Fetch logs on first expand
                if (!scanLogLoaded) {
                    scanLogLoaded = true;
                    $('#scan-log-loader').show();
                    sf.fetchData('${docroot}/scanlog', {'id': instanceId}, function(data) {
                        var logTable = "<table class='table table-bordered table-striped table-condensed small tablesorter' style='table-layout: fixed'>";
                        logTable += "<thead><tr><th>Time</th><th>Component</th><th>Type</th><th>Event</th></tr></thead><tbody>";
                        for (var i = 0; i < data.length; i++) {
                            if (data[i][2] == "ERROR") {
                                logTable += "<tr class='danger'>";
                            } else {
                                logTable += "<tr>";
                            }
                            logTable += "<td>" + data[i][0] + "</td>";
                            logTable += "<td>" + data[i][1] + "</td>";
                            logTable += "<td>" + data[i][2] + "</td>";
                            logTable += "<td>" + data[i][3] + "</td>";
                            logTable += "</tr>";
                        }
                        logTable += "</tbody></table>";
                        $('#scan-log-loader').hide();
                        $('#scan-log-content').html(logTable);
                        $('#scan-log-content .tablesorter').tablesorter({widgets: ["filter"], widgetOptions : { filter_searchDelay : 300, filter_hideFilters : false }});
                    });
                }
            } else {
                $header.addClass('collapsed');
                $chevron.removeClass('glyphicon-chevron-down').addClass('glyphicon-chevron-right');
                $body.slideUp(200);
            }
        }

        // Always default to Summary view
        // Use replaceState for initial load (don't push a new history entry)
        _skipHistoryPush = true;
        scanSummaryView("${id}");
        _skipHistoryPush = false;
        history.replaceState(buildHistoryState(), '', window.location.href);

        var refreshSummaryInterval;

        refreshSummary = function() {
            var status = document.getElementById("scanstatusbadge").innerHTML;

            if (status == "ERROR-FAILED" || status == "FINISHED" || status == "ABORTED") {
                sf.log("Scan is " + status);
                clearInterval(refreshSummaryInterval);
                return;
            }

            sf.log("Scan is " + status + ". Refreshing scan summary ...");

            for (var i = 0; i < dataloaders.length; i++) {
                if (!loadersrunning) {
                    loadersrunning = true;
                    dataloaders[i]();
                    loadersrunning = false;
                }
            }
        }

        // Poll summary every 15s (was 5s) to reduce server load during active scans.
        // The progress bar still updates more frequently below.
        refreshSummaryInterval = setInterval(refreshSummary, 15000);

        // Scan progress bar
        var progressInterval;

        function updateScanProgress() {
            sf.fetchData('${docroot}/scanmonitor', {'id': '${id}'}, function(resp) {
                var container = $('#scan-progress-container');
                var bar = $('#scan-progress-bar');
                var data = resp.progress || {};
                var status = data.status;

                if (status == 'FINISHED' || status == 'ABORTED' || status == 'ERROR-FAILED') {
                    bar.css('width', '100%').attr('aria-valuenow', 100);
                    bar.removeClass('active progress-bar-striped');
                    if (status == 'FINISHED') {
                        bar.addClass('progress-bar-success');
                    } else if (status == 'ABORTED') {
                        bar.addClass('progress-bar-warning');
                    } else {
                        bar.addClass('progress-bar-danger');
                    }
                    $('#scan-progress-pct').text('Done');
                    // Show final state in dashboard
                    sfMonitor.renderStatCards('#scaninfo-monitor-stats', data);
                    sfMonitor.renderModulePipeline('#scaninfo-col-modules', resp.modules || {});
                    sfMonitor.renderEventTypeGrid('#scaninfo-col-events', resp.eventTypes || []);
                    sfMonitor.renderRecentDiscoveries('#scaninfo-col-recent', resp.recentEvents || []);
                    clearInterval(progressInterval);
                    setTimeout(function() { container.fadeOut(1000); }, 5000);
                    return;
                }

                if (status == 'CREATED' || status == 'INITIALIZING' || status == 'STARTING' || status == 'STARTED' || status == 'RUNNING') {
                    container.show();
                    var pct = data.progressPercent || 0;
                    bar.css('width', pct + '%').attr('aria-valuenow', pct);
                    $('#scan-progress-pct').text('~' + pct + '%');

                    // Stat cards + 3-column dashboard via shared renderers
                    sfMonitor.renderStatCards('#scaninfo-monitor-stats', data);
                    sfMonitor.renderModulePipeline('#scaninfo-col-modules', resp.modules || {});
                    sfMonitor.renderEventTypeGrid('#scaninfo-col-events', resp.eventTypes || []);
                    sfMonitor.renderRecentDiscoveries('#scaninfo-col-recent', resp.recentEvents || []);
                } else {
                    container.hide();
                }
            });
        }

        // Start progress polling if scan is active
        if ("${status}" == "CREATED" || "${status}" == "RUNNING" || "${status}" == "STARTING" || "${status}" == "STARTED" || "${status}" == "INITIALIZING") {
            updateScanProgress();
            progressInterval = setInterval(updateScanProgress, 5000);
        }

        // Check if this scan is the latest for its target and handle auto-import
        var scanLatestInfo = null;
        var filterImported = false;  // Default: show imported entries

        function checkScanLatest() {
            sf.fetchData('${docroot}/scanislatest', {'id': '${id}'}, function(data) {
                scanLatestInfo = data;

                // Show LATEST badge if this is the latest scan
                if (data.isLatest) {
                    $('#latestbadge').show();

                    // Show SYNC/RESYNC badge only for latest scans with multiple scans for target
                    if (data.scanCount > 1) {
                        if (data.importedCount > 0) {
                            // Already synced - show RESYNC
                            $('#syncbadge').text('RESYNC').attr('title', 'Click to delete and re-import entries from previous scans').show();
                        } else {
                            // Not yet synced - show SYNC
                            $('#syncbadge').text('SYNC').attr('title', 'Click to import entries from previous scans').show();
                        }
                    }
                }

                // Show imported count badge if there are imported entries
                if (data.importedCount > 0) {
                    $('#importedbadge').text('+' + data.importedCount + ' IMPORTED').show();
                }

                // Log import status
                if (data.importStatus && data.importStatus.indexOf('Imported') === 0) {
                    alertify.success(data.importStatus);
                }
            });
        }

        // Resync scan entries - delete imported and re-import fresh
        function resyncScanEntries() {
            var currentText = $('#syncbadge').text();
            var actionText = currentText === 'RESYNC' ? 'delete existing imports and re-import' : 'import';

            alertify.confirm("Are you sure you want to " + actionText + " entries from previous scans?",
            function() {
                // User confirmed
                $('#syncbadge').text('SYNCING...').css('background-color', '#f59e0b');
                $('#loader').show();

                sf.fetchData('${docroot}/resyncscanentries', {'id': '${id}'}, function(data) {
                    $('#loader').hide();

                    if (data.success) {
                        alertify.success(data.message);

                        // Update badges
                        if (data.imported > 0) {
                            $('#syncbadge').text('RESYNC').css('background-color', '#10b981');
                            $('#importedbadge').text('+' + data.imported + ' IMPORTED').show();
                        } else {
                            $('#syncbadge').text('SYNC').css('background-color', '#10b981');
                            $('#importedbadge').hide();
                        }

                        // Refresh the current view to show updated data
                        if (typeof refresh === 'function') {
                            refresh();
                        }
                    } else {
                        alertify.error('Sync failed: ' + data.message);
                        $('#syncbadge').text(currentText).css('background-color', '#10b981');
                    }
                });
            },
            function() {
                // User cancelled
            }).set({title: currentText === 'RESYNC' ? "Re-sync entries?" : "Sync entries?"});
        }

        // Check on page load
        checkScanLatest();

    </script>
<!-- Correlation Progress Modal -->
<div id="correlation-progress-modal" class="assets-modal-overlay" style="display:none;">
  <div class="assets-modal" style="width: 520px;">
    <div class="assets-modal-header">
      <span class="assets-modal-title">PROCESSING - PLEASE WAIT</span>
    </div>
    <div class="assets-modal-body" style="text-align: center; padding: 30px 20px;">
      <i class="glyphicon glyphicon-flash" style="font-size: 28px; color: #38bdf8; margin-bottom: 15px; display: block;"></i>
      <p id="correlation-progress-step" style="font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 20px;">Initializing...</p>
      <div class="progress" style="height: 22px; margin-bottom: 10px; border-radius: 4px;">
        <div id="correlation-progress-bar" class="progress-bar progress-bar-striped active" role="progressbar"
             style="width: 0%; min-width: 2em; transition: width 0.5s ease; font-weight: 600; font-size: 11px; line-height: 22px;">
          0%
        </div>
      </div>
      <p style="font-size: 11px; color: #94a3b8; margin: 0;">Correlation analysis is running. This may take a few minutes for large scans.</p>
    </div>
  </div>
</div>
<iframe class="hidden" id='exportframe'></iframe>
