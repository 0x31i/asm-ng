        // Expand/collapse a correlation group to show individual findings
        function toggleCorrelationGroup(instanceId, groupId) {
            var groupRow = $('tr.corr-group-row[data-group-id="' + groupId + '"]');
            var childRows = $('tr.corr-group-child[data-group-id="' + groupId + '"]');
            var childDetailRows = $('tr.corr-group-child-detail[data-group-id="' + groupId + '"]');

            if (groupRow.hasClass('finding-expanded')) {
                // Collapse group
                groupRow.removeClass('finding-expanded');
                childRows.slideUp(150);
                childDetailRows.hide();
                // Reset any expanded individual correlations within the group
                childRows.removeClass('finding-expanded');
                childDetailRows.find('.finding-detail').stop(true, true).hide();
            } else {
                // Expand group to show individual findings
                groupRow.addClass('finding-expanded');
                childRows.slideDown(150);
                // Don't show detail rows - they appear only when individual correlations are expanded
            }
        }

        // Expand the correlation list to show the events associated
        function toggleCorrelation(instanceId, correlationId) {
            var row = $('tr[data-corr-id="' + correlationId + '"]');
            var detailTr = $('#corrwell_tr_' + correlationId);
            var detail = $('#corr-detail-content-' + correlationId);
            var eventsContainer = $('#corrwell_td_' + correlationId);

            if (row.hasClass('finding-expanded')) {
                row.removeClass('finding-expanded');
                detail.slideUp(150, function() {
                    // For grouped children, hide the detail <tr> after animation completes
                    if (detailTr.hasClass('corr-group-child-detail')) {
                        detailTr.hide();
                    }
                });
                return;
            }

            row.addClass('finding-expanded');
            // For grouped children, show the detail <tr> before animating the inner content
            if (detailTr.hasClass('corr-group-child-detail')) {
                detailTr.show();
            }
            detail.slideDown(150);

            // Only fetch events if not already loaded
            if (eventsContainer.data('loaded')) return;

            eventsContainer.html("<div style='padding: 10px; text-align: center;'><i class='glyphicon glyphicon-refresh spinning'></i> Loading events...</div>");

            $.ajax({
                type: "POST",
                url: '${docroot}/scaneventresults',
                data: { 'id': instanceId, 'correlationId': correlationId },
                dataType: "json",
                timeout: 30000,
                success: function(data) {
                    if (!data || data.length === 0) {
                        eventsContainer.html("<div style='padding: 10px; color: var(--text-muted); font-family: var(--font-mono); font-size: 11px;'><i class='glyphicon glyphicon-info-sign'></i> No event data available for this correlation. Try re-running the correlation engine.</div>");
                        eventsContainer.data('loaded', true);
                        return;
                    }
                    var table = "<table class='table corr-events-table small'>";
                    table += "<thead><tr>";
                    table += "<th>Type</th>";
                    table += "<th>Data Element</th>";
                    table += "<th>Source Data Element</th>";
                    table += "<th>Source Module</th>";
                    table += "<th>Identified</th>";
                    table += "</tr></thead><tbody>";

                    for (var i = 0; i < data.length; i++) {
                        var evtType = data[i][10] || '';
                        table += "<tr>";
                        // Type column with link to Data
                        if (evtType) {
                            table += "<td><a class='finding-type-link' onclick='dataEventData(\"" + instanceId + "\", \"" + evtType.replace(/"/g, '&quot;') + "\", \"" + evtType.replace(/"/g, '&quot;') + "\", \"full\");' title='View " + evtType + " data'>" + evtType + "</a></td>";
                        } else {
                            table += "<td></td>";
                        }
                        table += "<td><pre class='table-border-bg-inherit'>";
                        table += sf.replace_sfurltag(data[i][1]);
                        table += "</pre></td><td><pre class='table-border-bg-inherit'>";
                        table += sf.replace_sfurltag(data[i][2]);
                        table += "</pre></td><td><pre class='table-border-bg-inherit'>" + data[i][3];
                        table += "</pre></td><td><pre class='table-border-bg-inherit'>" + data[i][0];
                        table += "</pre></td>";
                        table += "</tr>";
                    }
                    table += "</tbody></table>";
                    eventsContainer.html(table);
                    eventsContainer.data('loaded', true);
                },
                error: function(xhr, status, err) {
                    eventsContainer.html("<div style='padding: 10px; color: #dc3545; font-family: var(--font-mono); font-size: 11px;'><i class='glyphicon glyphicon-exclamation-sign'></i> Failed to load event data. Click to retry.</div>");
                    eventsContainer.off('click.retry').on('click.retry', function() {
                        eventsContainer.data('loaded', false);
                        eventsContainer.html('');
                        toggleCorrelation(instanceId, correlationId);
                    });
                }
            });
        }

        // Legacy dataCorrelations - redirect to Findings page with Correlations tab
        function dataCorrelations(instanceId) {
            viewFindings(instanceId);
            // Switch to correlations tab after a short delay to let the DOM render
            setTimeout(function() {
                switchFindingsTab('correlations', instanceId);
