            h += "</div>"; // end padding wrapper

            // Debug: show raw grade data for DNS Health types
            var debugTypes = ['DNS_SPF', 'DNS_TEXT'];
            var debugInfo = [];
            for (var ci2 = 0; ci2 < catOrder.length; ci2++) {
