<%include file="HEADER.tmpl"/>

<style>
/* TASKS page layout */
.tasks-container { display: flex; gap: 20px; min-height: 600px; }
.tasks-main { flex: 1; min-width: 0; }
.tasks-sidebar { width: 280px; flex-shrink: 0; }

/* Summary cards — sharp, glowing stat cards */
.tasks-summary { display: flex; gap: 8px; margin-bottom: 20px; }
.tasks-card {
  background: var(--bg-secondary, #151515);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0;
  padding: 14px 20px;
  text-align: center;
  flex: 1;
}
.tasks-card .card-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 32px;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
  line-height: 1.2;
}
.tasks-card .card-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  text-transform: uppercase;
  color: var(--text-muted, #6b7280);
  letter-spacing: 1.5px;
  margin-top: 2px;
}
.tasks-card.open .card-count { color: #3b82f6; text-shadow: 0 0 20px rgba(59, 130, 246, 0.5); }
.tasks-card.inprogress .card-count { color: #f97316; text-shadow: 0 0 20px rgba(249, 115, 22, 0.5); }
.tasks-card.done .card-count { color: #22c55e; text-shadow: 0 0 20px rgba(34, 197, 94, 0.5); }

/* Target selector — sharp, monospace */
.tasks-target-bar {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  padding: 12px 16px;
  background: var(--bg-secondary, #151515);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0;
}
.tasks-target-bar label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #ffffff;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  white-space: nowrap;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
}
.tasks-target-bar select {
  flex: 1;
  padding: 8px 12px;
  border-radius: 0;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: var(--bg-primary, #0c0c0c);
  color: #ffffff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  letter-spacing: 0.5px;
}
.tasks-target-bar select:focus {
  border-color: #22c55e;
  box-shadow: 0 0 10px rgba(34, 197, 94, 0.5);
  outline: none;
}

/* Toolbar — sharp buttons with glow */
.tasks-toolbar {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  padding: 10px 14px;
  background: linear-gradient(180deg, #0a0a0a 0%, #000000 100%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0;
  flex-wrap: wrap;
}
.tasks-toolbar label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: #ffffff;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
  cursor: pointer;
}
.tasks-toolbar .btn-task {
  padding: 6px 14px;
  border: none;
  border-radius: 0;
  background: transparent;
  color: #ffffff;
  cursor: pointer;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
  border-bottom: 2px solid transparent;
}
.tasks-toolbar .btn-task:hover {
  transform: translateY(-1px);
}
.tasks-toolbar .btn-task.btn-assign-action {
  background: linear-gradient(135deg, #22d3ee 0%, #06b6d4 100%);
  box-shadow: 0 0 12px rgba(34, 211, 238, 0.4);
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
}
.tasks-toolbar .btn-task.btn-assign-action:hover {
  box-shadow: 0 0 20px rgba(34, 211, 238, 0.6), 0 4px 15px rgba(0, 0, 0, 0.3);
}
.tasks-toolbar .btn-task.btn-rank {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
  box-shadow: 0 0 12px rgba(139, 92, 246, 0.4);
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
}
.tasks-toolbar .btn-task.btn-rank:hover {
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.6), 0 4px 15px rgba(0, 0, 0, 0.3);
}
.tasks-toolbar .btn-task.btn-auto {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  box-shadow: 0 0 12px rgba(34, 197, 94, 0.4);
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
}
.tasks-toolbar .btn-task.btn-auto:hover {
  box-shadow: 0 0 20px rgba(34, 197, 94, 0.6), 0 4px 15px rgba(0, 0, 0, 0.3);
}
.tasks-toolbar .btn-task.btn-reset {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  box-shadow: 0 0 12px rgba(249, 115, 22, 0.4);
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
}
.tasks-toolbar .btn-task.btn-reset:hover {
  box-shadow: 0 0 20px rgba(249, 115, 22, 0.6), 0 4px 15px rgba(0, 0, 0, 0.3);
}
.toolbar-assign-select {
  padding: 6px 10px;
  border-radius: 0;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: var(--bg-primary, #0c0c0c);
  color: #ffffff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
}
.toolbar-assign-select:focus {
  border-color: #22c55e;
  box-shadow: 0 0 8px rgba(34, 197, 94, 0.5);
  outline: none;
}
.toolbar-sep { width: 1px; height: 24px; background: rgba(255, 255, 255, 0.1); margin: 0 6px; }

/* Category group */
.cat-group { margin-bottom: 12px; }
.cat-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  background: var(--bg-primary, #0c0c0c);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 0;
  cursor: pointer;
  transition: background 0.15s ease;
}
.cat-header:hover { background: var(--bg-tertiary, #1e1e1e); }
.cat-color { width: 8px; height: 8px; border-radius: 0; flex-shrink: 0; box-shadow: 0 0 6px currentColor; }
.cat-name {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
}
.cat-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--text-muted, #6b7280);
  margin-left: auto;
  letter-spacing: 0.5px;
}

/* Type rows */
.type-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 7px 12px 7px 30px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  transition: background 0.15s ease;
}
.type-row:hover { background: rgba(255, 255, 255, 0.03); }
.type-row .type-cb { width: 13px; height: 13px; accent-color: #22c55e; cursor: pointer; }
.type-row .type-name {
  flex: 1;
  color: #ffffff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.3px;
}
.type-row .type-findings {
  font-family: 'JetBrains Mono', monospace;
  color: var(--text-muted, #6b7280);
  font-size: 10px;
  min-width: 45px;
  text-align: right;
  letter-spacing: 0.5px;
}
.type-row .assign-chip {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  border-radius: 0;
  background: rgba(139, 92, 246, 0.1);
  color: #a78bfa;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 600;
  cursor: pointer;
  border: 1px solid rgba(139, 92, 246, 0.3);
  min-width: 70px;
  justify-content: center;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all 0.15s ease;
}
.type-row .assign-chip.unassigned {
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-muted, #6b7280);
  border-color: rgba(255, 255, 255, 0.1);
}
.type-row .assign-chip:hover {
  background: rgba(139, 92, 246, 0.2);
  box-shadow: 0 0 8px rgba(139, 92, 246, 0.3);
}
.type-row .assign-dropdown {
  padding: 3px 8px;
  border-radius: 0;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: var(--bg-primary, #0c0c0c);
  color: #ffffff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  display: none;
}
.type-row .assign-dropdown:focus {
  border-color: #22c55e;
  box-shadow: 0 0 8px rgba(34, 197, 94, 0.5);
  outline: none;
}
.type-row .assign-dropdown.visible { display: inline-block; }
.type-row .status-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.status-badge.s-open { background: rgba(59, 130, 246, 0.15); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.3); }
.status-badge.s-in_progress { background: rgba(249, 115, 22, 0.15); color: #f97316; border: 1px solid rgba(249, 115, 22, 0.3); }
.status-badge.s-done { background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }

/* Analyst sidebar */
.analyst-card {
  background: var(--bg-secondary, #151515);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0;
  padding: 12px 14px;
  margin-bottom: 6px;
  transition: border-color 0.15s ease;
}
.analyst-card:hover { border-color: rgba(255, 255, 255, 0.2); }
.analyst-card .analyst-name {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
}
.analyst-card .analyst-stats {
  display: flex;
  gap: 14px;
  margin-top: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--text-muted, #6b7280);
  letter-spacing: 0.5px;
}
.analyst-card .analyst-stat { display: flex; align-items: center; gap: 4px; }
.analyst-card .stat-dot { width: 6px; height: 6px; border-radius: 0; }
.analyst-card .stat-dot.open { background: #3b82f6; box-shadow: 0 0 6px rgba(59, 130, 246, 0.5); }
.analyst-card .stat-dot.inprogress { background: #f97316; box-shadow: 0 0 6px rgba(249, 115, 22, 0.5); }
.analyst-card .stat-dot.done { background: #22c55e; box-shadow: 0 0 6px rgba(34, 197, 94, 0.5); }
.sidebar-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #ffffff;
  font-weight: 700;
  margin-bottom: 10px;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
}
.sidebar-summary {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text-muted, #6b7280);
  margin-bottom: 12px;
  padding: 10px 12px;
  background: var(--bg-primary, #0c0c0c);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 0;
  letter-spacing: 0.5px;
}

/* Analyst view table */
.analyst-tasks-table { width: 100%; border-collapse: collapse; }
.analyst-tasks-table th {
  background: rgba(0, 0, 0, 0.85);
  color: #ffffff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 10px 14px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  text-align: left;
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
}
.analyst-tasks-table td {
  padding: 10px 14px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  color: #ffffff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
}
.analyst-tasks-table tr:hover { background: rgba(255, 255, 255, 0.03); }
.task-target {
  color: #22c55e;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-shadow: 0 0 8px rgba(34, 197, 94, 0.3);
}
.task-status-btn {
  padding: 4px 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0;
  background: transparent;
  color: var(--text-muted, #6b7280);
  cursor: pointer;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-right: 4px;
  transition: all 0.15s ease;
}
.task-status-btn:hover { background: rgba(255, 255, 255, 0.05); color: #ffffff; }
.task-status-btn.active-open { border-color: #3b82f6; color: #3b82f6; box-shadow: 0 0 8px rgba(59, 130, 246, 0.3); }
.task-status-btn.active-inprogress { border-color: #f97316; color: #f97316; box-shadow: 0 0 8px rgba(249, 115, 22, 0.3); }
.task-status-btn.active-done { border-color: #22c55e; color: #22c55e; box-shadow: 0 0 8px rgba(34, 197, 94, 0.3); }

/* Rank overlay — sharp panel with glow */
.rank-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 9999;
  justify-content: center;
  align-items: center;
}
.rank-overlay.visible { display: flex; }
.rank-panel {
  background: var(--bg-secondary, #151515);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 0;
  padding: 24px;
  width: 640px;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 0 40px rgba(139, 92, 246, 0.2), 0 20px 60px rgba(0, 0, 0, 0.5);
}
.rank-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 20px;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.5), 0 0 20px rgba(255, 255, 255, 0.3);
}
.rank-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.rank-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: #8b5cf6;
  min-width: 36px;
  text-align: center;
  text-shadow: 0 0 8px rgba(139, 92, 246, 0.5);
}
.rank-type {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #ffffff;
  flex: 1;
  letter-spacing: 0.3px;
}
.rank-cat {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--text-muted, #6b7280);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.rank-reason {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--text-muted, #6b7280);
  letter-spacing: 0.3px;
}
.rank-close {
  padding: 8px 20px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 0;
  background: transparent;
  color: #ffffff;
  cursor: pointer;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 20px;
  transition: all 0.15s ease;
}
.rank-close:hover {
  background: rgba(255, 255, 255, 0.05);
  box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
}

.tasks-empty {
  text-align: center;
  color: var(--text-muted, #6b7280);
  padding: 60px 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
</style>

<h4 style="font-family:'JetBrains Mono',monospace;font-weight:700;text-transform:uppercase;letter-spacing:2px;text-shadow:0 0 10px rgba(255,255,255,0.5),0 0 20px rgba(255,255,255,0.3);">TASKS</h4>

<!-- Summary cards -->
<div class="tasks-summary" id="task-summary">
  <div class="tasks-card open"><div class="card-count" id="count-open">-</div><div class="card-label">Open</div></div>
  <div class="tasks-card inprogress"><div class="card-count" id="count-inprogress">-</div><div class="card-label">In Progress</div></div>
  <div class="tasks-card done"><div class="card-count" id="count-done">-</div><div class="card-label">Done</div></div>
</div>

% if user_role == 'admin':
<!-- ============ ADMIN VIEW ============ -->

<!-- Target selector -->
<div class="tasks-target-bar">
  <label>TARGET:</label>
  <select id="target-select" onchange="loadAdminBoard()">
    <option value="">SELECT A TARGET...</option>
  </select>
</div>

<!-- Toolbar -->
<div class="tasks-toolbar" id="admin-toolbar" style="display:none">
  <input type="checkbox" id="select-all-cb" onchange="toggleSelectAll(this.checked)" title="Select all" style="accent-color:#22c55e">
  <label for="select-all-cb">SELECT ALL</label>
  <div class="toolbar-sep"></div>
  <label>ASSIGN TO:</label>
  <select id="bulk-assign-analyst" class="toolbar-assign-select"></select>
  <button class="btn-task btn-assign-action" onclick="bulkAssignSelected()">ASSIGN</button>
  <div class="toolbar-sep"></div>
  <button class="btn-task btn-rank" onclick="autoRankTypes()">AUTO RANK</button>
  <button class="btn-task btn-auto" onclick="autoAssign(false)">AUTO ASSIGN</button>
  <button class="btn-task btn-reset" onclick="autoAssign(true)">RESET &amp; REASSIGN</button>
</div>

<!-- Two-panel layout -->
<div class="tasks-container" id="admin-content" style="display:none">
  <div class="tasks-main" id="type-board">
    <div class="tasks-empty">SELECT A TARGET TO VIEW EVENT TYPES</div>
  </div>
  <div class="tasks-sidebar" id="analyst-sidebar">
    <div class="sidebar-title">ANALYSTS</div>
    <div id="analyst-list"></div>
  </div>
</div>

<!-- Rank overlay -->
<div class="rank-overlay" id="rank-overlay">
  <div class="rank-panel">
    <div class="rank-title">AUTO RANK &mdash; TYPE PRIORITY</div>
    <div id="rank-body" style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6b7280">ANALYZING...</div>
    <button class="rank-close" onclick="document.getElementById('rank-overlay').classList.remove('visible')">CLOSE</button>
  </div>
</div>

<script>
var _analysts = [];
var _assignments = {};
var _typeSummary = [];
var _currentTarget = '';

// Category colors from grade_config
var CAT_COLORS = {
    'Network Security': '#dc2626',
    'Web App Security': '#ea580c',
    'Information Leakage': '#eab308',
    'General Health': '#3b82f6',
    'External Account Exposure': '#06b6d4',
    'DNS Health': '#22c55e',
    'IP Reputation': '#d946ef',
    'AI Security': '#8b5cf6',
    'Information / Reference': '#6b7280'
};

// Load targets
(function() {
    sf.fetchData('${docroot}/scanlist', {}, function(data) {
        if (!data || !data.length) return;
        var sel = document.getElementById('target-select');
        var seen = {};
        for (var i = 0; i < data.length; i++) {
            var t = data[i][1];
            if (!t || seen[t]) continue;
            seen[t] = true;
            var opt = document.createElement('option');
            opt.value = t;
            opt.textContent = t;
            sel.appendChild(opt);
        }
    });
    // Load analysts
    sf.fetchData('${docroot}/analysts', {}, function(data) {
        if (!data || !data.success) return;
        _analysts = data.analysts || [];
        var sel = document.getElementById('bulk-assign-analyst');
        for (var i = 0; i < _analysts.length; i++) {
            var opt = document.createElement('option');
            opt.value = _analysts[i].username;
            opt.textContent = _analysts[i].display_name || _analysts[i].username;
            sel.appendChild(opt);
        }
    });
    // Load counts
    sf.fetchData('${docroot}/typeassignments', {count_only: '1'}, function(data) {
        if (data && data.success && data.counts) {
            document.getElementById('count-open').textContent = data.counts.OPEN || 0;
            document.getElementById('count-inprogress').textContent = data.counts.IN_PROGRESS || 0;
            document.getElementById('count-done').textContent = data.counts.DONE || 0;
        }
    });
})();

function loadAdminBoard() {
    var target = document.getElementById('target-select').value;
    if (!target) {
        document.getElementById('admin-toolbar').style.display = 'none';
        document.getElementById('admin-content').style.display = 'none';
        return;
    }
    _currentTarget = target;
    document.getElementById('admin-toolbar').style.display = 'flex';
    document.getElementById('admin-content').style.display = 'flex';

    // Load assignments for this target
    sf.fetchData('${docroot}/typeassignments', {target: target}, function(data) {
        _assignments = (data && data.success) ? (data.assignments || {}) : {};
        // Load scan result summary for this target
        sf.fetchData('${docroot}/scanlist', {}, function(scanData) {
            if (!scanData) return;
            // Find latest scan for this target
            var latestScan = null;
            for (var i = 0; i < scanData.length; i++) {
                if (scanData[i][1] === target) {
                    if (!latestScan || scanData[i][0] > latestScan) latestScan = scanData[i][0];
                }
            }
            if (latestScan) {
                sf.fetchData('${docroot}/scansummary', {id: latestScan, by: 'type'}, function(summary) {
                    _typeSummary = summary || [];
                    renderTypeBoard();
                    renderAnalystSidebar();
                });
            } else {
                _typeSummary = [];
                renderTypeBoard();
                renderAnalystSidebar();
            }
        });
    });
}

function renderTypeBoard() {
    var board = document.getElementById('type-board');
    if (!_typeSummary.length) {
        board.innerHTML = '<div class="tasks-empty">NO SCAN RESULTS FOR THIS TARGET</div>';
        return;
    }

    // Group types by category
    var catGroups = {};
    for (var i = 0; i < _typeSummary.length; i++) {
        var row = _typeSummary[i];
        var et = row[0];
        var descr = row[1];
        var count = row[3] || 0;
        // Use category from scansummary data (index 6) if available
        var cat = (row.length > 6 && row[6]) ? row[6] : getTypeCategory(et);
        if (!catGroups[cat]) catGroups[cat] = [];
        catGroups[cat].push({eventType: et, descr: descr, count: count});
    }

    // Sort categories by weight
    var catOrder = ['Network Security', 'Web App Security', 'AI Security', 'Information Leakage',
                    'General Health', 'External Account Exposure', 'DNS Health', 'IP Reputation', 'Information / Reference'];
    var html = '';
    for (var ci = 0; ci < catOrder.length; ci++) {
        var cat = catOrder[ci];
        var types = catGroups[cat];
        if (!types || !types.length) continue;
        delete catGroups[cat];
        html += renderCatGroup(cat, types);
    }
    // Any remaining categories
    for (var cat in catGroups) {
        html += renderCatGroup(cat, catGroups[cat]);
    }
    board.innerHTML = html;
}

function renderCatGroup(cat, types) {
    var color = CAT_COLORS[cat] || '#6b7280';
    var html = '<div class="cat-group">';
    html += '<div class="cat-header" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display===\'none\'?\'block\':\'none\'">';
    html += '<span class="cat-color" style="background:' + color + ';box-shadow:0 0 6px ' + color + '"></span>';
    html += '<span class="cat-name">' + sf.escapeHtml(cat) + '</span>';
    html += '<span class="cat-count">' + types.length + ' TYPES</span>';
    html += '</div>';
    html += '<div class="cat-types">';
    for (var i = 0; i < types.length; i++) {
        var t = types[i];
        var assigns = _assignments[t.eventType] || [];
        var assignNames = [];
        var statusClass = '';
        for (var j = 0; j < assigns.length; j++) {
            assignNames.push(assigns[j].assigned_to);
            if (!statusClass && assigns[j].status !== 'DONE') {
                statusClass = 's-' + assigns[j].status.toLowerCase();
            }
        }
        var chipText = assignNames.length ? assignNames.join(', ') : 'UNASSIGNED';
        var chipClass = assignNames.length ? 'assign-chip' : 'assign-chip unassigned';

        html += '<div class="type-row">';
        html += '<input type="checkbox" class="type-cb" value="' + sf.escapeHtml(t.eventType) + '">';
        html += '<span class="type-name" title="' + sf.escapeHtml(t.descr) + '">' + sf.escapeHtml(t.eventType) + '</span>';
        html += '<span class="type-findings">' + t.count + '</span>';
        if (statusClass) html += '<span class="status-badge ' + statusClass + '">' + (statusClass === 's-open' ? 'OPEN' : statusClass === 's-in_progress' ? 'WIP' : 'DONE') + '</span>';
        html += '<span class="' + chipClass + '" onclick="showAssignDropdown(this, \'' + sf.escapeHtml(t.eventType) + '\')">' + sf.escapeHtml(chipText) + '</span>';
        html += '</div>';
    }
    html += '</div></div>';
    return html;
}

function showAssignDropdown(chip, eventType) {
    var existing = chip.parentNode.querySelector('.assign-dropdown.visible');
    if (existing) { existing.remove(); return; }

    var sel = document.createElement('select');
    sel.className = 'assign-dropdown visible';
    var optNone = document.createElement('option');
    optNone.value = '';
    optNone.textContent = '-- REMOVE --';
    sel.appendChild(optNone);
    for (var i = 0; i < _analysts.length; i++) {
        var opt = document.createElement('option');
        opt.value = _analysts[i].username;
        opt.textContent = _analysts[i].display_name || _analysts[i].username;
        sel.appendChild(opt);
    }
    sel.onchange = function() {
        var user = sel.value;
        if (!user) {
            var assigns = _assignments[eventType] || [];
            for (var i = 0; i < assigns.length; i++) {
                sf.fetchData('${docroot}/typeassignremove', {target: _currentTarget, eventType: eventType, assignedTo: assigns[i].assigned_to}, function() {});
            }
            delete _assignments[eventType];
        } else {
            sf.fetchData('${docroot}/typeassign', {target: _currentTarget, eventType: eventType, assignTo: user}, function(data) {
                if (data && data.success) {
                    _assignments[eventType] = [{assigned_to: user, status: 'OPEN', assigned_by: '${user}'}];
                }
            });
        }
        sel.remove();
        setTimeout(function() { renderTypeBoard(); renderAnalystSidebar(); }, 300);
    };
    chip.parentNode.appendChild(sel);
    sel.focus();
}

function renderAnalystSidebar() {
    var container = document.getElementById('analyst-list');
    if (!_analysts.length) {
        container.innerHTML = '<div class="tasks-empty" style="padding:20px">NO ANALYST USERS</div>';
        return;
    }
    var analystCounts = {};
    for (var i = 0; i < _analysts.length; i++) {
        analystCounts[_analysts[i].username] = {open: 0, inprogress: 0, done: 0, total: 0};
    }
    for (var et in _assignments) {
        var assigns = _assignments[et];
        for (var j = 0; j < assigns.length; j++) {
            var u = assigns[j].assigned_to;
            if (!analystCounts[u]) analystCounts[u] = {open: 0, inprogress: 0, done: 0, total: 0};
            analystCounts[u].total++;
            if (assigns[j].status === 'OPEN') analystCounts[u].open++;
            else if (assigns[j].status === 'IN_PROGRESS') analystCounts[u].inprogress++;
            else if (assigns[j].status === 'DONE') analystCounts[u].done++;
        }
    }

    var totalTypes = _typeSummary.length;
    var assignedTypes = Object.keys(_assignments).length;
    var html = '<div class="sidebar-summary">' + assignedTypes + ' / ' + totalTypes + ' TYPES ASSIGNED</div>';

    for (var i = 0; i < _analysts.length; i++) {
        var a = _analysts[i];
        var c = analystCounts[a.username] || {open:0, inprogress:0, done:0, total:0};
        html += '<div class="analyst-card">';
        html += '<div class="analyst-name">' + sf.escapeHtml(a.display_name || a.username) + '</div>';
        html += '<div class="analyst-stats">';
        html += '<span class="analyst-stat"><span class="stat-dot open"></span>' + c.open + ' OPEN</span>';
        html += '<span class="analyst-stat"><span class="stat-dot inprogress"></span>' + c.inprogress + ' WIP</span>';
        html += '<span class="analyst-stat"><span class="stat-dot done"></span>' + c.done + ' DONE</span>';
        html += '</div></div>';
    }
    container.innerHTML = html;
}

function toggleSelectAll(checked) {
    var cbs = document.querySelectorAll('.type-cb');
    for (var i = 0; i < cbs.length; i++) cbs[i].checked = checked;
}

function getSelectedTypes() {
    var cbs = document.querySelectorAll('.type-cb:checked');
    var types = [];
    for (var i = 0; i < cbs.length; i++) types.push(cbs[i].value);
    return types;
}

function bulkAssignSelected() {
    var types = getSelectedTypes();
    if (!types.length) { alert('Select event types first'); return; }
    var analyst = document.getElementById('bulk-assign-analyst').value;
    if (!analyst) { alert('Select an analyst'); return; }
    var items = [];
    for (var i = 0; i < types.length; i++) {
        items.push({eventType: types[i], assignedTo: analyst});
    }
    sf.fetchData('${docroot}/typeassignbulk', {target: _currentTarget, assignments: JSON.stringify(items)}, function(data) {
        if (data && data.success) {
            loadAdminBoard();
        }
    });
}

function autoAssign(reset) {
    var msg = reset ? 'Clear ALL existing assignments and redistribute evenly?' : 'Distribute unassigned types evenly across analysts?';
    if (!confirm(msg)) return;
    sf.fetchData('${docroot}/typeassignauto', {target: _currentTarget, reset: reset ? '1' : '0'}, function(data) {
        if (data && data.success) {
            alert('Assigned ' + data.count + ' types across ' + data.analysts + ' analysts');
            loadAdminBoard();
        } else {
            alert(data ? data.message : 'Auto-assign failed');
        }
    });
}

function autoRankTypes() {
    var overlay = document.getElementById('rank-overlay');
    var body = document.getElementById('rank-body');
    body.innerHTML = 'ANALYZING EVENT TYPES...';
    overlay.classList.add('visible');
    sf.fetchData('${docroot}/typeassignairank', {target: _currentTarget}, function(data) {
        if (!data || !data.success) {
            body.innerHTML = '<div style="color:#ef4444;text-shadow:0 0 8px rgba(239,68,68,0.5)">FAILED: ' + (data ? sf.escapeHtml(data.message) : 'ERROR') + '</div>';
            return;
        }
        var ranked = data.ranked_types || [];
        var html = '';
        for (var i = 0; i < ranked.length; i++) {
            var r = ranked[i];
            html += '<div class="rank-row">';
            html += '<span class="rank-num">#' + r.rank + '</span>';
            html += '<span class="rank-type">' + sf.escapeHtml(r.event_type) + '</span>';
            html += '<span class="rank-cat">' + sf.escapeHtml(r.category) + '</span>';
            html += '</div>';
            html += '<div style="padding:0 0 6px 48px"><span class="rank-reason">' + sf.escapeHtml(r.reason) + '</span></div>';
        }
        if (!html) html = '<div class="tasks-empty" style="padding:20px">NO TYPES TO RANK</div>';
        body.innerHTML = html;
    });
}

// Category mapping (client-side, mirrors grade_config)
function getTypeCategory(eventType) {
    var netTypes = ['EXTERNAL_VULNERABILITIES','VULNERABILITY_CVE_CRITICAL','VULNERABILITY_CVE_HIGH','VULNERABILITY_CVE_MEDIUM','VULNERABILITY_CVE_LOW','VULNERABILITY_GENERAL','TCP_PORT_OPEN','TCP_PORT_OPEN_BANNER','UDP_PORT_OPEN','UDP_PORT_OPEN_INFO','OPEN_TCP_PORT_HAS_VULNS','OPEN_TCP_PORT_HAS_VULNS_LOW','WEBSERVER_BANNER','WEBSERVER_HTTPHEADERS','WEBSERVER_TECHNOLOGY','OPERATING_SYSTEM','INTERNAL_IP_ADDRESS','IP_ADDRESS'];
    var webTypes = ['HTTP_CODE','URL_FORM','URL_UPLOAD','URL_JAVASCRIPT','URL_JAVA_APPLET','URL_FLASH','URL_WEB_FRAMEWORK','URL_STATIC_PARAM','URL_PASSWORD','WEBSERVER_STRANGEHEADER','CONTENT_INTERESTING_SUBDIR'];
    var dnsTypes = ['DNS_SPF','DNS_TEXT','DNS_SRV','DOMAIN_NAME','DOMAIN_NAME_PARENT','DOMAIN_REGISTRAR','DOMAIN_WHOIS','INTERNET_NAME','INTERNET_NAME_UNRESOLVED','PROVIDER_DNS','AFFILIATE_INTERNET_NAME','DNS_PASSIVE','DOMAIN_IMPERSONATION'];
    var infoLeakTypes = ['EMAILADDR','EMAIL_COMPROMISED','DARKNET_MENTION_CONTENT','LEAKSITE_CONTENT','PASSWORD_COMPROMISED','PHONE_NUMBER','PHYSICAL_ADDRESS','HUMAN_NAME','PGP_KEY','CREDENTIAL_SET','BASE64_DATA'];
    var ipRepTypes = ['MALICIOUS_IPADDR','MALICIOUS_AFFILIATE_IPADDR','MALICIOUS_SUBNET','MALICIOUS_INTERNET_NAME','MALICIOUS_EMAILADDR','BLACKLISTED_IPADDR','BLACKLISTED_AFFILIATE_IPADDR','BLACKLISTED_SUBNET','BLACKLISTED_NETBLOCK'];
    var aiTypes = ['AI_ENDPOINT','AI_MODEL_LEAK','AI_TRAINING_DATA','MCP_SERVER','AI_INFRASTRUCTURE'];

    if (netTypes.indexOf(eventType) !== -1) return 'Network Security';
    if (webTypes.indexOf(eventType) !== -1) return 'Web App Security';
    if (dnsTypes.indexOf(eventType) !== -1) return 'DNS Health';
    if (infoLeakTypes.indexOf(eventType) !== -1) return 'Information Leakage';
    if (ipRepTypes.indexOf(eventType) !== -1) return 'IP Reputation';
    if (aiTypes.indexOf(eventType) !== -1) return 'AI Security';
    if (eventType.indexOf('ACCOUNT_EXTERNAL') !== -1 || eventType.indexOf('SOCIAL_MEDIA') !== -1) return 'External Account Exposure';
    if (eventType.indexOf('SSL_CERTIFICATE') !== -1 || eventType.indexOf('GEOINFO') !== -1 || eventType.indexOf('SOFTWARE_USED') !== -1) return 'General Health';
    if (eventType.indexOf('WEBAPP_VULNERABILITIES') !== -1) return 'Web App Security';
    return 'Information / Reference';
}
</script>

% else:
<!-- ============ ANALYST VIEW ============ -->

<script>
(function() {
    sf.fetchData('${docroot}/tasks', {}, function(data) {
        if (!data || !data.success) return;
        var counts = data.counts || {};
        document.getElementById('count-open').textContent = counts.OPEN || 0;
        document.getElementById('count-inprogress').textContent = counts.IN_PROGRESS || 0;
        document.getElementById('count-done').textContent = counts.DONE || 0;

        var tasks = data.assignments || [];
        var tbody = document.getElementById('analyst-tasks-body');
        if (!tasks.length) {
            tbody.innerHTML = "<tr><td colspan='5' style='text-align:center;color:#6b7280;font-family:JetBrains Mono,monospace;font-size:11px;text-transform:uppercase;letter-spacing:1px'>NO TASKS ASSIGNED</td></tr>";
            return;
        }
        var byTarget = {};
        for (var i = 0; i < tasks.length; i++) {
            var t = tasks[i];
            if (!byTarget[t.target]) byTarget[t.target] = [];
            byTarget[t.target].push(t);
        }
        var html = '';
        for (var target in byTarget) {
            var items = byTarget[target];
            for (var i = 0; i < items.length; i++) {
                var t = items[i];
                var statusBtns = '';
                ['OPEN','IN_PROGRESS','DONE'].forEach(function(s) {
                    var cls = t.status === s ? ('active-' + s.toLowerCase().replace('_','')) : '';
                    var label = s === 'IN_PROGRESS' ? 'IN PROGRESS' : s;
                    statusBtns += "<button class='task-status-btn " + cls + "' onclick='updateTaskStatus(\"" +
                        sf.escapeHtml(t.target) + "\",\"" + sf.escapeHtml(t.event_type) + "\",\"" +
                        sf.escapeHtml(t.assigned_to) + "\",\"" + s + "\",this)'>" + label + "</button>";
                });
                var dateStr = t.date_assigned ? new Date(t.date_assigned).toLocaleDateString() : '';
                html += '<tr>';
                html += '<td class="task-target">' + sf.escapeHtml(target) + '</td>';
                html += '<td>' + sf.escapeHtml(t.event_type) + '</td>';
                html += '<td>' + statusBtns + '</td>';
                html += '<td>' + sf.escapeHtml(t.assigned_by || '') + '</td>';
                html += '<td>' + dateStr + '</td>';
                html += '</tr>';
            }
        }
        tbody.innerHTML = html;
    });
})();

function updateTaskStatus(target, eventType, assignedTo, status, btn) {
    sf.fetchData('${docroot}/typeassignstatus', {
        target: target, eventType: eventType, assignedTo: assignedTo, status: status
    }, function(data) {
        if (data && data.success) {
            var row = btn.closest('tr');
            row.querySelectorAll('.task-status-btn').forEach(function(b) {
                b.className = 'task-status-btn';
            });
            btn.classList.add('active-' + status.toLowerCase().replace('_', ''));
        }
    });
}
</script>

<table class="analyst-tasks-table" id="analyst-tasks">
  <thead>
    <tr>
      <th>TARGET</th>
      <th>EVENT TYPE</th>
      <th>STATUS</th>
      <th>ASSIGNED BY</th>
      <th>DATE</th>
    </tr>
  </thead>
  <tbody id="analyst-tasks-body">
    <tr><td colspan="5" style="text-align:center;color:#6b7280;font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:1px">LOADING...</td></tr>
  </tbody>
</table>

% endif

<%include file="FOOTER.tmpl"/>
