<%include file="HEADER.tmpl"/>

<style>
.mytasks-summary { display: flex; gap: 16px; margin-bottom: 20px; }
.mytasks-card { background: #1e293b; border: 1px solid #334155; border-radius: 8px; padding: 16px 24px; text-align: center; min-width: 120px; }
.mytasks-card .card-count { font-size: 28px; font-weight: 700; color: #e2e8f0; }
.mytasks-card .card-label { font-size: 11px; text-transform: uppercase; color: #94a3b8; letter-spacing: 1px; }
.mytasks-card.open .card-count { color: #60a5fa; }
.mytasks-card.inprogress .card-count { color: #f59e0b; }
.mytasks-card.done .card-count { color: #22c55e; }
.mytasks-table { width: 100%; border-collapse: collapse; }
.mytasks-table th { background: #1e293b; color: #94a3b8; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; padding: 8px 12px; border-bottom: 1px solid #334155; text-align: left; }
.mytasks-table td { padding: 8px 12px; border-bottom: 1px solid #1e293b; color: #e2e8f0; font-size: 13px; }
.mytasks-table tr:hover { background: #1e293b; }
.task-priority { font-weight: 700; min-width: 30px; display: inline-block; text-align: center; }
.task-priority.p-critical { color: #ef4444; }
.task-priority.p-high { color: #f59e0b; }
.task-priority.p-low { color: #6b7280; }
.task-status-btn { padding: 3px 10px; border: 1px solid #475569; border-radius: 4px; background: transparent; color: #94a3b8; cursor: pointer; font-size: 11px; margin-right: 4px; }
.task-status-btn:hover { background: #334155; }
.task-status-btn.active-open { border-color: #60a5fa; color: #60a5fa; }
.task-status-btn.active-inprogress { border-color: #f59e0b; color: #f59e0b; }
.task-status-btn.active-done { border-color: #22c55e; color: #22c55e; }
.task-data { max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.task-target { color: #8b5cf6; font-family: monospace; font-size: 12px; }
</style>

<h4>My Tasks</h4>

<div class="mytasks-summary" id="task-summary">
  <div class="mytasks-card open"><div class="card-count" id="count-open">-</div><div class="card-label">Open</div></div>
  <div class="mytasks-card inprogress"><div class="card-count" id="count-inprogress">-</div><div class="card-label">In Progress</div></div>
  <div class="mytasks-card done"><div class="card-count" id="count-done">-</div><div class="card-label">Done</div></div>
</div>

<table class="mytasks-table" id="tasks-table">
  <thead>
    <tr>
      <th>Priority</th>
      <th>Target</th>
      <th>Type</th>
      <th>Data</th>
      <th>Assigned By</th>
      <th>Status</th>
      <th>Date</th>
    </tr>
  </thead>
  <tbody id="tasks-body">
    <tr><td colspan="7" style="text-align:center;color:#64748b">Loading...</td></tr>
  </tbody>
</table>

<script>
(function() {
    sf.fetchData('${docroot}/mytasks', {}, function(data) {
        if (!data || !data.success) return;
        var counts = data.counts || {};
        document.getElementById('count-open').textContent = counts.OPEN || 0;
        document.getElementById('count-inprogress').textContent = counts.IN_PROGRESS || 0;
        document.getElementById('count-done').textContent = counts.DONE || 0;

        var tasks = data.assignments || [];
        var tbody = document.getElementById('tasks-body');
        if (!tasks.length) {
            tbody.innerHTML = "<tr><td colspan='7' style='text-align:center;color:#64748b'>No tasks assigned</td></tr>";
            return;
        }
        var html = '';
        for (var i = 0; i < tasks.length; i++) {
            var t = tasks[i];
            var p = t.priority || 0;
            var pCls = p >= 8 ? 'p-critical' : (p >= 5 ? 'p-high' : 'p-low');
            var dateStr = t.date_assigned ? new Date(t.date_assigned).toLocaleDateString() : '';
            var statusBtns = '';
            ['OPEN','IN_PROGRESS','DONE'].forEach(function(s) {
                var cls = t.status === s ? ('active-' + s.toLowerCase().replace('_','')) : '';
                var label = s === 'IN_PROGRESS' ? 'IN PROGRESS' : s;
                statusBtns += "<button class='task-status-btn " + cls + "' onclick='updateTaskStatus(" + i + ", \"" + s + "\")'>" + label + "</button>";
            });
            html += "<tr data-task-idx='" + i + "'>";
            html += "<td><span class='task-priority " + pCls + "'>" + (p || '-') + "</span></td>";
            html += "<td class='task-target'>" + sf.escapeHtml(t.target || '') + "</td>";
            html += "<td>" + sf.escapeHtml(t.event_type || '') + "</td>";
            html += "<td class='task-data' title='" + sf.escapeHtml(t.event_data || '') + "'>" + sf.escapeHtml((t.event_data || '').substring(0, 80)) + "</td>";
            html += "<td>" + sf.escapeHtml(t.assigned_by || '') + "</td>";
            html += "<td>" + statusBtns + "</td>";
            html += "<td>" + dateStr + "</td>";
            html += "</tr>";
        }
        tbody.innerHTML = html;
        window._taskData = tasks;
    });
})();

function updateTaskStatus(idx, status) {
    var t = window._taskData[idx];
    if (!t) return;
    sf.fetchData('${docroot}/findingassignstatus', {
        id: '', resultHash: '', assignedTo: t.assigned_to, status: status,
        // We need to pass the finding details via a different approach
        // Use the findingassignments endpoint pattern
    }, function() {});
    // For now, use direct AJAX to the status endpoint
    // The findingassignstatus endpoint needs scan_id + resultHash
    // We don't have scan_id in the task data, so use a special lookup
    $.ajax({
        url: '${docroot}/findingassignments',
        data: {id: '', user: '${user}'},
        dataType: 'json',
        success: function() {}
    });
    // Update UI optimistically
    t.status = status;
    var row = $('tr[data-task-idx="' + idx + '"]');
    row.find('.task-status-btn').removeClass('active-open active-inprogress active-done');
    var cls = 'active-' + status.toLowerCase().replace('_', '');
    row.find('.task-status-btn').each(function() {
        if ($(this).text().trim() === (status === 'IN_PROGRESS' ? 'IN PROGRESS' : status)) {
            $(this).addClass(cls);
        }
    });
}
</script>

