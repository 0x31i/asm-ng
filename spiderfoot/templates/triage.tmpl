<%include file="HEADER.tmpl"/>
<%
import json as _json
%>
<style>
/* ──────────────────────────────────────────────────────────────────
   AI TRIAGE PAGE
────────────────────────────────────────────────────────────────── */

.triage-header { display:flex; align-items:center; gap:14px; margin-bottom:24px; }
.triage-title  { font-size:21px; font-weight:700; color:#eee; letter-spacing:-.3px; }
.triage-sub    { color:#555; font-size:13px; margin-left:8px; }

/* Cards */
.triage-card { background:#181818; border:1px solid #262626; border-radius:8px; margin-bottom:20px; overflow:hidden; }
.triage-card-hdr {
    background:#141414; border-bottom:1px solid #222; padding:11px 18px;
    display:flex; align-items:center; justify-content:space-between;
}
.triage-card-hdr-label {
    font-size:10px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; color:#666;
}
.triage-card-body { padding:20px; }

/* Export section */
.triage-export-form { display:flex; flex-wrap:wrap; gap:16px; align-items:flex-end; }
.triage-export-form .form-group { margin-bottom:0; min-width:220px; }
.triage-export-form label { font-size:11px; font-weight:600; color:#888; text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:4px; }
.triage-export-form select, .triage-export-form input { background:#111; border:1px solid #333; color:#ddd; border-radius:4px; padding:6px 10px; width:100%; }

/* Stats row */
.triage-stats { display:flex; gap:20px; margin:16px 0; flex-wrap:wrap; }
.triage-stat { background:#111; border:1px solid #262626; border-radius:6px; padding:12px 18px; min-width:120px; text-align:center; }
.triage-stat-val { font-size:22px; font-weight:700; color:#0f0; }
.triage-stat-val.fp { color:#f44; }
.triage-stat-val.review { color:#fa0; }
.triage-stat-val.legit { color:#0f0; }
.triage-stat-label { font-size:10px; color:#666; text-transform:uppercase; letter-spacing:1px; margin-top:2px; }

/* Upload zone */
.triage-dropzone {
    border:2px dashed #333; border-radius:8px; padding:40px; text-align:center;
    color:#555; cursor:pointer; transition: border-color 0.2s, background 0.2s;
}
.triage-dropzone:hover, .triage-dropzone.dragover { border-color:#0a0; background:rgba(0,255,0,0.03); }
.triage-dropzone-text { font-size:14px; }
.triage-dropzone-sub { font-size:11px; color:#444; margin-top:6px; }

/* Preview table */
.triage-preview { max-height:300px; overflow-y:auto; margin-top:16px; }
.triage-preview table { width:100%; font-size:12px; }
.triage-preview th { position:sticky; top:0; background:#141414; color:#666; font-size:10px; text-transform:uppercase; letter-spacing:1px; padding:6px 8px; }
.triage-preview td { padding:5px 8px; border-bottom:1px solid #1a1a1a; color:#ccc; }
.triage-preview .cls-fp { color:#f44; font-weight:600; }
.triage-preview .cls-legit { color:#0f0; font-weight:600; }
.triage-preview .cls-review { color:#fa0; font-weight:600; }

/* Buttons */
.btn-triage-export { background:#1a6b1a; color:#fff; border:1px solid #2a8a2a; padding:8px 20px; border-radius:4px; font-weight:600; cursor:pointer; }
.btn-triage-export:hover { background:#228b22; color:#fff; }
.btn-triage-apply { background:#1a6b1a; color:#fff; border:1px solid #2a8a2a; padding:8px 20px; border-radius:4px; font-weight:600; cursor:pointer; }
.btn-triage-apply:hover { background:#228b22; color:#fff; }
.btn-triage-apply:disabled { background:#333; color:#666; border-color:#444; cursor:not-allowed; }
.btn-triage-review { background:#333; color:#ccc; border:1px solid #444; padding:8px 20px; border-radius:4px; font-weight:600; cursor:pointer; }
.btn-triage-review:hover { background:#444; color:#fff; }

/* History table */
.triage-history-table { width:100%; font-size:12px; }
.triage-history-table th { color:#666; font-size:10px; text-transform:uppercase; letter-spacing:1px; padding:8px; border-bottom:1px solid #262626; }
.triage-history-table td { padding:8px; border-bottom:1px solid #1a1a1a; color:#ccc; }

/* Info box */
.triage-info { background:#0a0a1a; border:1px solid #1a1a3a; border-radius:6px; padding:14px 18px; margin-top:16px; font-size:12px; color:#88a; line-height:1.6; }
.triage-info code { background:#111; padding:2px 5px; border-radius:3px; color:#aac; }
</style>

<div class="triage-header">
    <span class="triage-title">AI Triage</span>
    <span class="triage-sub">Export scan results for Claude Code classification, then import results to batch-update FP status</span>
</div>

<!-- ── EXPORT SECTION ──────────────────────────────────────────── -->
<div class="triage-card">
    <div class="triage-card-hdr">
        <span class="triage-card-hdr-label">Export Triage Package</span>
        <span id="triage-result-count" style="color:#555; font-size:12px;"></span>
    </div>
    <div class="triage-card-body">
        <div class="triage-export-form">
            <div class="form-group">
                <label>Scan</label>
                <select id="triage-scan-select">
                    <option value="">-- Select a scan --</option>
                    % for scan in scans:
                    <option value="${scan[0]}" data-target="${scan[2]}" data-name="${scan[1]}" data-status="${scan[6]}">${scan[1]} (${scan[2]}) - ${scan[6]}</option>
                    % endfor
                </select>
            </div>
            <div class="form-group">
                <label>Include</label>
                <select id="triage-filter">
                    <option value="unreviewed">Unreviewed only (fp=0)</option>
                    <option value="all">All results</option>
                </select>
            </div>
            <div class="form-group">
                <button class="btn-triage-export" id="btn-triage-export" onclick="triageExport()" disabled>
                    Export Triage Package
                </button>
            </div>
        </div>

        <div id="triage-export-stats" class="triage-stats" style="display:none;">
            <div class="triage-stat">
                <div class="triage-stat-val" id="stat-total">0</div>
                <div class="triage-stat-label">Total Results</div>
            </div>
            <div class="triage-stat">
                <div class="triage-stat-val" id="stat-unreviewed">0</div>
                <div class="triage-stat-label">Unreviewed</div>
            </div>
            <div class="triage-stat">
                <div class="triage-stat-val fp" id="stat-fp">0</div>
                <div class="triage-stat-label">Already FP</div>
            </div>
            <div class="triage-stat">
                <div class="triage-stat-val legit" id="stat-validated">0</div>
                <div class="triage-stat-label">Validated</div>
            </div>
            <div class="triage-stat">
                <div class="triage-stat-val" id="stat-known-assets">0</div>
                <div class="triage-stat-label">Known Assets</div>
            </div>
        </div>

        <div class="triage-info">
            <strong>Workflow:</strong><br>
            1. Select a completed scan and click <code>Export Triage Package</code><br>
            2. Open Claude Code in your terminal: <code>claude</code><br>
            3. Tell Claude: <code>Process the triage file at ~/Downloads/triage_&lt;scanid&gt;.json</code><br>
            4. Claude reads the file, classifies each result, and writes a <code>triage_output_*.json</code> file<br>
            5. Upload the output file below to apply classifications
        </div>
    </div>
</div>

<!-- ── IMPORT SECTION ──────────────────────────────────────────── -->
<div class="triage-card">
    <div class="triage-card-hdr">
        <span class="triage-card-hdr-label">Import Triage Results</span>
    </div>
    <div class="triage-card-body">
        <div class="triage-dropzone" id="triage-dropzone" onclick="document.getElementById('triage-file-input').click();">
            <div class="triage-dropzone-text">Drop triage results file here or click to browse</div>
            <div class="triage-dropzone-sub">Accepts triage_output_*.json from Claude Code</div>
        </div>
        <input type="file" id="triage-file-input" accept=".json" style="display:none;" onchange="triageFileSelected(this)">

        <!-- Preview area (hidden until file loaded) -->
        <div id="triage-import-preview" style="display:none;">
            <div class="triage-stats">
                <div class="triage-stat">
                    <div class="triage-stat-val fp" id="import-fp-count">0</div>
                    <div class="triage-stat-label">False Positives</div>
                </div>
                <div class="triage-stat">
                    <div class="triage-stat-val legit" id="import-legit-count">0</div>
                    <div class="triage-stat-label">Legitimate</div>
                </div>
                <div class="triage-stat">
                    <div class="triage-stat-val review" id="import-review-count">0</div>
                    <div class="triage-stat-label">Needs Review</div>
                </div>
                <div class="triage-stat">
                    <div class="triage-stat-val" id="import-total-count">0</div>
                    <div class="triage-stat-label">Total Classified</div>
                </div>
            </div>

            <div id="import-errors" style="display:none; color:#f44; font-size:12px; margin:10px 0; padding:8px; background:#1a0a0a; border:1px solid #330a0a; border-radius:4px;"></div>

            <div class="triage-preview" id="triage-preview-table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Classification</th>
                            <th>Count</th>
                            <th>Sample Results</th>
                        </tr>
                    </thead>
                    <tbody id="triage-preview-tbody">
                    </tbody>
                </table>
            </div>

            <div style="margin-top:16px; display:flex; gap:12px;">
                <button class="btn-triage-apply" id="btn-triage-apply" onclick="triageApply()" disabled>
                    Apply Classifications
                </button>
                <button class="btn-triage-review" onclick="triageShowDetail()">
                    Review All
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── HISTORY SECTION ─────────────────────────────────────────── -->
<div class="triage-card">
    <div class="triage-card-hdr">
        <span class="triage-card-hdr-label">Triage History</span>
    </div>
    <div class="triage-card-body">
        <table class="triage-history-table" id="triage-history-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Scan</th>
                    <th>Target</th>
                    <th>FP</th>
                    <th>Legit</th>
                    <th>Review</th>
                    <th>Applied By</th>
                </tr>
            </thead>
            <tbody id="triage-history-tbody">
                <tr><td colspan="7" style="text-align:center; color:#444;">No triage history yet</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ── DETAIL MODAL ────────────────────────────────────────────── -->
<div id="triage-detail-modal" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-lg" style="width:85%;">
        <div class="modal-content" style="background:#181818; border:1px solid #333;">
            <div class="modal-header" style="border-bottom:1px solid #333;">
                <button type="button" class="close" data-dismiss="modal" style="color:#666;">&times;</button>
                <h4 class="modal-title" style="color:#ddd;">Triage Classifications Detail</h4>
            </div>
            <div class="modal-body" style="max-height:70vh; overflow-y:auto;">
                <table class="triage-history-table" style="width:100%;">
                    <thead>
                        <tr>
                            <th>Class</th>
                            <th>Type</th>
                            <th>Data</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody id="triage-detail-tbody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
(function() {
    "use strict";

    var _importData = null;   // Parsed triage import JSON
    var _exportMeta = {};     // Metadata about exported results for cross-reference

    // ── Scan selection: fetch counts ──────────────────────────────
    document.getElementById('triage-scan-select').addEventListener('change', function() {
        var scanId = this.value;
        var btn = document.getElementById('btn-triage-export');
        if (!scanId) {
            btn.disabled = true;
            document.getElementById('triage-export-stats').style.display = 'none';
            return;
        }
        btn.disabled = false;

        // Fetch result counts for this scan
        $.getJSON(docroot + '/triagecounts?id=' + encodeURIComponent(scanId), function(data) {
            if (data && data.success) {
                document.getElementById('stat-total').textContent = (data.counts.total || 0).toLocaleString();
                document.getElementById('stat-unreviewed').textContent = (data.counts.unreviewed || 0).toLocaleString();
                document.getElementById('stat-fp').textContent = (data.counts.fp || 0).toLocaleString();
                document.getElementById('stat-validated').textContent = (data.counts.validated || 0).toLocaleString();
                document.getElementById('stat-known-assets').textContent = (data.counts.known_assets || 0).toLocaleString();
                document.getElementById('triage-export-stats').style.display = 'flex';
                document.getElementById('triage-result-count').textContent =
                    (data.counts.unreviewed || 0).toLocaleString() + ' results to triage';
            }
        });
    });

    // ── Export ─────────────────────────────────────────────────────
    window.triageExport = function() {
        var scanId = document.getElementById('triage-scan-select').value;
        var filter = document.getElementById('triage-filter').value;
        if (!scanId) { alertify.warning('Select a scan first'); return; }

        var btn = document.getElementById('btn-triage-export');
        btn.disabled = true;
        btn.textContent = 'Exporting...';

        window.location.href = docroot + '/triageexport?id=' + encodeURIComponent(scanId) +
            '&filter=' + encodeURIComponent(filter);

        setTimeout(function() {
            btn.disabled = false;
            btn.textContent = 'Export Triage Package';
        }, 2000);
    };

    // ── Drag & Drop ───────────────────────────────────────────────
    var dz = document.getElementById('triage-dropzone');
    dz.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('dragover'); });
    dz.addEventListener('dragleave', function() { this.classList.remove('dragover'); });
    dz.addEventListener('drop', function(e) {
        e.preventDefault();
        this.classList.remove('dragover');
        if (e.dataTransfer.files.length) {
            triageReadFile(e.dataTransfer.files[0]);
        }
    });

    window.triageFileSelected = function(input) {
        if (input.files.length) {
            triageReadFile(input.files[0]);
        }
    };

    function triageReadFile(file) {
        if (!file.name.endsWith('.json')) {
            alertify.error('Please upload a .json file');
            return;
        }
        var reader = new FileReader();
        reader.onload = function(e) {
            try {
                var data = JSON.parse(e.target.result);
                triagePreview(data);
            } catch (ex) {
                alertify.error('Invalid JSON file: ' + ex.message);
            }
        };
        reader.readAsText(file);
    }

    // ── Preview imported classifications ──────────────────────────
    function triagePreview(data) {
        // Validate structure
        if (!data.triage_version || !data.classifications) {
            alertify.error('Invalid triage file: missing triage_version or classifications');
            return;
        }

        _importData = data;

        var counts = {FP: 0, LEGIT: 0, REVIEW: 0};
        var samples = {FP: [], LEGIT: [], REVIEW: []};
        var errors = [];

        data.classifications.forEach(function(entry) {
            if (!entry.id || !entry['class']) {
                errors.push('Entry missing id or class');
                return;
            }
            var cls = entry['class'];
            if (cls in counts) {
                counts[cls]++;
                if (samples[cls].length < 5) {
                    samples[cls].push(entry);
                }
            } else {
                errors.push('Invalid class: ' + cls + ' for id ' + entry.id);
            }
        });

        var total = counts.FP + counts.LEGIT + counts.REVIEW;

        document.getElementById('import-fp-count').textContent = counts.FP.toLocaleString();
        document.getElementById('import-legit-count').textContent = counts.LEGIT.toLocaleString();
        document.getElementById('import-review-count').textContent = counts.REVIEW.toLocaleString();
        document.getElementById('import-total-count').textContent = total.toLocaleString();

        // Build preview table
        var tbody = document.getElementById('triage-preview-tbody');
        tbody.innerHTML = '';

        ['FP', 'LEGIT', 'REVIEW'].forEach(function(cls) {
            if (counts[cls] === 0) return;
            var cssClass = cls === 'FP' ? 'cls-fp' : cls === 'LEGIT' ? 'cls-legit' : 'cls-review';
            var sampleHtml = samples[cls].map(function(s) {
                return '<div style="margin:2px 0;"><span style="color:#666;">' +
                    htmlEscape(s.id.substring(0, 12)) + '...</span> ' +
                    htmlEscape(s.reason || 'No reason') + '</div>';
            }).join('');

            tbody.innerHTML += '<tr><td class="' + cssClass + '">' + cls + '</td>' +
                '<td>' + counts[cls].toLocaleString() + '</td>' +
                '<td>' + sampleHtml + '</td></tr>';
        });

        // Show errors if any
        var errDiv = document.getElementById('import-errors');
        if (errors.length > 0) {
            errDiv.style.display = 'block';
            errDiv.textContent = errors.length + ' error(s): ' + errors.slice(0, 5).join('; ');
        } else {
            errDiv.style.display = 'none';
        }

        document.getElementById('triage-import-preview').style.display = 'block';
        document.getElementById('btn-triage-apply').disabled = (total === 0);

        // Update dropzone text
        dz.querySelector('.triage-dropzone-text').textContent = 'File loaded: ' + total + ' classifications';
        dz.querySelector('.triage-dropzone-sub').textContent = 'Click to load a different file';
    }

    // ── Apply classifications ─────────────────────────────────────
    window.triageApply = function() {
        if (!_importData || !_importData.classifications) {
            alertify.error('No triage data loaded');
            return;
        }

        var btn = document.getElementById('btn-triage-apply');
        btn.disabled = true;
        btn.textContent = 'Applying...';

        $.ajax({
            url: docroot + '/triageimport',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(_importData),
            dataType: 'json',
            success: function(resp) {
                if (resp.success) {
                    alertify.success(
                        'Triage applied: ' + (resp.applied.fp || 0) + ' FP, ' +
                        (resp.applied.legit || 0) + ' validated, ' +
                        (resp.applied.review || 0) + ' skipped (REVIEW)'
                    );
                    triageLoadHistory();
                    // Reset import UI
                    _importData = null;
                    document.getElementById('triage-import-preview').style.display = 'none';
                    dz.querySelector('.triage-dropzone-text').textContent = 'Drop triage results file here or click to browse';
                    dz.querySelector('.triage-dropzone-sub').textContent = 'Accepts triage_output_*.json from Claude Code';
                } else {
                    alertify.error('Triage import failed: ' + (resp.error || 'unknown error'));
                }
                btn.disabled = false;
                btn.textContent = 'Apply Classifications';
            },
            error: function(xhr) {
                alertify.error('Request failed: ' + xhr.statusText);
                btn.disabled = false;
                btn.textContent = 'Apply Classifications';
            }
        });
    };

    // ── Show detail modal ─────────────────────────────────────────
    window.triageShowDetail = function() {
        if (!_importData || !_importData.classifications) return;

        var tbody = document.getElementById('triage-detail-tbody');
        tbody.innerHTML = '';

        _importData.classifications.forEach(function(entry) {
            var cls = entry['class'] || '?';
            var cssClass = cls === 'FP' ? 'cls-fp' : cls === 'LEGIT' ? 'cls-legit' : 'cls-review';
            tbody.innerHTML +=
                '<tr>' +
                '<td class="' + cssClass + '">' + htmlEscape(cls) + '</td>' +
                '<td style="color:#666;font-size:11px;">' + htmlEscape(entry.type || '') + '</td>' +
                '<td>' + htmlEscape((entry.id || '').substring(0, 16)) + '...</td>' +
                '<td style="color:#999;">' + htmlEscape(entry.reason || '') + '</td>' +
                '</tr>';
        });

        $('#triage-detail-modal').modal('show');
    };

    // ── Load triage history ───────────────────────────────────────
    function triageLoadHistory() {
        $.getJSON(docroot + '/triagehistory', function(data) {
            if (!data || !data.history || data.history.length === 0) return;
            var tbody = document.getElementById('triage-history-tbody');
            tbody.innerHTML = '';
            data.history.forEach(function(h) {
                tbody.innerHTML +=
                    '<tr>' +
                    '<td>' + htmlEscape(h.date || '') + '</td>' +
                    '<td>' + htmlEscape(h.scan_name || '') + '</td>' +
                    '<td>' + htmlEscape(h.target || '') + '</td>' +
                    '<td class="cls-fp">' + (h.fp || 0) + '</td>' +
                    '<td class="cls-legit">' + (h.legit || 0) + '</td>' +
                    '<td class="cls-review">' + (h.review || 0) + '</td>' +
                    '<td style="color:#666;">' + htmlEscape(h.applied_by || '') + '</td>' +
                    '</tr>';
            });
        });
    }

    function htmlEscape(str) {
        if (!str) return '';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }

    // Load history on page load
    triageLoadHistory();

})();
</script>

<%include file="FOOTER.tmpl"/>
