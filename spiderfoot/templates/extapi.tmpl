<%include file="HEADER.tmpl"/>
<%
import json as _json, datetime as _dt

# ── Inline SVG icons (no emojis) ────────────────────────────────────────────
_EYE = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>'
_EYE_OFF = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>'
_COPY = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>'
_PENCIL = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>'
_RESTORE = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>'
_WARN = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>'

def _fmt_ts(ts):
    if not ts: return 'Never'
    try: return _dt.datetime.utcfromtimestamp(int(ts)/1000).strftime('%Y-%m-%d %H:%M')
    except: return str(ts)

def _fmt_date(ts):
    if not ts: return 'Never'
    try: return _dt.datetime.utcfromtimestamp(int(ts)/1000).strftime('%Y-%m-%d')
    except: return str(ts)
%>
<style>
/* ────────────────────────────────────────────────────────────────────────────
   EXTERNAL API PAGE
──────────────────────────────────────────────────────────────────────────── */

/* Page header */
.xapi-header { display:flex; align-items:center; gap:14px; margin-bottom:24px; }
.xapi-title  { font-size:21px; font-weight:700; color:#eee; letter-spacing:-.3px; }
.xapi-sub    { color:#555; font-size:13px; margin-left:8px; }

/* Cards */
.xapi-card { background:#181818; border:1px solid #262626; border-radius:8px; margin-bottom:20px; overflow:hidden; }
.xapi-card-hdr {
    background:#141414; border-bottom:1px solid #222; padding:11px 18px;
    display:flex; align-items:center; justify-content:space-between;
}
.xapi-card-hdr-label {
    font-size:10px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; color:#666;
}
.xapi-card-body { padding:20px; }

/* Toggle switch */
.xapi-toggle { position:relative; display:inline-block; width:50px; height:24px; }
.xapi-toggle input { opacity:0; width:0; height:0; }
.xapi-toggle-track {
    position:absolute; cursor:pointer; inset:0; background:#2a2a2a;
    border-radius:24px; border:1px solid #333; transition:.25s;
}
.xapi-toggle-track:before {
    position:absolute; content:""; height:18px; width:18px;
    left:2px; bottom:2px; background:#555; border-radius:50%; transition:.25s;
}
.xapi-toggle input:checked + .xapi-toggle-track { background:#1c3d24; border-color:#2a5a38; }
.xapi-toggle input:checked + .xapi-toggle-track:before { background:#27ae60; transform:translateX(26px); }

/* Key table */
.key-table { width:100%; border-collapse:collapse; font-size:13px; }
.key-table thead th {
    background:#121212; color:#555; font-size:10px; font-weight:700;
    letter-spacing:1px; text-transform:uppercase; padding:10px 14px;
    border-bottom:1px solid #222;
}
.key-row td {
    padding:11px 14px; border-bottom:1px solid #1e1e1e;
    vertical-align:middle; cursor:pointer; transition:background .12s;
}
.key-row:hover td { background:#1b1b1b; }
.key-row.is-open td { background:#1c1c1c; border-bottom:none; }

/* Scope / status badges */
.badge-scope {
    display:inline-block; background:#14233a; border:1px solid #1e3a5f;
    color:#4f8ec9; padding:1px 7px; border-radius:3px;
    font-size:11px; font-family:monospace; margin:1px 2px 1px 0;
}
.badge-active  { display:inline-block; background:#162616; border:1px solid #1e3f1e; color:#27ae60; padding:2px 8px; border-radius:3px; font-size:11px; font-weight:700; letter-spacing:.4px; }
.badge-revoked { display:inline-block; background:#2a1616; border:1px solid #3f1e1e; color:#c0392b; padding:2px 8px; border-radius:3px; font-size:11px; font-weight:700; letter-spacing:.4px; }

/* Drawer */
.drawer-row td { padding:0!important; border-bottom:1px solid #222!important; background:#111!important; }
.drawer-inner {
    padding:16px 18px 18px;
    display:grid; grid-template-columns:1fr 1fr; gap:14px;
}
.drawer-full  { grid-column:1/-1; }
.drawer-panel { background:#161616; border:1px solid #222; border-radius:6px; overflow:hidden; }
.drawer-panel-hdr {
    background:#131313; border-bottom:1px solid #1e1e1e; padding:8px 12px;
    display:flex; align-items:center; justify-content:space-between;
}
.drawer-panel-label { font-size:9px; font-weight:700; letter-spacing:1.3px; text-transform:uppercase; color:#4a4a4a; }
.drawer-panel-body  { padding:13px 14px; }

/* Key-ID box (styled like code) */
.keyid-code {
    font-family:monospace; font-size:12px; color:#4f8ec9; background:#0d1824;
    border:1px solid #1a3050; border-radius:4px; padding:6px 10px;
    word-break:break-all; letter-spacing:.5px;
}

/* Raw key reveal */
.key-masked-btn {
    display:flex; align-items:center; justify-content:space-between;
    background:#0d0d0d; border:1px solid #252525; border-radius:5px;
    padding:10px 14px; cursor:pointer; transition:border-color .15s, background .15s;
    width:100%; text-align:left; font-family:monospace;
}
.key-masked-btn:hover { border-color:#4f8ec9; background:#111a25; }
.key-masked-dots { font-size:16px; color:#383838; letter-spacing:4px; flex:1; }
.key-masked-hint { display:flex; align-items:center; gap:6px; color:#3a3a3a; font-size:11px; white-space:nowrap; }
.key-masked-hint svg { color:#2a2a2a; }

.key-revealed-wrap { display:none; }
.key-revealed-box {
    display:block; width:100%; font-family:monospace; font-size:12px; color:#4f8ec9;
    background:#0d1824; border:1px solid #1a3050; border-radius:5px;
    padding:10px 14px; word-break:break-all; cursor:pointer;
    transition:border-color .15s, background .15s; letter-spacing:.5px; position:relative;
}
.key-revealed-box:hover { border-color:#27ae60; background:#0d1f14; }
.key-revealed-box:hover .copy-hint-badge { opacity:1; }
.copy-hint-badge {
    opacity:0; transition:opacity .2s;
    position:absolute; top:6px; right:8px;
    background:#0f2a18; border:1px solid #1a4a28; color:#27ae60;
    font-size:10px; padding:2px 7px; border-radius:3px; font-family:sans-serif;
    pointer-events:none;
}
.key-revealed-actions { display:flex; align-items:center; gap:7px; margin-top:8px; }
.copy-ok { font-size:11px; color:#27ae60; opacity:0; transition:opacity .3s; }
.copy-ok.show { opacity:1; }

/* Icon buttons */
.icon-btn {
    background:#1a1a1a; border:1px solid #2a2a2a; border-radius:4px;
    padding:5px 7px; color:#555; cursor:pointer; line-height:0;
    transition:border-color .15s, color .15s;
}
.icon-btn:hover { border-color:#4f8ec9; color:#4f8ec9; }
.icon-btn svg { display:block; }

/* Permissions read view */
.perm-table { width:100%; font-size:12px; }
.perm-table td { padding:3px 0; vertical-align:top; }
.perm-table td:first-child { color:#4a4a4a; width:90px; white-space:nowrap; }

/* Inline edit form */
.edit-field-group { margin-bottom:9px; }
.edit-field-label { font-size:10px; color:#555; text-transform:uppercase; letter-spacing:.6px; display:block; margin-bottom:3px; }
.edit-field-label small { text-transform:none; letter-spacing:0; font-size:10px; color:#3a3a3a; }
.edit-input {
    width:100%; background:#0e0e0e; border:1px solid #252525; border-radius:4px;
    color:#ccc; font-size:12px; padding:6px 8px;
}
.edit-input:focus { outline:none; border-color:#4f8ec9; }
.edit-scope-row { display:flex; flex-wrap:wrap; gap:10px; margin-top:3px; }
.edit-scope-lbl { display:flex; align-items:center; gap:5px; font-size:12px; color:#999; cursor:pointer; }
.edit-scope-lbl input { accent-color:#4f8ec9; cursor:pointer; }

/* Audit log */
.audit-line {
    display:flex; align-items:flex-start; gap:7px; padding:3px 0;
    border-bottom:1px solid #1a1a1a; font-size:11px; color:#555; font-family:monospace;
}
.audit-line:last-child { border-bottom:none; }
.audit-dot { width:5px; height:5px; background:#2a2a2a; border-radius:50%; flex-shrink:0; margin-top:4px; }

/* Reinstate bar */
.reinstate-bar {
    grid-column:1/-1; display:flex; justify-content:flex-end;
    padding-top:4px;
}
.btn-reinstate {
    display:inline-flex; align-items:center; gap:6px;
    background:#162616; border:1px solid #214521; color:#27ae60;
    border-radius:5px; padding:6px 14px; font-size:12px; cursor:pointer;
    transition:background .15s;
}
.btn-reinstate:hover { background:#1c3321; }

/* Create modal */
#createKeyModal .modal-content { background:#181818; color:#ddd; border:1px solid #262626; border-radius:8px; }
#createKeyModal .modal-header { background:#141414; border-bottom:1px solid #222; padding:14px 18px; }
#createKeyModal .modal-footer { background:#141414; border-top:1px solid #222; }
#createKeyModal .form-group label { font-size:10px; text-transform:uppercase; letter-spacing:.6px; color:#666; margin-bottom:5px; display:block; }
#createKeyModal .form-group label small { text-transform:none; letter-spacing:0; font-size:10px; color:#3a3a3a; }
#createKeyModal input[type=text],
#createKeyModal input[type=number] { background:#0e0e0e; border:1px solid #252525; border-radius:4px; color:#ccc; font-size:13px; }
#createKeyModal input:focus { border-color:#4f8ec9; box-shadow:none; }
.modal-scope-grid { display:flex; flex-wrap:wrap; gap:10px; margin-top:4px; }
.modal-scope-lbl { display:flex; align-items:center; gap:5px; font-size:12px; color:#999; cursor:pointer; }
.modal-scope-lbl input { accent-color:#27ae60; cursor:pointer; }

/* New key display (one-time) */
.new-key-warn {
    background:#1f1200; border:1px solid #3a2200; border-left:3px solid #e67e22;
    border-radius:4px; padding:9px 13px; font-size:12px; color:#e67e22;
    display:flex; align-items:center; gap:8px; margin-bottom:10px;
}
.new-key-box {
    background:#0d1f10; border:1px solid #194a25; border-radius:5px;
    padding:13px 15px; font-family:monospace; font-size:13px; color:#2ecc71;
    word-break:break-all; cursor:pointer; transition:border-color .15s; position:relative;
}
.new-key-box:hover { border-color:#27ae60; }
.new-key-box:hover .copy-hint-badge { opacity:1; }
.new-key-actions { display:flex; align-items:center; gap:10px; margin-top:10px; }
</style>

<div class="container-fluid" style="max-width:1140px;">
<div class="row">
<div class="col-md-12">

  <!-- PAGE HEADER -->
  <div class="xapi-header">
    <a href="${docroot}/opts" class="btn btn-default btn-sm">
      <i class="glyphicon glyphicon-arrow-left"></i> Back to Settings
    </a>
    <div>
      <span class="xapi-title">External API</span>
      <span class="xapi-sub">Trusted third-party vendor access management</span>
    </div>
  </div>

  <!-- MASTER SWITCH -->
  <div class="xapi-card">
    <div class="xapi-card-hdr">
      <span class="xapi-card-hdr-label">Master Switch</span>
    </div>
    <div class="xapi-card-body">
      <div style="display:flex; align-items:center; gap:13px; margin-bottom:12px;">
        <label class="xapi-toggle" style="margin:0;">
          <input type="checkbox" id="extApiEnabled" ${'checked' if ext_api_enabled else ''}>
          <span class="xapi-toggle-track"></span>
        </label>
        <span id="toggleLabel" style="font-weight:700; font-size:13px; letter-spacing:1.2px; color:#ccc;">
          ${'ENABLED' if ext_api_enabled else 'DISABLED'}
        </span>
      </div>
      <ul style="color:#444; font-size:12px; margin:0; padding-left:16px; line-height:2;">
        <li>When disabled, all <code>/v1/ext/*</code> endpoints return <code>503</code></li>
        <li>Existing keys remain in the database — re-enabling restores access instantly</li>
        <li>Admin key management (<code>/v1/admin/*</code>) is unaffected by this switch</li>
      </ul>
    </div>
  </div>

  <!-- VENDOR API KEYS -->
  <div class="xapi-card">
    <div class="xapi-card-hdr">
      <span class="xapi-card-hdr-label">Vendor API Keys</span>
      <button class="btn btn-success btn-sm" data-toggle="modal" data-target="#createKeyModal">
        <i class="glyphicon glyphicon-plus"></i> Add Key
      </button>
    </div>

    % if not keys:
    <div style="padding:32px; color:#3a3a3a; text-align:center; font-size:13px;">
      No vendor keys configured yet.
    </div>
    % else:
    <table class="key-table">
      <thead>
        <tr>
          <th>Client Name</th>
          <th>Scopes</th>
          <th>Targets</th>
          <th style="width:88px;">Rate (RPM)</th>
          <th style="width:96px;">Expires</th>
          <th style="width:84px;">Status</th>
          <th style="width:115px;">Last Used</th>
          <th style="width:72px;"></th>
        </tr>
      </thead>
      <tbody id="keyTableBody">
      % for key in keys:
      <%
        _scopes = []
        try: _scopes = _json.loads(key.get('scopes') or '[]')
        except: pass
        _targets = None
        try: _targets = _json.loads(key.get('allowed_targets') or 'null')
        except: pass
        _expires_ts  = key.get('expires_at')
        _expires_str = _fmt_date(_expires_ts)
        _lu_str      = _fmt_ts(key.get('last_used_at'))
        _active      = key.get('active', 0)
        _kid         = key['key_id']
        _ip_list     = []
        try:
          _p = _json.loads(key.get('ip_allowlist') or 'null')
          if _p: _ip_list = _p
        except: pass
        _ip_str = ', '.join(_ip_list) if _ip_list else 'Any'
        # expires value for edit form (YYYY-MM-DD or empty)
        _expires_edit = ''
        if _expires_ts:
          try: _expires_edit = _dt.datetime.utcfromtimestamp(int(_expires_ts)/1000).strftime('%Y-%m-%d')
          except: pass
        # targets for edit form
        _targets_edit = '' if not _targets else ', '.join(_targets)
        # ip for edit form
        _ip_edit = ', '.join(_ip_list) if _ip_list else ''
      %>
      <tr class="key-row" id="row-${_kid}" data-keyid="${_kid}" onclick="toggleDrawer('${_kid}')">
        <td><strong style="color:#ddd;">${key['client_name']}</strong></td>
        <td>
          % for s in _scopes:
          <span class="badge-scope">${s}</span>
          % endfor
        </td>
        <td style="color:#777; font-size:12px;">
          ${'ALL' if not _targets else (', '.join(_targets[:2]) + ('…' if len(_targets) > 2 else ''))}
        </td>
        <td style="color:#777;">${key.get('rate_limit_rpm', 60)}</td>
        <td style="color:#777;">${_expires_str}</td>
        <td>
          % if _active:
          <span class="badge-active">Active</span>
          % else:
          <span class="badge-revoked">Revoked</span>
          % endif
        </td>
        <td style="color:#555; font-size:12px;">${_lu_str}</td>
        <td onclick="event.stopPropagation();" style="white-space:nowrap;">
          % if _active:
          <button class="btn btn-xs btn-danger" title="Revoke key"
            onclick="revokeKey('${_kid}', '${key['client_name']}')">Revoke</button>
          % else:
          <button class="btn btn-xs btn-success" title="Reinstate key"
            onclick="reinstateKey('${_kid}', '${key['client_name']}')">Reinstate</button>
          % endif
        </td>
      </tr>

      <!-- DRAWER -->
      <tr id="drawer-${_kid}" class="drawer-row" style="display:none;">
        <td colspan="8">
          <div class="drawer-inner">

            <!-- RAW KEY (full width) ──────────────────────────────────────── -->
            <div class="drawer-full">
              <div class="drawer-panel">
                <div class="drawer-panel-hdr">
                  <span class="drawer-panel-label">Raw Key</span>
                  <span class="copy-ok" id="copy-ok-${_kid}">Copied!</span>
                </div>
                <div class="drawer-panel-body">
                  <div style="margin-bottom:11px;">
                    <div class="edit-field-label" style="margin-bottom:4px;">Key ID</div>
                    <div class="keyid-code">${key['key_id']}</div>
                  </div>
                  <div class="edit-field-label" style="margin-bottom:5px;">API Key</div>

                  <!-- MASKED STATE -->
                  <button class="key-masked-btn" id="masked-${_kid}" onclick="revealKey('${_kid}')">
                    <span class="key-masked-dots">&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;</span>
                    <span class="key-masked-hint">${_EYE | n} Reveal</span>
                  </button>

                  <!-- REVEALED STATE -->
                  <div class="key-revealed-wrap" id="revealed-${_kid}">
                    <div class="key-revealed-box" id="rawbox-${_kid}" onclick="copyRevealedKey('${_kid}')" title="Click to copy">
                      <span id="raw-${_kid}"></span>
                      <span class="copy-hint-badge">Copy</span>
                    </div>
                    <div class="key-revealed-actions">
                      <button class="icon-btn" title="Re-blur key" onclick="hideKey('${_kid}')">${_EYE_OFF | n}</button>
                      <button class="icon-btn" title="Copy to clipboard" onclick="copyRevealedKey('${_kid}')">${_COPY | n}</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- PERMISSIONS (left) ──────────────────────────────────────── -->
            <div>
              <div class="drawer-panel">
                <div class="drawer-panel-hdr">
                  <span class="drawer-panel-label">Permissions</span>
                  <button class="icon-btn" title="Edit permissions" id="editbtn-${_kid}"
                    onclick="toggleEditMode('${_kid}', event)">${_PENCIL | n}</button>
                </div>
                <div class="drawer-panel-body">

                  <!-- READ-ONLY VIEW -->
                  <div id="perms-view-${_kid}">
                    <table class="perm-table">
                      <tr>
                        <td>Scopes</td>
                        <td>
                          % for s in _scopes:
                          <span class="badge-scope">${s}</span>
                          % endfor
                        </td>
                      </tr>
                      <tr>
                        <td>Targets</td>
                        <td style="color:#888;">${'ALL' if not _targets else ', '.join(_targets)}</td>
                      </tr>
                      <tr>
                        <td>Rate Limit</td>
                        <td style="color:#888;">${key.get('rate_limit_rpm', 60)} req/min</td>
                      </tr>
                      <tr>
                        <td>IP Allowlist</td>
                        <td style="color:#888;">${_ip_str}</td>
                      </tr>
                      <tr>
                        <td>Expires</td>
                        <td style="color:#888;">${_expires_str}</td>
                      </tr>
                      <tr>
                        <td>Notes</td>
                        <td style="color:#888;">${key.get('notes') or '—'}</td>
                      </tr>
                    </table>
                  </div>

                  <!-- EDIT FORM (hidden) -->
                  <div id="perms-edit-${_kid}" style="display:none;">
                    <div class="edit-field-group">
                      <label class="edit-field-label">Scopes</label>
                      <div class="edit-scope-row">
                        <label class="edit-scope-lbl"><input type="checkbox" name="es_${_kid}" value="assets:read" ${'checked' if 'assets:read' in _scopes else ''}> assets:read</label>
                        <label class="edit-scope-lbl"><input type="checkbox" name="es_${_kid}" value="grades:read" ${'checked' if 'grades:read' in _scopes else ''}> grades:read</label>
                        <label class="edit-scope-lbl"><input type="checkbox" name="es_${_kid}" value="findings:read" ${'checked' if 'findings:read' in _scopes else ''}> findings:read</label>
                        <label class="edit-scope-lbl"><input type="checkbox" name="es_${_kid}" value="data:read" ${'checked' if 'data:read' in _scopes else ''}> data:read</label>
                      </div>
                    </div>
                    <div class="edit-field-group">
                      <label class="edit-field-label">Allowed Targets <small>(comma-separated; blank&nbsp;=&nbsp;ALL)</small></label>
                      <input class="edit-input" type="text" id="et-${_kid}" value="${_targets_edit}" placeholder="fhcsd.org, client2.org">
                    </div>
                    <div class="edit-field-group">
                      <label class="edit-field-label">Rate Limit (req/min)</label>
                      <input class="edit-input" type="number" id="er-${_kid}" value="${key.get('rate_limit_rpm', 60)}" min="1" max="10000" style="width:120px;">
                    </div>
                    <div class="edit-field-group">
                      <label class="edit-field-label">IP Allowlist <small>(CIDR; blank&nbsp;=&nbsp;any)</small></label>
                      <input class="edit-input" type="text" id="ei-${_kid}" value="${_ip_edit}" placeholder="203.0.113.0/24">
                    </div>
                    <div class="edit-field-group">
                      <label class="edit-field-label">Expires <small>(YYYY-MM-DD; blank&nbsp;=&nbsp;never)</small></label>
                      <input class="edit-input" type="text" id="ee-${_kid}" value="${_expires_edit}" placeholder="2027-01-01" style="width:150px;">
                    </div>
                    <div class="edit-field-group">
                      <label class="edit-field-label">Notes</label>
                      <input class="edit-input" type="text" id="en-${_kid}" value="${key.get('notes') or ''}">
                    </div>
                    <div style="display:flex; gap:8px; margin-top:10px;">
                      <button class="btn btn-xs btn-primary" onclick="saveKeyEdit('${_kid}')">Save Changes</button>
                      <button class="btn btn-xs btn-default" onclick="cancelEditMode('${_kid}')">Cancel</button>
                    </div>
                  </div>

                </div>
              </div>
            </div>

            <!-- ACTIVITY (right) ────────────────────────────────────────── -->
            <div>
              <div class="drawer-panel">
                <div class="drawer-panel-hdr">
                  <span class="drawer-panel-label">Activity</span>
                </div>
                <div class="drawer-panel-body">
                  <table class="perm-table" style="margin-bottom:12px;">
                    <tr>
                      <td>Last Used</td>
                      <td style="color:#888;">${_lu_str}</td>
                    </tr>
                    <tr>
                      <td>Last IP</td>
                      <td style="color:#888;">${key.get('last_used_ip') or 'N/A'}</td>
                    </tr>
                  </table>
                  <div class="edit-field-label" style="margin-bottom:6px;">Recent Requests</div>
                  <div id="audit-${_kid}" style="color:#444; font-size:11px; font-family:monospace;">
                    <em>Loading…</em>
                  </div>
                </div>
              </div>
            </div>

            <!-- REINSTATE BAR (revoked keys only) ───────────────────────── -->
            % if not _active:
            <div class="reinstate-bar">
              <button class="btn-reinstate" onclick="reinstateKey('${_kid}', '${key['client_name']}')">
                ${_RESTORE | n} Reinstate Key
              </button>
            </div>
            % endif

          </div><!-- drawer-inner -->
        </td>
      </tr>
      % endfor
      </tbody>
    </table>
    % endif
  </div><!-- xapi-card keys -->

</div><!-- col -->
</div><!-- row -->
</div><!-- container -->

<!-- ── CREATE KEY MODAL ─────────────────────────────────────────────────── -->
<div class="modal fade" id="createKeyModal" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" style="color:#aaa;">&times;</button>
        <h4 class="modal-title" style="font-size:15px; font-weight:700; color:#eee;">Create Vendor API Key</h4>
      </div>
      <div class="modal-body" id="createModalBody">
        <!-- FORM -->
        <div id="createForm">
          <div class="form-group">
            <label>Vendor / Client Name *</label>
            <input type="text" class="form-control" id="newClientName" placeholder="ACME SOC">
          </div>
          <div class="form-group">
            <label>Allowed Targets <small>(comma-separated; blank = ALL)</small></label>
            <input type="text" class="form-control" id="newTargets" placeholder="fhcsd.org, client2.org">
          </div>
          <div class="form-group">
            <label>Scopes</label>
            <div class="modal-scope-grid">
              <label class="modal-scope-lbl"><input type="checkbox" name="scope" value="assets:read" checked> assets:read</label>
              <label class="modal-scope-lbl"><input type="checkbox" name="scope" value="grades:read" checked> grades:read</label>
              <label class="modal-scope-lbl"><input type="checkbox" name="scope" value="findings:read" checked> findings:read</label>
              <label class="modal-scope-lbl"><input type="checkbox" name="scope" value="data:read"> data:read</label>
            </div>
            <small style="color:#3a3a3a; font-size:10px; margin-top:5px; display:block;">data:read grants raw scan results access — grant only when needed</small>
          </div>
          <div class="form-group">
            <label>IP Allowlist <small>(CIDR; blank = any IP)</small></label>
            <input type="text" class="form-control" id="newIpAllowlist" placeholder="203.0.113.0/24">
          </div>
          <div class="form-group">
            <label>Rate Limit (req/min)</label>
            <input type="number" class="form-control" id="newRpm" value="60" min="1" max="10000" style="width:140px;">
          </div>
          <div class="form-group">
            <label>Expires <small>(YYYY-MM-DD; blank = never)</small></label>
            <input type="text" class="form-control" id="newExpires" placeholder="2027-01-01" style="width:180px;">
          </div>
          <div class="form-group">
            <label>Notes</label>
            <input type="text" class="form-control" id="newNotes" placeholder="AI SOC integration">
          </div>
        </div>

        <!-- CREATED KEY BOX (one-time reveal) -->
        <div id="createdKeyBox" style="display:none;">
          <div class="new-key-warn">
            <span style="line-height:0;">${_WARN | n}</span>
            <span><strong>Copy your key now</strong> — it will not be shown again.</span>
          </div>
          <div class="new-key-box" id="createdRawKey" onclick="copyNewKey()" title="Click to copy">
            <span class="copy-hint-badge">Copy</span>
          </div>
          <div class="new-key-actions">
            <button class="icon-btn" title="Copy to clipboard" onclick="copyNewKey()">${_COPY | n}</button>
            <span class="copy-ok" id="new-copy-ok">Copied!</span>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal" id="createCancelBtn">Cancel</button>
        <button type="button" class="btn btn-success" id="generateKeyBtn" onclick="generateKey()">Generate Key</button>
        <button type="button" class="btn btn-primary" id="createDoneBtn" style="display:none;" onclick="doneCreating()">Done</button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Kill switch ──────────────────────────────────────────────────────────────
document.getElementById('extApiEnabled').addEventListener('change', function() {
  var on = this.checked;
  document.getElementById('toggleLabel').textContent = on ? 'ENABLED' : 'DISABLED';
  fetch('${docroot}/extapisave', {
    method: 'POST', headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({enabled: on ? '1' : '0'})
  }).then(r => r.json()).then(function(d) {
    if (!d.ok) alert('Save failed: ' + (d.error || 'unknown'));
  }).catch(function(e) { alert('Network error: ' + e); });
});

// ── Drawer toggle ────────────────────────────────────────────────────────────
var _auditLoaded = {};
function toggleDrawer(kid) {
  var row  = document.getElementById('row-' + kid);
  var drw  = document.getElementById('drawer-' + kid);
  var open = drw.style.display === '';
  if (open) {
    drw.style.display = 'none';
    row.classList.remove('is-open');
  } else {
    drw.style.display = '';
    row.classList.add('is-open');
    if (!_auditLoaded[kid]) { loadAudit(kid); _auditLoaded[kid] = true; }
  }
}

function loadAudit(kid) {
  var el = document.getElementById('audit-' + kid);
  fetch('${docroot}/extapikeyaudit?id=' + encodeURIComponent(kid) + '&limit=6')
    .then(r => r.json())
    .then(function(d) {
      if (!d.entries || !d.entries.length) {
        el.innerHTML = '<em style="color:#3a3a3a;">No activity yet.</em>'; return;
      }
      el.innerHTML = d.entries.map(function(e) {
        var ts = e.created ? new Date(e.created).toLocaleString() : '?';
        return '<div class="audit-line"><span class="audit-dot"></span>'
          + '<span>' + (e.action || e.detail || '') + ' &mdash; ' + (e.ip_address || '?') + ' &mdash; ' + ts + '</span></div>';
      }).join('');
    }).catch(function() { el.innerHTML = '<em style="color:#3a3a3a;">Could not load.</em>'; });
}

// ── Key reveal / hide ────────────────────────────────────────────────────────
function revealKey(kid) {
  fetch('${docroot}/extapikeyreveal?id=' + encodeURIComponent(kid))
    .then(r => r.json())
    .then(function(d) {
      if (!d.raw_key) { alert('Could not reveal: ' + (d.error || 'unknown')); return; }
      document.getElementById('raw-' + kid).textContent = d.raw_key;
      document.getElementById('masked-' + kid).style.display = 'none';
      var wrap = document.getElementById('revealed-' + kid);
      wrap.style.display = 'block';
    }).catch(function(e) { alert('Error: ' + e); });
}

function hideKey(kid) {
  document.getElementById('raw-' + kid).textContent = '';
  document.getElementById('masked-' + kid).style.display = '';
  document.getElementById('revealed-' + kid).style.display = 'none';
}

function copyRevealedKey(kid) {
  var val = document.getElementById('raw-' + kid).textContent;
  _copyText(val, document.getElementById('copy-ok-' + kid));
}

// ── Edit mode ────────────────────────────────────────────────────────────────
function toggleEditMode(kid, e) {
  if (e) e.stopPropagation();
  document.getElementById('perms-view-' + kid).style.display = 'none';
  document.getElementById('perms-edit-' + kid).style.display = '';
  document.getElementById('editbtn-' + kid).style.display = 'none';
}

function cancelEditMode(kid) {
  document.getElementById('perms-view-' + kid).style.display = '';
  document.getElementById('perms-edit-' + kid).style.display = 'none';
  document.getElementById('editbtn-' + kid).style.display = '';
}

function saveKeyEdit(kid) {
  var scopes = [];
  document.querySelectorAll('input[name="es_' + kid + '"]:checked').forEach(function(cb) { scopes.push(cb.value); });
  if (!scopes.length) { alert('Select at least one scope.'); return; }

  var payload = {
    id:          kid,
    scopes:      scopes,
    targets:     document.getElementById('et-' + kid).value.trim(),
    rpm:         parseInt(document.getElementById('er-' + kid).value) || 60,
    ip_allowlist: document.getElementById('ei-' + kid).value.trim(),
    expires:     document.getElementById('ee-' + kid).value.trim(),
    notes:       document.getElementById('en-' + kid).value.trim()
  };

  fetch('${docroot}/extapikeyupdate', {
    method: 'POST', headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(payload)
  }).then(r => r.json()).then(function(d) {
    if (d.ok) { location.reload(); }
    else { alert('Save failed: ' + (d.error || 'unknown')); }
  }).catch(function(e) { alert('Error: ' + e); });
}

// ── Revoke ───────────────────────────────────────────────────────────────────
function revokeKey(kid, name) {
  if (!confirm('Revoke API key for "' + name + '"?\n\nRequests using this key will be blocked immediately.\nThe key record is preserved for audit purposes.')) return;
  fetch('${docroot}/extapirevoke?id=' + encodeURIComponent(kid))
    .then(r => r.json())
    .then(function(d) {
      if (d.ok) location.reload();
      else alert('Failed: ' + (d.error || 'unknown'));
    }).catch(function(e) { alert('Error: ' + e); });
}

// ── Reinstate ────────────────────────────────────────────────────────────────
function reinstateKey(kid, name) {
  if (!confirm('Reinstate API key for "' + name + '"?\n\nThis will immediately restore access for this key.')) return;
  fetch('${docroot}/extapireinstate?id=' + encodeURIComponent(kid))
    .then(r => r.json())
    .then(function(d) {
      if (d.ok) location.reload();
      else alert('Failed: ' + (d.error || 'unknown'));
    }).catch(function(e) { alert('Error: ' + e); });
}

// ── Create new key ───────────────────────────────────────────────────────────
function generateKey() {
  var name = document.getElementById('newClientName').value.trim();
  if (!name) { alert('Vendor name is required.'); return; }

  var scopes = [];
  document.querySelectorAll('input[name="scope"]:checked').forEach(function(cb) { scopes.push(cb.value); });
  if (!scopes.length) { alert('Select at least one scope.'); return; }

  var targetsRaw = document.getElementById('newTargets').value.trim();
  var targets = targetsRaw ? targetsRaw.split(',').map(s => s.trim()).filter(Boolean) : null;

  var ipRaw = document.getElementById('newIpAllowlist').value.trim();
  var ipList = ipRaw ? ipRaw.split(',').map(s => s.trim()).filter(Boolean) : null;

  var expiresStr = document.getElementById('newExpires').value.trim();
  var expiresAt = null;
  if (expiresStr) {
    var d = new Date(expiresStr + 'T00:00:00Z');
    if (isNaN(d)) { alert('Invalid expiry date. Use YYYY-MM-DD.'); return; }
    expiresAt = d.getTime();
  }

  var btn = document.getElementById('generateKeyBtn');
  btn.disabled = true;
  btn.textContent = 'Creating…';

  fetch('${docroot}/extapicreatekey', {
    method: 'POST', headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      client_name:     name,
      scopes:          scopes,
      allowed_targets: targets,
      ip_allowlist:    ipList,
      rate_limit_rpm:  parseInt(document.getElementById('newRpm').value) || 60,
      expires_at:      expiresAt,
      notes:           document.getElementById('newNotes').value.trim() || null
    })
  }).then(r => r.json()).then(function(d) {
    if (d.raw_key) {
      // show key text directly inside the box element
      var box = document.getElementById('createdRawKey');
      // insert text node before the hint badge
      box.insertBefore(document.createTextNode(d.raw_key), box.firstChild);
      document.getElementById('createForm').style.display = 'none';
      document.getElementById('createdKeyBox').style.display = '';
      btn.style.display = 'none';
      document.getElementById('createCancelBtn').style.display = 'none';
      document.getElementById('createDoneBtn').style.display = '';
    } else {
      alert('Error: ' + (d.error || JSON.stringify(d)));
      btn.disabled = false;
      btn.textContent = 'Generate Key';
    }
  }).catch(function(e) {
    alert('Network error: ' + e);
    btn.disabled = false;
    btn.textContent = 'Generate Key';
  });
}

function copyNewKey() {
  var box = document.getElementById('createdRawKey');
  // grab first text node
  var txt = '';
  box.childNodes.forEach(function(n) { if (n.nodeType === 3) txt += n.textContent; });
  _copyText(txt.trim(), document.getElementById('new-copy-ok'));
}

function doneCreating() {
  document.getElementById('createKeyModal').querySelector('[data-dismiss="modal"]').click();
  location.reload();
}

// ── Shared copy helper ───────────────────────────────────────────────────────
function _copyText(text, feedbackEl) {
  var done = function() {
    if (!feedbackEl) return;
    feedbackEl.classList.add('show');
    setTimeout(function() { feedbackEl.classList.remove('show'); }, 1800);
  };
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(done).catch(function() {
      _fallbackCopy(text); done();
    });
  } else {
    _fallbackCopy(text); done();
  }
}

function _fallbackCopy(text) {
  var ta = document.createElement('textarea');
  ta.value = text;
  ta.style.cssText = 'position:fixed;top:-9999px;';
  document.body.appendChild(ta);
  ta.focus(); ta.select();
  try { document.execCommand('copy'); } catch(e) {}
  document.body.removeChild(ta);
}
</script>

